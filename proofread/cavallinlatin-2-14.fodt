ktur">se</text:span> Sterno.<text:line-break/>Astipul . . . <text:span text:style-name="Fraktur">se</text:span> Stipulor.<text:line-break/>Astituo <text:span text:style-name="Fraktur">se</text:span> Statuo, Sto. <text:line-break/>Asto <text:span text:style-name="Fraktur">se</text:span> Sto.<text:line-break/>Astrepo <text:span text:style-name="Fraktur">se</text:span> Strepo. <text:line-break/>Astriet . . ., Astringo <text:span text:style-name="Fraktur">se</text:span> Stringo.<text:line-break/>Astrido, Astruo, Astupeo <text:span text:style-name="Fraktur">se</text:span> Strido, Struo, Stupeo, <text:line-break/>Atritas <text:span text:style-name="Fraktur">se</text:span> Ater.<text:line-break/>Attactus <text:span text:style-name="Fraktur">se</text:span> Attingo, Tango,<text:line-break/>Attemper . . . <text:span text:style-name="Fraktur">se</text:span> Tempus. <text:line-break/>Attempto, Attento <text:span text:style-name="Fraktur">se</text:span> Tento.<text:line-break/>Attent . . . <text:span text:style-name="Fraktur">se för öfrigt</text:span> Attendo, Tendo.<text:line-break/>Attenu . . . <text:span text:style-name="Fraktur">se</text:span> Tenuis.<text:line-break/>Attero <text:span text:style-name="Fraktur">se</text:span> Tero. = Atterraneus <text:span text:style-name="Fraktur">se</text:span> Terra.<text:line-break/>Attest . . . <text:span text:style-name="Fraktur">se</text:span> Testis. <text:line-break/>Attexo <text:span text:style-name="Fraktur">se</text:span> Texo.<text:line-break/>Attineo <text:span text:style-name="Fraktur">se</text:span> Teneo. <text:line-break/>Attingo <text:span text:style-name="Fraktur">se</text:span> Tango.</text:p>
