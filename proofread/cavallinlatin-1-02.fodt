   <text:p text:style-name="P1"><text:span text:style-name="T3">Cătīnus,</text:span> i, <text:span text:style-name="T2">m.</text:span> <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Cătīnum</text:span>, i, <text:span text:style-name="T2">n.</text:span> (Cato): <text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T3">Skål, tallrik:</text:span></text:span> Varr., Hor., Juv., Su. <text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T3">Smältdegel:</text:span></text:span> Pn.<text:line-break/>3. <text:span text:style-name="Fraktur">fördjupning i skålform,</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Cătillus</text:span>, i, <text:span text:style-name="T2">m.</text:span>: <text:span text:style-name="T2">Dem.</text:span>: <text:span text:style-name="Fraktur">liten </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T3">Tallrik, skål</text:span></text:span><text:span text:style-name="Fraktur"> eller hwad som har form deraf:</text:span> Cato, Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Cătillo</text:span>, ōnis, <text:span text:style-name="T2">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T3">Tallrik-, fat-slickare:</text:span></text:span> Su.</text:p>
