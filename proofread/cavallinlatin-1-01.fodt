 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
   </text:sequence-decls>
   <text:p text:style-name="P2"><text:span text:style-name="Fraktur">Motkämpe, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Medtäflare</text:span></text:span><text:span text:style-name="Fraktur"> i lärda strider l. idrotter:</text:span> Qu., Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Antispastos,</text:span> i, <text:span text:style-name="T3">m.:</text:span> v. gr.: <text:span text:style-name="Fraktur">versfoten</text:span> <text:span text:style-name="T5">⏑——⏑</text:span>, Diom.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ntissa, ae, <text:span text:style-name="T3">f.:</text:span> <text:span text:style-name="Fraktur">gr. stadsnamn.</text:span></text:p>
   <text:p text:style-name="P1">Antistes, <text:line-break/>Antistĭta <text:span text:style-name="Fraktur">se</text:span> Sto.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ntisthĕnes, is, <text:span text:style-name="T3">m.:</text:span> <text:span text:style-name="Fraktur">gr. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ntistius, <text:span text:style-name="Fraktur">Rom. gentilnamn.</text:span></text:p>
   <text:p text:style-name="P1">Antisto <text:span text:style-name="Fraktur">se</text:span> Sto.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Antĭthĕsis,</text:span> is, <text:span text:style-name="T3">f.:</text:span> v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Antithes,</text:span></text:span><text:span text:style-name="Fraktur"> symmetrisk motställning af motsatta begrepp.</text:span> <text:line-break/><text:span text:style-name="T6">Antithĕton</text:span>, i, <text:span text:style-name="T3">n.:</text:span> <text:span text:style-name="Fraktur">motsats, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Antithes</text:span></text:span><text:span text:style-name="Fraktur"> i saklig betydelse:</text:span> Ps.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ntium, ii, <text:span text:style-name="T3">n.:</text:span> <text:span text:style-name="Fraktur">Sjöstad i Latium.</text:span> <text:line-break/>Antiās, ātis, <text:line-break/>Antiensis, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Antlĭa,</text:span> ae, <text:span text:style-name="T3">f.:</text:span> v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Pumpwerk:</text:span></text:span> Mt. - <text:span text:style-name="Fraktur">såsom ställe för straffarbete:</text:span> in a-am condemnare, Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ntōnius, <text:span text:style-name="Fraktur">Rom. gentilnamn.</text:span> <text:line-break/>Antoniānus, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Antōnīnus, <text:span text:style-name="Fraktur">Rom. cognomen.</text:span> <text:line-break/>Antōninianus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ntŏnŏmăsĭa, ae, <text:span text:style-name="T3">f.:</text:span> <text:span text:style-name="Fraktur">rhetorisk figur, som består deri, att ett epithet sättes i stället för saknamnet.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Antrum,</text:span> i, <text:span text:style-name="T3">n.:</text:span> v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Grotta:</text:span></text:span> gelidum, viride, Vg., Pierium, Hor., Juv.; domus (primæ hominum) antra fuere, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>nūbis, is, <text:span text:style-name="Fraktur">l.</text:span> -ĭdis, <text:span text:style-name="T3">m.:</text:span> <text:span text:style-name="Fraktur">Egyptisk gudomlighet, som afbildades med hundhufwud, deraf</text:span> latrator A., Vg.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ānus,</text:span> i, <text:span text:style-name="T3">m.:</text:span> <text:span text:style-name="Fraktur">i allm. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ring:</text:span></text:span><text:line-break/>a. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fotblack:</text:span></text:span> Pt.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ändtarm:</text:span></text:span> C.<text:line-break/><text:span text:style-name="T6">Ānŭlus</text:span> <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/><text:span text:style-name="T6">Annŭlus</text:span>, i <text:span text:style-name="T3">m.:</text:span> <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ring:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i allm.:</text:span> a. catenæ; a. velaris <text:span text:style-name="Fraktur">(gardinring),</text:span> Pn.; = anus b., Cato; a. comarum <text:span text:style-name="Fraktur">(hårlock),</text:span> Mt.<text:line-break/>2. <text:span text:style-name="Fraktur">serskildt: Finger-</text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">ring</text:span></text:span><text:span text:style-name="Fraktur"> (hwars infattning</text:span> (pala) <text:span text:style-name="Fraktur">brukades såsom sigill):</text:span> tabulas a-o signare, Pt.; in cerā sigilla a-o imprimere; palam a-i ad manum convertere, C.; a. aureus <text:span text:style-name="Fraktur">war riddare-ståndets utmärkelse-tecken,</text:span> C., Pn. - <text:span text:style-name="Fraktur">deraf:</text:span> a-o aureo donare = equitem facere, C.; - gemmati a-i magna specie, L.; a-us digito (puellæ) male pertinaci ereptus, Hor.; a. signatorius, Val.<text:line-break/><text:span text:style-name="T6">Ānŭlāris</text:span>,<text:line-break/><text:span text:style-name="T6">Ānŭlārius</text:span>, <text:span text:style-name="T3">A.:</text:span> <text:span text:style-name="Fraktur">som hör till, brukas till ring l. har form deraf, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ring-:</text:span></text:span> creta <text:span text:style-name="Fraktur">(hwarmed förseglas),</text:span> Vitr.; scalæ a., Su.<text:line-break/><text:span text:style-name="T6">Ānŭlātus</text:span>, <text:span text:style-name="T3">A.:</text:span> <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ring-prydd:</text:span></text:span> aures, Pt.<text:line-break/><text:soft-page-break/><text:span text:style-name="T6">Ānellus</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T6">Annellus</text:span>, i, <text:span text:style-name="T3">m.: Dem.:</text:span> <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Liten ring:</text:span></text:span> Pt., Lucr., Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ănus,</text:span> ūs, <text:span text:style-name="T3">f.:</text:span><text:line-break/>a. <text:span text:style-name="T3">A.:</text:span> <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gammal, åldrig:</text:span></text:span> avia, Ct.; cerva, Ov.; charta, Mt.<text:line-break/>b. <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gumma, käring:</text:span></text:span> decrepita, Ter.; prudens, Hor.; pauper, sed mundæ sedulitatis a.; comis, Ov.; - Quæ a. est tam delira, quæ ista credat, C.<text:line-break/><text:span text:style-name="T6">Ănĭcŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.:</text:span> <text:span text:style-name="Fraktur">stackars gumma; eländig käring:</text:span> Ter., C. <text:line-break/><text:span text:style-name="T6">Ănĭcilla</text:span>, <text:line-break/>Ănucella, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.:</text:span> Varr., Fr. <text:line-break/><text:span text:style-name="T6">Ănīlis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:line-break/>a. <text:span text:style-name="Fraktur">sådan som en gummas, en gummas, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">gummo-:</text:span></text:span> gradum studio properabat a-i, Vg.; ignem suscitare anima anili, Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Käringaktig, käring-:</text:span></text:span> ineptiæ, fabellæ, C.<text:line-break/><text:span text:style-name="T6">Ănīlĭter</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Käringaktigt, som en käring:</text:span></text:span> C.<text:line-break/><text:span text:style-name="T6">Ănīlĭtas</text:span>, ātis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">gummåldren:</text:span> Catl.<text:line-break/><text:span text:style-name="T6">Ănīlĭtor</text:span>, Dep. 1.: <text:span text:style-name="Fraktur">bli gammal:</text:span> Ap.</text:p>
   <text:p text:style-name="P1">Anxius, <text:line-break/>Anxietas, <text:line-break/>Anxĭtūdo <text:span text:style-name="Fraktur">se</text:span> Ango.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>nxur, ŭris, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">stad i Latium.</text:span> <text:line-break/>Anxŭrus, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">ss. epithet för Jupiter.</text:span> <text:line-break/>Anxŭras, ātis, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ā</text:span>on, ŏnis, <text:span text:style-name="Fraktur">och</text:span> <text:line-break/>Āonius, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">Boeotisk.</text:span> <text:line-break/>Āonia, ae, <text:span text:style-name="T3">f.</text:span> = <text:span text:style-name="Fraktur">Boeotien.</text:span><text:line-break/><text:span text:style-name="T1">Ā</text:span>ŏnĭdes, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">patron.</text:span> <text:line-break/>Āŏnis, ĭdis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">patron. af</text:span> Aonia, <text:span text:style-name="Fraktur">om Muserna på Helicon.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăornos,</text:span> <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur">utan foglar, der foglar ej kunna wistas,</text:span> Vg. (l. d.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>ōus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. flodnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpăge,</text:span> v. gr. <text:span text:style-name="Fraktur">(egentl. imperativus af</text:span> ἀπάγειν = <text:span text:style-name="Fraktur">för l. drag bort!): </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bort!, bort med!, Åh!:</text:span></text:span> a., sis (si vis), amor; a. te, a. istum, Pt.; a. te, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pămēa, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">asiatiskt stadsnamn.</text:span> <text:line-break/>Ăpămensis, <text:line-break/>Ăpămēnus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăparctiās,</text:span> ae, <text:span text:style-name="T3">m.</text:span>: v. gr.: <text:span text:style-name="Fraktur">nordanwind:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpēliōtes</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T6">Ăphēliōtes</text:span>, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">östanwind:</text:span> Catl.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pelles, is, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span> <text:line-break/>Ăpellēus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ā</text:span>pennīnus <text:line-break/>(Āppennīnus), i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">bergssträcka i Italien, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Apenninerna:</text:span></text:span> C., L. <text:line-break/><text:span text:style-name="T6">Āpennīnĭcŏla</text:span>, ae, <text:span text:style-name="T3">c.</text:span>: <text:span text:style-name="Fraktur">som bor på l. wid A.</text:span> <text:line-break/><text:span text:style-name="T6">Āpennīnĭgĕna</text:span>, ae, <text:span text:style-name="T3">c.</text:span>: <text:span text:style-name="Fraktur">som uppkommer från</text:span> <text:span text:style-name="T3">A.</text:span>: Thybris, Ov.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Ăper,</text:span> ri, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wildswin;</text:span></text:span> capere, Pt.; a-i spumantis cursum clamore premere, Vg.; a. trux, ferus, torvus, Ov.; fruticeto latitantem a-um excipere; Umber iligna nutritus glande lances curvat, Hor.; a. animal propter convivia natum, Juv.<text:line-break/><text:span text:style-name="T6">Ăpra</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: Pn. <text:line-break/><text:span text:style-name="T6">Ăprīnus</text:span>,<text:line-break/><text:span text:style-name="T6">Ăprugnus</text:span>,<text:line-break/><text:span text:style-name="T6">Ăprūnus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">som är af wildswin, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wildswins- :</text:span></text:span> caro, callum, fel, Pt., Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpĕrio,</text:span> ĕrui, ert., 4.: <text:span text:style-name="Fraktur">(af owiß rot, jfr</text:span> operio): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afhölja; öppna:</text:span></text:span><text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afhölja, blotta, bringa i dagen, wisa;</text:span></text:span><text:span text:style-name="Fraktur"> refl. och pass.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Träda fram i dagen, bli synlig:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i eg. men.:</text:span> partes corporis, caput, pectus; stellæ a-untur, C.; dispulsa nebula diem a-uit, L.; a-it (Sibylla) ramum, qui veste latebat; unda dehiscens terram inter fluctus a-it; terra - se attollere visa - aperire procul montes et volvere fumum; Apollo <text:span text:style-name="Fraktur">(A:s tempel)</text:span> nautis a-itur, Vg.; maturos a-ire partus lenis Ilithyia; nulli malo obdere latus apertum, Hor.; sic exhausta nocte novam aciem dies a-uit, T.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.: med ord l. handling </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bringa, lägga i dagen, bringa, sprida ljus i, öfwer ngt, uppenbara, yppa, röja, wisa:</text:span></text:span> probra alicujus, Pt.; argumentum fabulæ; se a. <text:span text:style-name="Fraktur">(röja sig),</text:span> Ter.; sententiam suam alicui de aliqua re, C.; mores suos <text:span text:style-name="Fraktur">(wisa);</text:span> consilium, rem, vera <text:span text:style-name="Fraktur">(yppa);</text:span> conjurationem <text:span text:style-name="Fraktur">(upptäcka);</text:span> socios sceleris <text:span text:style-name="Fraktur">(röja),</text:span> Sa.; ignorando regem, quis esset, a-uit, L.; (exspectandum censuerunt,) dum res se ipsa aperiret; alicui sensus suos; clementiam; a-ire, se non fortunæ, sed hominibus solere esse amicum, N.; futura a-ire, Vg.; id Marcius uxori a-uit; ambages a-ire et copiam veri facere, T.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Förklara, utreda:</text:span></text:span> occulta et quasi involuta a-ire; involutæ rei notitiam definiendo, C.; Nunc Jovis incipiam causas a-ire Feretri, Ppt.<text:line-break/>II. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppna, upplåta, öppna tillträde till något, göra tillgänglig:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i eg. men.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> ostium, fores, fenestram, Ter., C.; epistolam, oculos; ludum <text:span text:style-name="Fraktur">(skola),</text:span> C.; portam, ærarium, Cs., L.; asylum <text:span text:style-name="Fraktur">(till en fristad)</text:span> locum - -, L.; Trojam a. Achivis, Vg.; arbor florem, Pn.<text:line-break/>b. <text:span text:style-name="Fraktur">om wägar, grafwar, brunnar: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bana, anlägga, gräfwa:</text:span></text:span> iter ferro, Sa.; viam, L.; specus subterraneos, T.; fontes, C.<text:line-break/>c. <text:span text:style-name="Fraktur">om ställen, länder och folk: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Rödja, göra tillgänglig, öppna förbindelser</text:span></text:span><text:span text:style-name="Fraktur"> med -:</text:span> saltum, L.; Pompejus Pontum a-uit, C.; omnes terras fortibus viris natura a-uit; bellum, expeditio gentes, reges a-uit, T.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. = <text:span text:style-name="Fraktur">öppna, lemna öppen; bereda:</text:span> Non est ita claudenda res familiaris ut eam benignitas a-ire non possit; fores amicitiæ; locum crimini aut suspicioni; alicui cursum ad laudem, C.; occasionem alicui ad aliquid, iter alicui, viam alicui rei, L.; casum (i. e. occasionem, locum) insidiantibus ap., T.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppna</text:span></text:span><text:span text:style-name="Fraktur"> = börja:</text:span> annum, Vg., Pn.<text:line-break/>part.:<text:line-break/><text:span text:style-name="T6">Ăpertus</text:span>, <text:span text:style-name="T3">A.</text:span>: p. tr. gr.: <text:line-break/><text:soft-page-break/>1. <text:span text:style-name="Fraktur">i eg. men.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Obetäckt;</text:span></text:span><text:span text:style-name="Fraktur"> om luft: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">ren, klar:</text:span></text:span> caput, Pt.; pectus a., C.; latus, Cs.; naves, C., Cs.; æther, caelum, Vg.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppen, fri</text:span></text:span><text:span text:style-name="Fraktur"> (ej instängd, bewuxen, bebyggd o. s. w.):</text:span> locus, C., Cs.; campus, collis, mare, litus, Oceanus, Cs., L.; aditus a-ior, L.; æquor, Vg.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Uppenbar, ohöljd, klar, tydlig:</text:span></text:span> exemplum rem a-iorem facit; a-a actio rerum; reus a-us <text:span text:style-name="Fraktur">(hwars skuld är klar),</text:span> narratio, C.; oratio, Qu.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Oförställd, öppen</text:span></text:span><text:span text:style-name="Fraktur"> (om personer och saker):</text:span> homo, animus, dolor, latrocinium, C.; homo, Cs.; apertam in rabiem verti coepit jocus, Hor.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Utsatt</text:span></text:span><text:span text:style-name="Fraktur"> för -:</text:span> a. ad injuriam, ad reprehendendum, C.<text:line-break/><text:span text:style-name="T6">Ăpertum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppen, fri plats</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">rymd:</text:span></text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> castra in a-o locare, L.; per a-um fugientes cervos jaculari, Hor.; a-a maris, T.<text:line-break/>b. <text:span text:style-name="Fraktur">oeg.:</text:span> in a-o esse <text:span text:style-name="Fraktur">(synon. -</text:span> in promtu esse) = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wara tydlig; wara till hands, ej möta hinder:</text:span></text:span> pauca supra repetam, quo magis illustria omnia magisque in aperto sint, Sa.; veniunt (hostes) e latebris suis extrusi, et vota virtusque in a-o sunt; - integro exercitus robore fessos hostes aggredi in a-o (fuit), T.<text:line-break/><text:span text:style-name="T6">Ăpertē</text:span>, <text:span text:style-name="T3">Adv.</text:span>: p. tr. gr.:<text:line-break/>a. <text:span text:style-name="Fraktur">(i sig) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Tydligt, klart:</text:span></text:span> loqui, narrare, Ter.; dicere, mentiri, scribere a-e; ponere aliquid a-e falsum; quam a-issime explicare aliquid, C.; ostendere, Qu.<text:line-break/>b. <text:span text:style-name="Fraktur">(till afsigten) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppet</text:span></text:span><text:span text:style-name="Fraktur"> (utan förställning, utan att dölja sig l. sin afsigt):</text:span> a-e adulantem nemo non videt; a-e vel odisse magis ingenui est quam fronte occultare sententiam; <text:s/>a. ferre lætitiam, C.; bellum parare, Cs.; totius Numidiæ imperium a. petere; rogationi a-e resistere non poterant, Sa.; Fidenæ a-e desciverunt, L.; a-e ostendit, quod venale habet, Hor.<text:line-break/><text:span text:style-name="T6">Ăpertĭlis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">som kan öppnas:</text:span> latus tauri, Ov.<text:line-break/><text:span text:style-name="T6">Ăpertio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppnande:</text:span></text:span> Varr., Pal.<text:line-break/><text:span text:style-name="T6">Ăpertūra</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppning</text:span></text:span><text:span text:style-name="Fraktur"> i abstract och concret men.:</text:span> Vitr. <text:line-break/><text:span text:style-name="T6">Ăperto</text:span>, 1. Frequ.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afhölja, blotta:</text:span></text:span> a-re caput, Val., ora a-ata, Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppna:</text:span></text:span> fores a-tæ, L.; januam a-re; pars fenestræ a-ata, Ov.; cuniculum <text:span text:style-name="Fraktur">(öppna, gräfwa),</text:span> L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ĭnăpertus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ej öppen, tillgänglig</text:span></text:span><text:span text:style-name="Fraktur"> för -:</text:span> senectus fraudi, Sil. <text:line-break/><text:span text:style-name="T6">Sēmĭăpertus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Half-öppen:</text:span></text:span> fores portarum, L.</text:p>
   <text:p text:style-name="P1">Apes <text:span text:style-name="Fraktur">se</text:span> Apis.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpex,</text:span> ĭcis, <text:span text:style-name="T3">m.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">i allm.: (kegelformig) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Spets, topp:</text:span></text:span> lauri, galeæ, flammæ <text:span text:style-name="Fraktur">(af en låga),</text:span> Vg.; flammeus, Ov.; volucrum, Pn. <text:line-break/>2. <text:span text:style-name="Fraktur">kegelformig hufwudbetäckning:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">för Romerske prester, serskildt</text:span> flamen Dialis: cuilibet a-em dialem, modo homo sit, imponamus, L.<text:line-break/>b. <text:span text:style-name="Fraktur">för konungar och furstar: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Diadem, tiar:</text:span></text:span> regum a-es; hinc a-em rapax fortuna cum stridore acuto sustulit, hic posuisse gaudet, Hor. - <text:span text:style-name="Fraktur">bildl.:</text:span> apex <text:span text:style-name="Fraktur">(hederskrona)</text:span> est senectutis auctoritas, C.<text:line-break/>3. <text:span text:style-name="Fraktur">skrift-tecken</text:span> (^), <text:span text:style-name="Fraktur">hwarmed vocalers längd utmärkes:</text:span> Qu. - <text:span text:style-name="Fraktur">skrift-</text:span><text:soft-page-break/><text:span text:style-name="Fraktur">tecken öfwerhufwud:</text:span> Gell. <text:line-break/><text:span text:style-name="T6">Ăpĭcātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">klädd i</text:span> apex: flamen: Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Apexăbo,</text:span> ōnis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Korf:</text:span></text:span> Varr. (d. l.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>phærĕsis, is, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">en stafwelses bortfallande:</text:span> Gramm.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>phăreus, ei, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span> <text:line-break/>Ăphărēius, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>pheliotes <text:span text:style-name="Fraktur">se</text:span> Apeliotes.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăphractus,</text:span> i, <text:span text:style-name="T3">f.</text:span>:<text:line-break/><text:span text:style-name="T6">Ăphractum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Odäckadt fartyg:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>phrŏdīte, es, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Ăphrŏdīta, æ, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">skönhetens gudinna, på lat.</text:span> Venus. <text:line-break/>Ăphrŏdīsia, ōrum, <text:span text:style-name="T3">n.</text:span>: Aphrodites <text:span text:style-name="Fraktur">fest:</text:span> Pt. <text:line-break/>Ăphrŏdīsias, ădis, <text:span text:style-name="T3">f.</text:span> <text:line-break/>Ăphrŏdīsium, ii, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">stadsnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ăphrŏnĭtrum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Salpeterskum:</text:span></text:span> Pn., St.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăphye,</text:span> ēs, <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Ăphya, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">äfwen</text:span><text:line-break/><text:span text:style-name="T6">Ăpua</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Anjovis:</text:span></text:span> Pn.</text:p>
   <text:p text:style-name="P1">Apiacus <text:span text:style-name="Fraktur">se</text:span> Apium.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>piānus, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">tillnamn för ett slags drufwor och win:</text:span> A-is vitibus apes dedere cognomen præcipue earum avidæ, Pn.</text:p>
   <text:p text:style-name="P1">Apiarius <text:span text:style-name="Fraktur">se</text:span> Apis.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pica ovis = <text:span text:style-name="Fraktur">som ej har ull under buken:</text:span> Varr. </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ăpīcius</text:span>,<text:line-break/>a. <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">tilln. för ett slags drufwor och win, kanske af</text:span> apis = apianus <text:span text:style-name="Fraktur">(Muskat-win):</text:span> vinum, uva, a., Cato, Varro.<text:line-break/>b. <text:span text:style-name="Fraktur">Rom. tillnamn, som tillhörde l. tillades flere såsom gastronomer berömda personer.</text:span> <text:line-break/>Ăpīcianus, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Läcker, delicat:</text:span></text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ā</text:span>pĭdănus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. flodnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpĭnæ,</text:span> ārum, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lappri, gyckel:</text:span></text:span> Mt. <text:line-break/>Ăpĭnārius, ii, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gyckelmakare:</text:span></text:span> Treb. </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>piŏlæ, ārum, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Latium.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ā</text:span>pion, ōnis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpis,</text:span> is, <text:line-break/>(Ăpēs, is, Prisc.), <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bi:</text:span></text:span> a-ium examina congregantur, fingunt favos, C.; a-is parca, sedula; a-es insidunt floribus, stipant fragrantia mella, Vg.; a. grata carpit thyma per laborem plurimum, Hor.<text:line-break/><text:span text:style-name="T6">Ăpiārius</text:span>, ii, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bi-odlare, -skötare:</text:span></text:span> Pn.<text:line-break/><text:span text:style-name="T6">Ăpiārium</text:span>, ii, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bihus:</text:span></text:span> Col.<text:line-break/><text:span text:style-name="T6">Ăpĭcŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: Pt., Pn.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Ā</text:span>pis, is, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">Egyptisk gudomlighet, som troddes tid efter annan uppenbara sig i oxgestalt.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpiscor,</text:span> aptus, 3. <text:span text:style-name="Fraktur">(jfr</text:span> aptus):<text:line-break/>1. <text:span text:style-name="Fraktur">passiv.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Winnas:</text:span></text:span> non ætate, verum ingenio apiscitur sapientia, Pt.<text:line-break/>2. Dep.:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nå, hinna, komma till; träffa:</text:span></text:span> mortem aptus est, <text:span text:style-name="Fraktur">epigram om</text:span> Pt. <text:span text:style-name="Fraktur">hos</text:span> Gell.; mare, C.; contagia morbi alios ex aliis, Lucr.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ernå, få, winna, tillegna sig;</text:span></text:span><text:span text:style-name="Fraktur"> med förståndet </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">tillegna sig</text:span></text:span><text:span text:style-name="Fraktur"> (fatta, lära):</text:span> hereditatem, Pt.; honores, L.; favorem, dominationis apisci, T.; ratione animi aliquid <text:span text:style-name="Fraktur">(jfr</text:span> assequor), Lucr.; artem Chaldæorum, T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ădĭpiscor</text:span>, ădeptus, 3.:<text:line-break/>1. passive: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Uppnås,</text:span></text:span><text:span text:style-name="Fraktur"> hos andra än archaistiske förff. blott i part.</text:span> pf. adeptus = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Uppnådd, ernådd, wunnen:</text:span></text:span> senectutem - omnes accusant a-tam, C.; civitas - -, a-ā libertate, brevi crevit; victoriā a-ā, Sa.; principatus <text:span text:style-name="Fraktur">(tillträdd),</text:span> T. <text:line-break/>2. Dep.:<text:line-break/>a. <text:span text:style-name="Fraktur">i rum l. tid: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hinna, upphinna</text:span></text:span><text:span text:style-name="Fraktur"> någon, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">hinna</text:span></text:span><text:span text:style-name="Fraktur"> till ngt:</text:span> fugientes, L.; senectutem ut adipiscantur, omnes optant, C. <text:line-break/>b. <text:span text:style-name="Fraktur">i factiska förhållanden: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hinna, komma</text:span></text:span><text:span text:style-name="Fraktur"> (stiga) till ngt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">uppnå, åstadkomma; ernå, winna:</text:span></text:span> aliquantum se a-tos esse <text:span text:style-name="Fraktur">(hafwa gjort ett betydligt framsteg)</text:span> arbitrantur et ad dicendum et ad judicandum; sapientiam; amplissimos dignitatis gradus; hoc mirum est, quod vis divina assequi non possit, si id mens humana a-ta non sit; his et adipiscendi honores et gerenda respublica est, laudem ab omnibus a., C.; victoriam, Cs.; consulatum, victoriam, gloriam, otium, Sa.; libertatem, jus suum, L.; crimen <text:span text:style-name="Fraktur">(ådraga sig),</text:span> Ov.; rerum a-i <text:span text:style-name="Fraktur">(i analogi med</text:span> potiri), T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ădeptio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ernående:</text:span></text:span> boni, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Indĭpiscor</text:span>, indeptus, 3.:<text:line-break/>1. pass.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Winnas:</text:span></text:span> Pt.<text:line-break/>2. Depon.:<text:line-break/>a. <text:span text:style-name="Fraktur">i rummet </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hinna, upphinna:</text:span></text:span> navem, L.; maritum Psyche, Ap. <text:line-break/>b. <text:span text:style-name="Fraktur">i oeg. men.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Komma, gå till, nå, winna, ådraga sig:</text:span></text:span> pugnam; i-i animo <text:span text:style-name="Fraktur">(upptänka),</text:span> Gell.; occasionem, divitias; dolorem indipiscor, Pt.<text:line-break/><text:span text:style-name="T6">Rĕdĭpiscor</text:span>, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Återfå:</text:span></text:span> Pt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpium,</text:span> ii, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Selleri, bi-ört:</text:span></text:span> a-o crines ornatus amaro, Vg.; a-um nectendis coronis est in horto meo, Hor.; Grajæ a-m coronæ mereri <text:span text:style-name="Fraktur">(d. w. s. winna pris wid de Nemeiska spelen),</text:span> Juv.<text:line-break/><text:span text:style-name="T6">Ăpiāceus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">af</text:span> a., corona, Hyg.<text:line-break/><text:span text:style-name="T6">Ăpiăcus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">selleri-artad:</text:span> Pn.<text:line-break/><text:span text:style-name="T6">Ăpiastrum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">wildt</text:span> a.: Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Aplūda,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Kli:</text:span></text:span> Pn., Gell.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Aplustra,</text:span> ōrum, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">äfwen</text:span><text:line-break/><text:span text:style-name="T6">Aplustre</text:span>, is, pl.<text:line-break/><text:span text:style-name="T6">Aplustria</text:span>, ium, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">det swängda </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bakstycket</text:span></text:span><text:span text:style-name="Fraktur"> l. sirat i bakstammen af ett skepp (stundom i form af en fogelstjert):</text:span> navibus absumptis fluitantia quærere a-ra; fulgent Argoae stellis a-ia puppis, <text:soft-page-break/>C.; fluitantia a-stra <text:span text:style-name="Fraktur">(wid ett skeppsbrott),</text:span> Lucr.; a-stre torquere in aliquem, Luc.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏcătastăsis,</text:span> is, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Återställelse</text:span></text:span><text:span text:style-name="Fraktur"> till förut innehafd plats:</text:span> astrorum, Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpoclēti,</text:span> ōrum, <text:span text:style-name="T3">m.</text:span>: v. gr. <text:span text:style-name="Fraktur">medlemmar af det mindre rådet hos Aetolerna,</text:span> L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pŏcŏlŏcynthōsis, is, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">förwandling till en kurbits, titel på Senecas satir öfwer Claudius Cæsar.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pŏcŏpe, es, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">bortskärning = bokstafs eller stafwelses bortfallande i slutet af ett ord.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ăpŏdictĭcus</text:span>, <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur">apodiktisk</text:span> i. e. <text:span text:style-name="Fraktur">med nödwändighet bewisande:</text:span> argumentum, Gell.<text:line-break/><text:span text:style-name="T6">Ăpŏdixis</text:span>, is, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">nödwändigt bindande bewisning:</text:span> Gell.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏdy̆tērium,</text:span> i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afklädningsrum</text:span></text:span><text:span text:style-name="Fraktur"> i badhus:</text:span> C., Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏgēus,</text:span> <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur">från land kommande:</text:span> ventus, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ăpō̆grăphon</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">copia af målning:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pollo, ĭnis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">Apollo (solens, ljusets, sångens, läkare- och siarekonstens gud).</text:span> <text:line-break/>Ăpollĭnāris, <text:line-break/>Ăpollĭnĕus, <text:span text:style-name="T3">A.</text:span>: ludi A-res, C.; laurea A-ris, Hor.; ars A-ea, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>pollŏdōrus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span> <text:line-break/>Ăpollŏdōrēus, <text:span text:style-name="T3">A.</text:span> </text:p>
   <text:p text:style-name="P1">Ăpollōnia, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">namn på flere gr. städer.</text:span> <text:line-break/>Ăpollōniātes, ae, pl. -atæ, ārum <text:span text:style-name="Fraktur">och</text:span> -ates, ium, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">innewånare i A.</text:span> <text:line-break/>Ăpollōniensis, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Ăpollōnis, ĭdis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">gr. stadsnamn.</text:span> <text:line-break/>Ăpollōnĭdenses, ium, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">innewånare i A.</text:span> <text:line-break/>Ăpollōnius, ii, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏlŏgo,</text:span> 1.: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Förkasta:</text:span></text:span> Sen.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏlŏgus,</text:span> i, <text:span text:style-name="T3">m.</text:span>: v. gr.:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Anecdot:</text:span></text:span> a. facere <text:span text:style-name="Fraktur">(uppdikta);</text:span> agere <text:span text:style-name="Fraktur">(utföra, framställa),</text:span> Pt.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fabel</text:span></text:span><text:span text:style-name="Fraktur"> (isynn.: djur-fabel;</text:span> syn. fabula, <text:span text:style-name="Fraktur">jfr</text:span> Gell. II. 29): vel fabula vel a.; narrationes a-orum, C.; a-i et historiæ, Qu.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏphŏrēta,</text:span> ōrum, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Skänker,</text:span></text:span><text:span text:style-name="Fraktur"> som från ett gästabud medtogos hem,</text:span> Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpoplexis,</text:span> is, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Slaganfall:</text:span></text:span> Pn.<text:line-break/><text:span text:style-name="T6">Ăpoplectĭcus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">träffad af slag:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpoprŏegmĕna,</text:span> ōrum, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">förkastliga ting (som sakna relativt wärde: stoiskt-philosophisk term),</text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏsiōpēsis,</text:span> is, <text:span text:style-name="T3">f.</text:span>: v. gr. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Förtegande</text:span></text:span> (Cic. reticentia), <text:span text:style-name="Fraktur">rhetorisk figur, som består deri, att i en påbörjad mening hufwudordet l. hufwudmomentet utelemnas,</text:span> Qu.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Ăpostrŏphe,</text:span> ēs, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">rhetorisk figur (= när man wänder sig från den, talet egentligen gäller, och tilltalar en tredje (ofta en frånwarande) person),</text:span> Qu.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăpŏthēca,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Förwaringsställe, källare, wind</text:span></text:span><text:span text:style-name="Fraktur"> (serskildt förwaringsrum för win),</text:span> C., Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>poxyŏmĕnus, i, <text:span text:style-name="T3">m.</text:span>: v. gr.: <text:span text:style-name="Fraktur">ynglingen som skrapar sig, berömd bildstod af Lysippus.</text:span></text:p>
   <text:p text:style-name="P1">Appareo, <text:line-break/>Apparitor <text:span text:style-name="Fraktur">se</text:span> Pareo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Appello</text:span> <text:line-break/>(adpello), 1.: <text:span text:style-name="Fraktur">(af okändt stamverb, jfr</text:span> compello, interpello):<text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Tilltala, tala till, med ord wända sig till</text:span></text:span><text:span text:style-name="Fraktur"> -:</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i allm.: (utan serskild afsigt):</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">egentl.:</text:span> patrem, Ter.; milites blande a-ndo delenire; a-re aliquem comiter, hilari vultu, superbius, asperius, C.; milites a-re cohortarique, nominatim aliquos, Cs.; benigne aliquem; unumquemque nominans a-at; adveniens quæstorem a-at dicitque se a patre missum esse, Sa.<text:line-break/>b. <text:span text:style-name="Fraktur">skriftligen eller i phantasien:</text:span> litteris aliquem, absentem, C.; flebiliter nomine sponsum mortuum a-at <text:span text:style-name="Fraktur">(ropar wid namn),</text:span> L.<text:line-break/>2. <text:span text:style-name="Fraktur">i serskild afsigt:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Åkalla, anropa:</text:span></text:span> Deum a-re, aliquem in periculo a-re; vos imploro et a-o, sanctissimæ Deæ, C.; exsul patria, quo accedam quosve appellem?, Sa.; Mater, te a-o, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">(under frihets-tiden) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Påkalla</text:span></text:span><text:span text:style-name="Fraktur"> en myndighets skydd: (under kejsaretiden) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">wädja</text:span></text:span><text:span text:style-name="Fraktur"> (söka få en under-rätts dom upphäfd):</text:span> tribunum, C., L.; prætorem, C.; prætor, si quis a-sset de - solutionibus -, fore auxilio pollicebatur, Cs.; regem, L.; tribunos a prætore, C. - a. ad imperatorem <text:span text:style-name="Fraktur">(wädja till kejsaren),</text:span> Ict.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wända sig till, widtala</text:span></text:span><text:span text:style-name="Fraktur"> någon för att rådfråga sig med eller söka förmå honom till ngt:</text:span> aliquem de communi re, Pt.; a-at hominem, docet quid fieri possit; senatum pro dignitate alicujus, C.; aliquem de proditione, L.; a-tus est a Flavio Atticus, ut rei princeps esse vellet, N.<text:line-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lagligen tilltala, åtala; kräfwa</text:span></text:span> (de aliqua re = <text:span text:style-name="Fraktur">för ngt), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">påminna</text:span></text:span><text:span text:style-name="Fraktur"> gäldenär eller borgensman:</text:span> iisdem de causis alii plectuntur, alii ne a-ntur quidem; biennio non a-sti; de pecuniā; Tullia tuum munusculum flagitat, me sponsorem a-at, C.; exactor ad diem, Pn.; creditor in solidum a-bat, T. <text:line-break/>II. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nämna:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">absol.:</text:span> <text:line-break/>a. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nämna</text:span></text:span><text:span text:style-name="Fraktur"> en persons namn:</text:span> Cæsar nunquam nisi honorificentissime Pompejum a-at; nomine aliquem, C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nämna</text:span></text:span><text:span text:style-name="Fraktur"> (uttryckligen omröra eller säga) en sak:</text:span> ea in lege non a-ntur, C. <text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nämna, benämna, kalla, gifwa namn:</text:span></text:span> eum, quicum bella geras, tam molli nomine a-re; P. Scipio, is, qui primus Africanus a-tus est; te sapientem et appellant et existimant; appellari ex <text:span text:style-name="Fraktur">l.</text:span> ab re <text:span text:style-name="Fraktur">(få sitt namn af ngt),</text:span> C.; ipsorum lingua Celtæ, nostrā Galli a-antur; Ariovistus a senatu amicus appellatus erat, Cs.; aliquem regem, Sa.; <text:soft-page-break/>librum a-at Origines, N.; id ab re <text:span text:style-name="Fraktur">(af saken, af det, som det war) -</text:span> interregnum a-tum; Iovem Indigetem a-nt (Aenean mortuum), L. <text:line-break/>III. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Uttala:</text:span></text:span> suavitas a-arum literarum; nomen alicujus - identidem cum gemitu, C. <text:line-break/><text:span text:style-name="T6">Appellātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Tilltalande,</text:span></text:span> Cs.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Tillkallande, anropande</text:span></text:span><text:span text:style-name="Fraktur"> af en myndighet till skydd mot förtryck eller wåld; (under kejsarne) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">wädjande, wad</text:span></text:span><text:span text:style-name="Fraktur"> till kejsarne eller senaten:</text:span> tribunorum, C.; decemviri collegæ, L.; a. Cæsaris <text:span text:style-name="Fraktur">(till Cæsar);</text:span> ad senatum, Su.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nämnande, benämnande, benämning</text:span></text:span><text:span text:style-name="Fraktur"> (titel), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">namn:</text:span></text:span> a-nes regum venales erant, C.; nihil esse rempublicam, a-nem modo, sine corpore ac specie, Su.; id vocabulum (tribuni) Augustus reperit, - ut aliqua a-ne cetera imperia præmineret, T. - <text:span text:style-name="Fraktur">i Gramm. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nomen,</text:span></text:span><text:span text:style-name="Fraktur"> enkannerligen substantivum,</text:span> Qu.<text:line-break/>4. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Uttal:</text:span></text:span> lenis literarum a., C.<text:line-break/><text:span text:style-name="T6">Appellātīvus</text:span>, <text:span text:style-name="T3">A.</text:span>: nomen a-um, <text:span text:style-name="Fraktur">(som tillkommer en klaß af föremål): Gramm.</text:span><text:line-break/><text:span text:style-name="T6">Appellātor</text:span>, ōris, <text:span text:style-name="T3">m.</text:span>: <text:line-break/>a. <text:span text:style-name="Fraktur">som påkallar en myndighets skydd,</text:span> C.<text:line-break/>b. <text:span text:style-name="Fraktur">som wädjar till högre domsrätt,</text:span> Ict.<text:line-break/><text:span text:style-name="T6">Appellātōrius</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">som rörer wad,</text:span> Ict.<text:line-break/><text:span text:style-name="T6">Appellĭto</text:span>, Frequ. 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Benämna:</text:span></text:span> Coelius mons a Coele Vibenna a-tus est, T.</text:p>
   <text:p text:style-name="P1">Appendix <text:span text:style-name="Fraktur">se</text:span> Pendeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ppius, ii, <text:span text:style-name="T3">m.</text:span>: prænomen <text:span text:style-name="Fraktur">i</text:span> Gens Claudia. <text:line-break/>Appius, <text:line-break/>Appiānus, <text:span text:style-name="T3">A.</text:span>: via A-ia <text:span text:style-name="Fraktur">(Appisk = anlagd af en A.);</text:span> cædes A-ana <text:span text:style-name="Fraktur">(mord på A.).</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>ppŭlējus <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Āpŭlējus, <text:span text:style-name="Fraktur">Rom. gentilnamn.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ā</text:span>ppŭlus <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/><text:span text:style-name="T1">Ă</text:span>pŭlus, <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur">Apulier och Apulisk.</text:span><text:line-break/><text:span text:style-name="T1">Ă</text:span>pūlia, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">Apulien, del af Italien.</text:span> <text:line-break/>Ăpūlĭcus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ăprīcus,</text:span> <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">(enl.</text:span> Paul. Diac. <text:span text:style-name="Fraktur">af</text:span> aperio):<text:line-break/>a. <text:span text:style-name="Fraktur">om ställen: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppen, solig</text:span></text:span><text:span text:style-name="Fraktur"> (mots.</text:span> opācus): loca opaca aut a., C.; colles a-i, Vg.; campus, pratum, Hor. - <text:span text:style-name="Fraktur">Subst.</text:span> <text:line-break/>Ăprīcum, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öppen, solig plats:</text:span></text:span> amat buxus a-ca, Pn.; quidquid sub terra est, in a-cum <text:span text:style-name="Fraktur">(i dagen)</text:span> proferet ætas, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">om wäderlek: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Torr, solig:</text:span></text:span> dies a., Varr.; dies apricissimus, Col. <text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Solsken älskande,</text:span></text:span><text:span text:style-name="Fraktur"> som gerna solar sig:</text:span> flores, Hor.; mergi, Vg.; senes, Ps.<text:line-break/><text:span text:style-name="T6">Ăprīcĭtas</text:span>, ātis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Solighet:</text:span></text:span> regionis, Pn.; diei, Col. <text:line-break/>Ăprīcor, Dep. 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sola sig:</text:span></text:span> Alexander Diogeni a-nti offecerat, C.<text:line-break/><text:span text:style-name="T6">Ăprīcātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: calescere vel a-ne <text:span text:style-name="Fraktur">(genom att sola sig)</text:span> vel igni, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ă</text:span>prīlis <text:span text:style-name="Fraktur">(enl.</text:span> Varro <text:span text:style-name="Fraktur">af</text:span> aperire, quod ver omnia aperit), <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och subst. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">April-</text:span></text:span><text:span text:style-name="Fraktur"> (som är i, tillhör April), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">April:</text:span></text:span> mensis, Nonæ A-es, C., A., mensis Veneris, Hor.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/>Aprinus <text:span text:style-name="Fraktur">se</text:span> Aper.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">A</text:span>prōnius, <text:span text:style-name="Fraktur">Rom. gentilnamn.</text:span> <text:line-break/>Aprōnianus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1">Aprugnus <text:span text:style-name="Fraktur">och</text:span> <text:line-break/>Aprunus <text:span text:style-name="Fraktur">se</text:span> Aper.</text:p>
   <text:p text:style-name="P1">Apto <text:span text:style-name="Fraktur">se</text:span> Aptus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Aptōta</text:span>, ōrum, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">oböjliga nomina, som ej hafwa</text:span> πτώσεις <text:span text:style-name="Fraktur">(casus), som blott förekomma i nominativens (acc., vocat.) form med betydelse af nom. (acc., voc.): Gramm.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Aptus,</text:span> <text:span text:style-name="T3">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur">(eg. part. pf. af</text:span> apio (apiendo Isid.), apere, <text:span text:style-name="Fraktur">enl.</text:span> Paul. Diac. = vinculo comprehendere, <text:span text:style-name="Fraktur">fästa, sammanbinda):</text:span><text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fästad</text:span></text:span><text:span text:style-name="Fraktur"> wid ngt</text:span> (ex re, <text:span text:style-name="Fraktur">sällan</text:span> re): <text:line-break/>a. <text:span text:style-name="Fraktur">i eg. men.:</text:span> gladium e lacunari setā aptum demittere, C.; juvencos ex torquibus aptos junge, Vg.<text:line-break/>b. <text:span text:style-name="Fraktur">bildl. eller oeg. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Beroende</text:span></text:span><text:span text:style-name="Fraktur"> af:</text:span> causæ aliæ ex aliis aptæ; ex honesto officium a-um est; fortuna rudentibus a-a, C.<text:line-break/>2. <text:span text:style-name="Fraktur">sinsemellan eller inom sig </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sammanfogad, sammanhängande:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> corpus validis aptum nervis, Lucr.; ut in oratione constanti, sic in vita omnia sint inter se a-a et convenientia, C.<text:line-break/>b. <text:span text:style-name="Fraktur">serskildt om framställningens periodiska form: (sluten), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Rundad,</text:span></text:span><text:span text:style-name="Fraktur"> rhythmisk (syn.</text:span> composita, conclusa, <text:span text:style-name="Fraktur">ej</text:span> coagmentata, constructa): adde numeros et a-ior sit oratio; a-a et numerosa oratio, C. <text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Passande, lämpad, öfwerensstämmande, lämplig, egnad</text:span></text:span><text:span text:style-name="Fraktur"> (bidragande till), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">skicklig, tjenlig:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">relativt: passande o. s. w. för ngt l. ngn (constr. med</text:span> ad, in <text:span text:style-name="Fraktur">och accus., med Dat. eller med en sats med</text:span> qui <text:span text:style-name="Fraktur">och conj.):</text:span> calcei a-i ad pedem; ornatus ad actionem a-us; ad rem militarem, ad dicendum a-us; voce forma, motu corporis ad hoc munus a-is; ad claritatem amplitudinemque aptior est eorum vita, qui se ad rempublicam accommodaverunt; hæc scenicis a-a sunt, nobis dissoluta; id naturæ hominum a-simum est; nulla videbatur a-ior persona, quæ de senectute loqueretur, C.; castra ad bellum docendum a-sima; nostra classis celeritate, - præstabat: reliqua - hostibus - erant a-iora, Cs.; pugnæ genus, in quod minime apti erant, L.; sŏlum pecori et vitibus a-um, Vg.; aptum equis Argos; a-us alternis sermonibus iambus, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">absolute: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Passande:</text:span></text:span> quod a-um est, hoc est, quod decet, C. - <text:span text:style-name="Fraktur">serskildt om talet, så wäl i enskilda uttryck </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Præcis, riktig, träffande,</text:span></text:span><text:span text:style-name="Fraktur"> som i det hela af framställningen: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">passande</text:span></text:span><text:span text:style-name="Fraktur"> (öfwerensstämmande med ämnets art och omständigheterna):</text:span> Thucydides ita verbis aptus et pressus est, ut nescias, utrum res oratione, an verba sententiis illustrentur; qui (in dicendo) ita moderantur, ut personarum dignitates ferunt, ii sunt in eo genere laudandi, quod ego a. et congruens dico, C.<text:line-break/>4. <text:span text:style-name="Fraktur">(det hwartill l. -på ngt är fogadt) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besatt</text:span></text:span><text:span text:style-name="Fraktur"> med -:</text:span> o fides alma, apta pinnis <text:span text:style-name="Fraktur">(bewingad),</text:span> Enn. ap. C.; Atlas humeris torquet caelum stellis ardentibus aptum, Vg.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Aptē</text:span>, <text:span text:style-name="T3">Adv.</text:span>: p. tr. gr.:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wäl afpassadt, sammanfogadt, fast, riktigt:</text:span></text:span> cohærere, C., L.; pileum capiti a-e reponere, L.<text:line-break/><text:soft-page-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">På ett passande sätt, på ett sätt, som öfwerensstämmer med -, är egnadt att -, bidrager till att</text:span></text:span><text:span text:style-name="Fraktur"> - -:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> ad dignitatem a., ad persuadendum a. dicere, C.; equitem a. locare (in proelio), L.; chorus ne quid intercinat actus, quod non proposito conducat et hæreat apte, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">serskildt om föredraget: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">På ett passande,</text:span></text:span><text:span text:style-name="Fraktur"> med ämnets art och omständigheterna </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">enligt sätt:</text:span></text:span> a., distincte, ornate dicere oratoris est, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Apto</text:span>, 1.:<text:line-break/>1. <text:span text:style-name="Fraktur">(i eg. och oeg. men.): </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Passa, foga till, afpassa, lämpa</text:span></text:span><text:span text:style-name="Fraktur"> efter:</text:span> arma corpori, L.; sagittas nervo, Vg.; anulum digito, Su.; verbum ad rem a-tum, C.; valli usum ad commoditatem ferendi a-re, L.; in structurā a-re <text:span text:style-name="Fraktur">(inpassa)</text:span> aliquid, Pn.; ensem vaginā, Vg.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Göra i ordning</text:span></text:span><text:span text:style-name="Fraktur"> (till ngt l. absolute), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">laga, reda till; förse, utrusta med:</text:span></text:span> arma pugnæ, L.; se pugnæ, animos armis <text:span text:style-name="Fraktur">(bereda sig på krig);</text:span> classem a-nt socii, Vg.; in pace a-re idonea bello, Hor.; ad transeundum a. omnia, Ct.; classem velis, Vg.; se armis, L. <text:line-break/><text:span text:style-name="T6">Adapto</text:span>, 1.: <text:span text:style-name="Fraktur">part. pf.</text:span> a-tus: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afpassad efter:</text:span></text:span> galericulum capiti, Su.<text:line-break/><text:span text:style-name="T6">Exaptus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fästad wid</text:span></text:span><text:span text:style-name="Fraktur"> ngt,</text:span> Pn.<text:line-break/><text:span text:style-name="T6">Exapto</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fästa wid</text:span></text:span><text:span text:style-name="Fraktur"> -:</text:span> tintinnabula Deo, Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T6">Ĭneptus</text:span>, <text:span text:style-name="T3">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Opassande</text:span></text:span><text:span text:style-name="Fraktur"> (om personer, deras beteende och tal), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">takt-, smaklös, (pedantisk), narraktig:</text:span></text:span> qui in aliquo genere inconcinnus aut multus est, is - ineptus dicitur; Lysias nihil habet insolens aut i-i, C.; lenitas (patris) i-ta et absurda, Ter.; i-us homo et paulo jactantior; quidquid chartis amicitur ineptis <text:span text:style-name="Fraktur">(dumma</text:span> i. e. <text:span text:style-name="Fraktur">med dumt innehåll: enl. andra = odugliga),</text:span> Hor.; eos, qui plus literis tribuerunt, i-os <text:span text:style-name="Fraktur">(pedanter)</text:span> et jejunos appellant, Qu.<text:line-break/><text:span text:style-name="T6">Ĭnepte</text:span>, <text:span text:style-name="T3">Adv.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur">på </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Opassande, narraktigt, pedantiskt, tillgjordt sätt:</text:span></text:span> nec i. neque odiose neque putide dicere; i. facere aliquid, C.; quanto rectius hic (Homerus), qui nil molitur i., Hor.; Claudius historiam scripsit magis i., quam ineleganter, Su.<text:line-break/><text:span text:style-name="T6">Ĭneptia</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Narraktighet,</text:span></text:span> Pt., Ter.; <text:span text:style-name="Fraktur">wanl. i plur.</text:span><text:line-break/><text:span text:style-name="T6">Ĭneptiæ</text:span>, ārum, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">i saklig men.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Narraktigheter, dumheter, tokigheter:</text:span></text:span> pellantur <text:span text:style-name="Fraktur">(bort med)</text:span> aniles istæ i-æ; petam a vobis, ne has meas i-as efferatis, C.<text:line-break/><text:span text:style-name="T6">Ĭneptio</text:span>, 4.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wara narraktig, fjollig:</text:span></text:span> ineptis, Ter.; Miser Catulle, desinas i-re, Catl.<text:line-break/><text:span text:style-name="T6">Ĭneptĭtūdo</text:span>, ĭnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Oskicklighet,</text:span></text:span> Caecil.<text:line-break/><text:span text:style-name="T6">Interaptus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ömsesidigt infogad</text:span></text:span> (i tmesis), Lucr.</text:p>
   <text:p text:style-name="P1">Apua <text:span text:style-name="Fraktur">se</text:span> Aphye.</text:p>
   <text:p text:style-name="P1"><draw:custom-shape text:anchor-type="paragraph" draw:z-index="4" draw:name="AutoShape 7" draw:style-name="gr5" draw:text-style-name="P4" svg:width="1.572cm" svg:height="0.253cm" svg:x="11.017cm" svg:y="-40.838cm">
