   <text:p text:style-name="P1"><text:span text:style-name="T5">Hephthēmĭmĕris,</text:span> dis, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">cæsur på sjunde half-foten i en vers:</text:span> Diom.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Heptăphōnus</text:span>, <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur">s. ger sjufaldt echo:</text:span> porticus, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Heptăpy̆los</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">sjuportad:</text:span> Thebæ, Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Heptēris</text:span>, is, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Skepp med sju roddare-rader:</text:span></text:span> L.</text:p>
   <text:p text:style-name="P1">Hĕra <text:span text:style-name="Fraktur">se</text:span> Herus.</text:p>
