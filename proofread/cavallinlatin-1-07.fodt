   <text:p text:style-name="P1"><text:span text:style-name="T5">Hēmĕrēsĭus,</text:span> <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur">s. är för en dag:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmĕrŏdrŏmus</text:span>, i <text:span text:style-name="T3">m.</text:span>: v. gr.: <text:span text:style-name="Fraktur">(dagslöpare), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T5">Snabblöpare, ilbud, courir:</text:span></text:span> Athenienses miserunt Lacedæmonem cursorem ejus generis, qui h-oe (<text:span text:style-name="T3">nom. pl.</text:span> gr.) vocantur, N.; L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T5">Hēmĭcillus,</text:span> i, <text:span text:style-name="T3">m.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Half åsna</text:span></text:span><text:span text:style-name="Fraktur"> (skymford):</text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmĭcrānĭum</text:span>; i, <text:span text:style-name="T3">n.</text:span> <text:line-break/>(Hēmĭcrānia, ae, <text:span text:style-name="T3">f.</text:span>): v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Hufwudwärk:</text:span></text:span><text:span text:style-name="Fraktur"> (migraine):</text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmĭcyclĭum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Halfkrets, -rund:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">Sittplats (murad) i form af </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T5">halfkrets</text:span></text:span><text:span text:style-name="Fraktur"> (halfrotunda):</text:span> Vitr.; C. (de Am. 1). <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Solur</text:span></text:span><text:span text:style-name="Fraktur"> (af sådan form):</text:span> Vitr. <text:line-break/><text:span text:style-name="T1">Hēmĭcyclus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">halfcirkel:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmīna</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">ett slags mått (stop):</text:span> Cato.<text:line-break/><text:span text:style-name="T1">Hēmīnāria</text:span>, ōrum, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">skänker af en h.:</text:span> Qu.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmĭŏlĭos</text:span>, <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">En och en half:</text:span></text:span> Gell.<text:line-break/><text:span text:style-name="T1">Hēmĭŏlĭa</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">ett slags fartyg:</text:span> Gell.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmisphærĭum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Halfsphær; kupol:</text:span></text:span> Varr., Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmistĭchĭum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">hälften af en vers:</text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēmĭtŏnĭum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">half ton:</text:span> Vitr.</text:p>
