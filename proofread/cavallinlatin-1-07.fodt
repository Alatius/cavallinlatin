   <text:p text:style-name="P1"><text:span text:style-name="T1">Hēlĭŏtrŏpĭum</text:span>, i, <text:span text:style-name="T3">n.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur">en blomma, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T5">Heliotrop:</text:span></text:span> Pn.<text:line-break/>b. <text:span text:style-name="Fraktur">en ädelsten:</text:span> Pn.</text:p>
