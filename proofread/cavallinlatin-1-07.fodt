   <text:p text:style-name="P1"><text:span text:style-name="T5">H</text:span>ēnĭŏchi, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">sarmatiskt folk i Asien:</text:span> Pn. <text:line-break/>Hēnĭŏchus, <text:span text:style-name="T3">A.</text:span>: Ov. – </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T5">H</text:span>enna <text:line-break/>(Enna), ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad på Sicilien:</text:span> C. <text:line-break/>Hennæus, <text:span text:style-name="T3">A.</text:span>: Ov. <text:line-break/>Hennensis, <text:span text:style-name="T3">A.</text:span>: C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T5">Hēpar,</text:span> ătis, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Lefwer:</text:span></text:span> Veg. <text:line-break/><text:span text:style-name="T1">Hēpătārius</text:span>, <text:span text:style-name="T3">A.</text:span>: morbus, Pt.<text:line-break/><text:span text:style-name="T1">Hēpătĭcus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">lefwersjuk:</text:span> Pn.<text:line-break/><text:span text:style-name="T1">Hēpătium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: Petr.<text:line-break/><text:span text:style-name="T1">Hēpătizon</text:span>, ontis, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">lefwerfärgad:</text:span> Pn.</text:p>
