   <text:p text:style-name="P1"><text:span text:style-name="T5">H</text:span>elvii, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">galliskt folk.</text:span></text:p>
   <text:p text:style-name="P1">Helvinus <text:span text:style-name="Fraktur">se</text:span> Helvus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T5">H</text:span>elvius, <text:span text:style-name="Fraktur">rom. slägtnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T5">Hēluo</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:line-break/><text:span text:style-name="T5">Helluo,</text:span> ōnis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Fråssare; slösare, s. förtär i fråsseri; förstörare:</text:span></text:span> h., ganeo, Ter.; gurges et h. natus abdomini suo; h. patriæ; h. patrimonii; impurus h., C.<text:line-break/><text:span text:style-name="T1">Helluor</text:span>, 1.: <text:span text:style-name="T3">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Fråssa på ngt, slösa med ngt</text:span></text:span> (<text:span text:style-name="T3">re</text:span>); <text:span text:style-name="Fraktur"><text:span text:style-name="T5">förstöra, -spilla</text:span></text:span> (<text:span text:style-name="T3">rem</text:span>): meo periculo; libris; sanguinem reipublicæ, C.<text:line-break/><text:span text:style-name="T1">Helluātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Fråssande, -eri:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1">Helvolus <text:span text:style-name="Fraktur">se</text:span> Helvus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T5">Helvus,</text:span> <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T5">Honingsgul:</text:span></text:span> color vaccarum, Varr.<text:line-break/><text:span text:style-name="T1">Helvŏlus</text:span> <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Helveŏlus</text:span>, <text:line-break/><text:span text:style-name="T1">Helvenācus</text:span>,<text:line-break/><text:span text:style-name="T1">Helvenācius</text:span>,<text:line-break/><text:span text:style-name="T1">Helvīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: id.: Varr., Col.</text:p>
