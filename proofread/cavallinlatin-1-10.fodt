 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
   </text:sequence-decls>
   <text:p text:style-name="P3"><text:line-break/><text:span text:style-name="T1">Ēmāno</text:span>, 1.:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Utströmma:</text:span></text:span> fons unde e-at aquai, C. poēt.; vis animæ diffusa uti fumus e-at <text:span text:style-name="Fraktur">(i döden),</text:span> Lucr.; sanies, Col. <text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Härflyta, -stamma, utgå</text:span></text:span><text:span text:style-name="Fraktur"> från:</text:span> istinc mala nostra e-runt; alii alio ex fonte præceptores dicendi; hinc (ab Arcesila) recentior Academia e-vit, C.<text:line-break/>b. <text:span text:style-name="Fraktur">framgå ur = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Blifwa utrönt, kändt:</text:span></text:span> multis e-bat indiciis, M. Volscii fratrem - ex morbo non assurrexisse, L.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sprida sig, utspridas, blifwa bekant:</text:span></text:span> fama, sermo per alqm, ab aliquo; oratio in vulgus, C.; quo accuratius celentur, eo facilius e-ant, L.; e-vit in vulgus, (percussores) missos esse, Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Permāno</text:span>, 1.: <text:span text:style-name="Fraktur">(genomströmma) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sprida sig</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">tränga igenom, fram till:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i eg. men.:</text:span> sucus ex alvo ad jecur per vias -; venenum epotum in venas, C.; p-at calor argentum, Lucr.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span> a principiis ad finem; macula ad animum ex sanguine paterno; oratio ad aures, ad mentes, ad sensus; Pythagoræ doctrina in hanc civitatem, C.; res ad patrem <text:span text:style-name="Fraktur">(ryktet derom),</text:span> Ter. <text:line-break/><text:span text:style-name="T1">Permānanter</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Genomträngande:</text:span></text:span> Lucr. <text:line-break/><text:span text:style-name="T1">Permānasco</text:span>, ĕre: ad alqm <text:span text:style-name="Fraktur">(till ngns kunskap),</text:span> Pt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Rĕmāno</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Strömma tillbaka:</text:span></text:span> retro ad caput humor, Lucr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Submāno</text:span> <text:line-break/>(summano), 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Flyta under</text:span></text:span><text:span text:style-name="Fraktur">:</text:span> Vitr.</text:p>
   <text:p text:style-name="P1">Mansio, Mansito <text:span text:style-name="Fraktur">se</text:span> Maneo.<text:line-break/>Mansue . . . <text:span text:style-name="Fraktur">se</text:span> Mănus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mantēle</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T1">Mantīle</text:span>, is, <text:span text:style-name="T3">n.</text:span>: <text:line-break/>(Mantēlium, <text:line-break/>Mantīlium, i, Varr.; <text:span text:style-name="Fraktur">af</text:span> manus <text:span text:style-name="Fraktur">och</text:span> tela?): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handduk, servet, bordduk:</text:span></text:span> m. est, ubi manus tergentur, Varr.; tonsis m-a villis ferunt (convivis famuli), Vg.; m-bus aureis sternere <text:span text:style-name="Fraktur">(duka),</text:span> Treb.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mantellum,</text:span> i, <text:span text:style-name="T3">n.</text:span>:<text:line-break/>a. = mantele: Lucil.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hölje:</text:span></text:span> Pt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mantĭca,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Rensel, twärsäck, -påse, kappsäck:</text:span></text:span> m. lumbos ulcerat equi, Hor.; m. = perula viatoria, Porphyr.; <text:span text:style-name="Fraktur">ordspråk (om blindhet för egna fel):</text:span> non videmus, quod in tergo m-æ est, Catl.<text:line-break/><text:span text:style-name="T1">Mantĭcŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: Paul. Diac.<text:line-break/><text:span text:style-name="T1">Mantĭcŭlor</text:span>, 1.: <text:span text:style-name="T3">Dep.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Stjäla</text:span></text:span><text:span text:style-name="Fraktur"> (ur ngns rensel,</text:span> furandi gratia manticas attrectare, Paul. Diac.): Ap.<text:line-break/>b. = dolose agere alqd: id.; - <text:span text:style-name="Fraktur">falskt antaga,</text:span> Lucr. II. 547.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mantĭcĭnor</text:span> <text:span text:style-name="Fraktur">(l.</text:span> <text:line-break/><text:bookmark text:name="_GoBack"/>Mantiscĭnor), 1.: <text:span text:style-name="T3">Dep.</text:span>: (vox hybrida <text:span text:style-name="Fraktur">af</text:span> μάντις <text:span text:style-name="Fraktur">och</text:span> cano = vaticinor?): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Spå:</text:span></text:span> Pt.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/>Manticula, -culor <text:span text:style-name="Fraktur">se</text:span> Mantica.<text:line-break/>Mantile, -tilium <text:span text:style-name="Fraktur">se</text:span> Mantele.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>antĭnēa, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Arcadien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mantīsa</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T1">Mantissa</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: additamentum - quod ponderi adjicitur, lingua Tusca, Paul. Diac.</text:p>
   <text:p text:style-name="P1">Manto (-are) <text:span text:style-name="Fraktur">se</text:span> Maneo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>anto, ūs, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">gr. myth. personn.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>antua, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Gallia Transpadana (Virgilii födelseort).</text:span> Mantuānus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1">Manualis, -arius <text:span text:style-name="Fraktur">se</text:span> Mănus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mănŭbia,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">(enl.</text:span> Gramm. <text:span text:style-name="Fraktur">af</text:span> manus):<text:line-break/>1. <text:span text:style-name="Fraktur">i etruskiska auguralspråket</text:span> = genus fulminis: Jovi tres m-as dant <text:span text:style-name="Fraktur">(olika i anseende till den frihet, hwarmed de sändas af Jupiter, och i anseende till sina werkningar),</text:span> Sen., Fs.; numen fatales contorquet m-as, Amm.<text:line-break/>2. <text:span text:style-name="Fraktur">i</text:span> <text:span text:style-name="T3">plur.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Krigsbyte,</text:span></text:span><text:span text:style-name="Fraktur"> spec.: öfwerbefälhafwarens andel af bytet, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">fältherrebyte</text:span></text:span><text:span text:style-name="Fraktur"> l. de genom deß försäljning inkasserade penningesummorna (enl.</text:span> Gell. <text:span text:style-name="Fraktur">egentl. endast</text:span> = pecunia prædaticia):<text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> quod ad quemque pervenit ex præda, ex m-is, - id ad decemviros referri (lex agraria Rulli) jubet; Catulus porticum de m-is Cimbricis fecit; Rostra imperatoriis m-is ornare, C.; his ex m-is arx Athenarum ornata est, N.; ædem ex m-is faciendam locare, L.<text:line-break/>b. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Rof, utpreßning</text:span></text:span><text:span text:style-name="Fraktur"> (isynn. af embetsmän i provinserna l. af kejsarne):</text:span> sibi m-as ex m-is alterius facere, C.; Vespasianus ad rapinas et m-as compulsus est fisci ærariique inopia, Su.<text:line-break/><text:span text:style-name="T1">Mănŭbiālis</text:span>, <text:span text:style-name="T3">A.</text:span>: pecunia <text:span text:style-name="Fraktur">(af bytet),</text:span> Su.<text:line-break/><text:span text:style-name="T1">Mănŭbiārius</text:span>. <text:span text:style-name="T3">A.</text:span>: amicus <text:span text:style-name="Fraktur">(winstbringande),</text:span> Pt.</text:p>
   <text:p text:style-name="P1">Manubr . . . <text:span text:style-name="Fraktur">se</text:span> Mănus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mănŭciŏlum,</text:span> i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">litet bylte, bundt:</text:span> Petr.</text:p>
   <text:p text:style-name="P1">Manufestus <text:span text:style-name="Fraktur">se</text:span> Manifestus.<text:line-break/>Manul . . . <text:span text:style-name="Fraktur">se</text:span> Mănus.<text:line-break/>Manumiss . . ., -mitto <text:span text:style-name="Fraktur">se</text:span> Mitto. <text:line-break/>Manupretium <text:span text:style-name="Fraktur">se</text:span> Mănus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mănus,</text:span> us, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hand:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg. och i allm.:</text:span> m-us multarum rerum ministræ; porrigere m-um; m-u accipere, tenere, in m-us sumere, e <text:span text:style-name="Fraktur">l.</text:span> de m-bus dimittere, emittere, ponere, deponere, extorquere alqd; de m-u in m-um <text:span text:style-name="Fraktur">l.</text:span> per m-us tradere; tollere m-us <text:span text:style-name="Fraktur">(af förwåning),</text:span> C.; m-us post terga revinctus; tela m-u jactare; cape tela m-u; conjice tela m-u, Vg.; m-us tendere ad cælum, ad alqm, Cs.; m-u significare alqd; m-u levare, Sa.; m-um intendere, T.; m. explicata, compressa, Qu.; inter m-us auferre, C., L.; <text:span text:style-name="Fraktur">med personliga epithet:</text:span> m-u gratā sumere; m-us avidæ; m-u impia frangere guttur parentis; m. sacrilega, Hor.<text:line-break/>2. <text:span text:style-name="Fraktur">i serskilda, mer och mindre oegentl. uttryck:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i uttryck för rigtning, närhet, beredskap, tjenst; på högra, wenstra </text:span><text:soft-page-break/><text:span text:style-name="Fraktur">handen: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förhanden, wid sidan, till hands, till tjenst:</text:span></text:span> ad hanc m-um, Ter.; præ m-u esse, dare, Pt., Ter.; sub m-u (id), C.; servum habere ad m-um <text:span text:style-name="Fraktur">(s. angaf tonen åt talaren),</text:span> C.; ad m-um habere scribæ loco, N.; Romanis ad m-um domi supplementum erat, L. attendere te volo ea, quæ in m-bus sunt <text:span text:style-name="Fraktur">(det för handen warande),</text:span> C.<text:line-break/>b. <text:span text:style-name="Fraktur">i uttryck för arbete sysselsättning med ngt:</text:span> <text:line-break/>α. <text:span text:style-name="Fraktur">i allm.:</text:span> sub m-us lepide succedit negotium, Pt.; m-bus pedibusque conari, Ter.; victum m-u <text:span text:style-name="Fraktur">(med händers arbete)</text:span> quærere, C.; opus poscit multas m-us, Pn. ep.; cuncta festinat m., Hor.; m. extrema non accessit operibus ejus, C.; extremam m-um bello imponere, Vg.; prima, summa m. <text:span text:style-name="Fraktur">(första, sista handen</text:span> ɔ: <text:span text:style-name="Fraktur">delen af arbetet),</text:span> Qu., Ov., Pn.<text:line-break/>β. <text:span text:style-name="Fraktur">om menniskoarbete, -werk, i mots. till naturens werk (menniskohand, handkraft):</text:span> portus m-u facti, C.; arbor m-u sata; oppidum m-u munitum, Cs. - <text:span text:style-name="Fraktur">oeg.:</text:span> morbus m-u factus <text:span text:style-name="Fraktur">(sjelf-förwållad),</text:span> Sen.; m-um de tabula tollere <text:span text:style-name="Fraktur">(om en fullbordad målning),</text:span> Pn. - <text:span text:style-name="Fraktur">deraf ordspråk:</text:span> m-um de tabula = <text:span text:style-name="Fraktur">nog härom, jfr</text:span> tabula.<text:line-break/>γ. <text:span text:style-name="Fraktur">om literära sysselsättningar, läsning, skrifning, författande:</text:span> est in m-bus oratio <text:span text:style-name="Fraktur">(i allmänhetens händer);</text:span> habeo opus magnum in m-bus <text:span text:style-name="Fraktur">(under arbete);</text:span> libros in m-bus habent librarii (ɔ: <text:span text:style-name="Fraktur">afskrifwa dem);</text:span> septimus mihi liber Originum est in m-bus, C.; Ennius in m-bus non est et mentibus hæret?; vos exemplaria Græca nocturnā versate m-u; m. insudat libellis, Hor.<text:line-break/>c. <text:span text:style-name="Fraktur">i uttr. för besittning, besittningstagande, makt:</text:span> abstinere m-um alieno, Cato; m-us abstinentes habere prætorem decet; m-us abstinere a pecunia alicujus; alienis bonis m-us afferre <text:span text:style-name="Fraktur">(tillgripa);</text:span> dare m-us <text:span text:style-name="Fraktur">(eg. till att bindas = gifwa tappt),</text:span> C., Hor. - <text:span text:style-name="Fraktur">serdeles i uttr. med præp. = i, ur ngns wåld, hand:</text:span> rem de m-bus amittere, C.; hostem m-bus <text:span text:style-name="Fraktur">l.</text:span> de, e m-bus <text:span text:style-name="Fraktur">(släppa lös, låta undkomma),</text:span> L.; m-u emittere, mittere alqm <text:span text:style-name="Fraktur">(= frigifwa i borgerlig men.),</text:span> Pt., C.; incidere in m-us alicujus; mulier viro in m-um convenit <text:span text:style-name="Fraktur">(i hans wåld),</text:span> C.; libertina, mortuo patrono, in nullius m-u erat, L.; hæc non sunt in nostra m-u, C.; tibi id est in m-u, Ter.; ut fortuna in sua m-u esset, eo, quo contenderat, pervenit, N.; tantam fortunam ex m-bus dimittere <text:span text:style-name="Fraktur">(låta gå sig ur händerna),</text:span> Cs.; victoria est in m-u nostra, Sa.<text:line-break/>d. <text:span text:style-name="Fraktur">i uttr. för wåld, strid, handgemäng:</text:span> m-us afferre <text:span text:style-name="Fraktur">(bära hand)</text:span> socio; vim et m-us senatui inferre; templo m-us sacrilegas afferre; m-us injicere alicui, C.; non m-u neque vi; per m-us retinere libertatem, Sa.; res ad m-us pervenit <text:span text:style-name="Fraktur">(till handgemäng);</text:span> rem ad m-us revocare; m-u confligere cum hoste, C.; m-um conserere, Pt., C., Cs., Sa., m-us, C., N.; m-u eum superari posse diffidebant, N.; m-u capere urbem; in m-bus facere proelium <text:span text:style-name="Fraktur">(bringa det till handgemäng);</text:span> m-u promptus <text:span text:style-name="Fraktur">(tapper);</text:span> m-u prior. Sa.; et m-u fortis et consilii plenus, N.; m-u fortissimus, L.; miscere (= conserere) m-us, T.<text:line-break/>3. <text:span text:style-name="Fraktur">meton. om arbete, werk af menniskohand:</text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">någons </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handskrift, stil:</text:span></text:span> occupationum mearum sit tibi signum librarii m-us; amare <text:span text:style-name="Fraktur">(tycka om)</text:span> m-um alicujus, C.; id m. ejus docet <text:span text:style-name="Fraktur">(bewisar),</text:span> Qu.<text:line-break/>b. <text:span text:style-name="Fraktur">concret och abstr.: konstnärers </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Arbete, werk</text:span></text:span><text:span text:style-name="Fraktur"> (stil, drag):</text:span> artificum inter se m-us miratur, Vg.; ebore, ære exactæ m-us, Ppt.; plus in m-bus <text:span text:style-name="Fraktur">(arbetet)</text:span> est, quam in marmore, Qu. <text:line-break/>c. <text:span text:style-name="Fraktur">i fäktning: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hugg, stöt:</text:span></text:span> gladiatorum m. prima, secunda, tertia, Qu.<text:line-break/><text:soft-page-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Kast, winst</text:span></text:span><text:span text:style-name="Fraktur"> i tärningsspel:</text:span> remittere, exigere m-um, Su.<text:line-break/>4. <text:span text:style-name="Fraktur">om mskor, s. anwändas till ngt:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">någons </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Werktyg, handtlangare:</text:span></text:span> comites illi tui delecti m-us erant tuæ: præfecti, scribæ, præcones - - m-us erant tuæ, C.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Manskap, wäpnad skara, trupp, här:</text:span></text:span> m-um facere, multitudinem hominum cogere (ad vim inferendam); m. conjuratorum, veteranorum, militum; m-um firmam comparare, C.; m-um conducere, cogere, dissipare, Cs.; parva m-u Romanus maximas hostium copias fudit; cum magna manu; diducere m-um hostium, Sa.; Romulum alia comparata m-u adjuvat Remus; delectam m-um præsidii causa circa se habuit, L.; juvenum, Auruncæ m-us, Vg.; m-um comparare, colligere; Mardonius haud ita magna m-u Græciæ fugatus est, N.; multa poētarum; Etrusca Porsenæ m., Hor. <text:line-break/>5. <text:span text:style-name="Fraktur">om djurs lemmar, som motswara l. brukas ss. händer:</text:span> m. elephanto data est <text:span text:style-name="Fraktur">(om snabeln),</text:span> C.; m. simiæ, ursi <text:span text:style-name="Fraktur">(framtassen),</text:span> Pn.<text:line-break/>b. ferrea m-us, <text:span text:style-name="Fraktur">ett slags </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Änterhake:</text:span></text:span> Cs., L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mănĭca</text:span>, ae, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Ärm:</text:span></text:span> tunicæ m-as habent, Vg.; partem vestitus superiorem in m-as extendere, T.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handske; fäktarehandske, stålhandske:</text:span></text:span> munire manus m-is hieme, Pn.; - balteus et m., Juv., C.<text:line-break/>c. <text:span text:style-name="T3">plur.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handklofwar, -fjettrar:</text:span></text:span> levare m-as alicui, Vg.; tenere alqm in m-is et compedibus, Hor.<text:line-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Änterhake:</text:span></text:span> Luc. <text:line-break/><text:span text:style-name="T1">Mănĭcātus</text:span>, <text:span text:style-name="T3">A.</text:span>: tunica <text:span text:style-name="Fraktur">(med ärmar):</text:span> C. <text:line-break/><text:span text:style-name="T1">Mănĭcŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handboja:</text:span></text:span> Pt.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handtag på plogen</text:span></text:span><text:span text:style-name="Fraktur"> (jfr</text:span> stiva): Varr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mansues</text:span>, ētis (<text:span text:style-name="T3">acc.</text:span> <text:span text:style-name="Fraktur">äfwen</text:span> mansuem) <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Mansuētus</text:span>, <text:span text:style-name="T3">A.</text:span>: p. tr. gr.: (manus, sueo):<text:line-break/>1. <text:span text:style-name="Fraktur">eg. om djur: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tam, tamd, spak:</text:span></text:span> ex fera reddere fame m-tem, Pt.; quadrupedem mansuem; juvenci m-ti et ad domandum proni, Varr.; sus m-tus, L.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.: om menniskor och hwad till dem hörer:</text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">i motsats till häftig, hård: (tam), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Saktmodig, mild, foglig, lugn, lugnad:</text:span></text:span> in senatu m.; in edictis ferus (Antonius); moribus m-simus; ad m-ores Musas se referre; id malum (ɔ: tribuniciæ actiones) m-tum fuit et sopitum externis terroribus, L.; ira læsi numinis m-ior, Ov.; manus m-tæ, Ppt. <text:line-break/>b. <text:span text:style-name="Fraktur">i motsats till rå: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hyfsad:</text:span></text:span> nulla gens nec tam m-a est nec tam fera, quæ non deum habendum sciat, C. (de Legg. I. 8. <text:span text:style-name="Fraktur">der somlige läsa</text:span> immansueta).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mansuēfăcio</text:span>, fēci, factum, 3.: <text:span text:style-name="T3">pass.</text:span>: mansuēfio, factus, fĭĕri:<text:line-break/>1. <text:span text:style-name="Fraktur">om djur: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tämja, späka, göra tam:</text:span></text:span> uri possunt m-fieri, Cs.; animalia, Qu.; arietes m-facti, Col.<text:line-break/>2. <text:span text:style-name="Fraktur">om menniskor:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Göra tam, lugna, blidka:</text:span></text:span> plebem patres, L.; ingenium ferum, Su. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förmildra</text:span></text:span><text:span text:style-name="Fraktur"> ngn till hans seder, eller någons seder; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">hyfsa:</text:span></text:span> m-facti a necessariis artificiis ad elegantiora defluximus, C.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Mansuesco</text:span>, suēvi, 3.:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Blifwa tam, göras tam; förmildras:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">om djur:</text:span> buculæ, Col.; feræ, Luc.<text:line-break/>b. <text:span text:style-name="Fraktur">om menniskor:</text:span> humanis precibus m-re inscia corda (inferorum), Vg.<text:line-break/>c. <text:span text:style-name="Fraktur">om jord, wäxter o. d.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Odlas; blifwa mild:</text:span></text:span> terra arando, Vg.; humor; fructus feri, Lucr.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tämja:</text:span></text:span> Varr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mansuētārius</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Djurtämjare:</text:span></text:span> Lpd. <text:line-break/><text:span text:style-name="T1">Mansuēte</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Med saktmod, med tålamod, med hofsamhet, med lugn; mildt, lugnt:</text:span></text:span> factum; ferre fortunam, C.; oboedire imperio, L.; immansueta m. tractanda sunt, Sen. <text:line-break/><text:span text:style-name="T1">Mansuētūdo</text:span>, ĭnis, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">om djur: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tamhet, spakhet:</text:span></text:span> elephanti, Js.<text:line-break/>2. <text:span text:style-name="Fraktur">såsom mensklig egenskap: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Saktmod</text:span></text:span><text:span text:style-name="Fraktur"> (långmod), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">hofsamhet, foglighet, mildhet, beskedlighet; tålamod:</text:span></text:span> m. imperii nostri; m. <text:span text:style-name="Fraktur">(mildhet)</text:span> Cæsaris in summa omnium rerum potestate; signa facilitatis, humanitatis, liberalitatis, m-is proferre; m. morum et facilitas, C.; uti m-e et clementia in aliquem (victum), Cs.; populi Rom. ea m., ut nemo ab eo frustra auxilium petiverit, Sa.; comitas in socios, m. in hostes (Germanici), T. - <text:span text:style-name="Fraktur">titel för kejsare</text:span> m. tua <text:span text:style-name="Fraktur">(= Din nåd),</text:span> Eutr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Immansuetus</text:span>, <text:span text:style-name="T3">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Otamd, wild, okufwad, -lig:</text:span></text:span> bos, Sen.; ingenium; de rapidis ventis i-us Boreas, Ov. <text:span text:style-name="Fraktur">(jfr</text:span> mansuetus 2. b.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mănuālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">s. hör till handen l. som kan fattas med, hållas i handen, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hand-:</text:span></text:span> digiti, Cass.; fasciculus, Pn.; saxa, T.<text:line-break/><text:span text:style-name="T1">Mănuāle</text:span>, is, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">(ss. det tyckes, ett handtag, hwari man höll bokrullen),</text:span> Mt.<text:line-break/><text:span text:style-name="T1">Mănuārius</text:span>, <text:span text:style-name="T3">A.</text:span>: id.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mănūbrium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handtag, skaft:</text:span></text:span> trulla m-o aureo, C.<text:line-break/><text:span text:style-name="T1">Mănūbriātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">försedd med handtag:</text:span> Pall.<text:line-break/><text:span text:style-name="T1">Mănūbriŏlum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: Ce.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mănŭlea</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Mănŭleus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Ärm</text:span></text:span><text:span text:style-name="Fraktur"> på tunican (lång) l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">manschett, uppslag</text:span></text:span><text:span text:style-name="Fraktur"> derpå:</text:span> Pt., Fronto.<text:line-break/>2. <text:span text:style-name="Fraktur">ett wißt parti af en</text:span> catapulta <text:span text:style-name="Fraktur"><text:span text:style-name="T2">(hane):</text:span></text:span> Vitr.<text:line-break/><text:span text:style-name="T1">Mănŭleārius</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">förfärdigare af</text:span> manuleæ (1.): Pt. Aul. 465 inc. l.<text:line-break/><text:span text:style-name="T1">Mănŭleātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">försedd med långa ärmar l. manschetter, på tunican l. om tunican (hwilket ansågs wekligt):</text:span> tunica, Pt.; m-um prodire in publicum, Su.; Epicurus fortis est, licet sit m., Sen.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mănŭprĕtium</text:span> <text:line-break/>(manipretium, <text:line-break/>manuprecium, <text:line-break/>manus pretium), i, <text:span text:style-name="T3">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Arbetslön</text:span></text:span><text:span text:style-name="Fraktur"> i motsats till ämnets l. warans wärde i och för sig (fabricationskostnad):</text:span> cedo aurum mi: ego m. dabo, Pt.; quod manu factum erat et datum pro eo, m. (dicebatur) a manibus et pretio, Varr. l. l. V. 178. VI. 85; m. machinæ, C. in Verr. I. §. 147; in auro præter m. nihil intertrimenti fuit, L.<text:line-break/><text:soft-page-break/>2. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Lön</text:span></text:span><text:span text:style-name="Fraktur"> (i föraktlig mening):</text:span> Pisoni provincia m. fuit perditæ civitatis, C.<text:line-break/><text:span text:style-name="T1">Mănŭprĕtiōsus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">af dyrbart arbete:</text:span> Cato.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Āmănuensis</text:span>, is, <text:span text:style-name="T3">m.</text:span>: (= a manu servus): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Handsecreterare:</text:span></text:span> Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Centĭmănus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hundrahändt:</text:span></text:span> Hor., Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ūnĭmănus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Enhändt:</text:span></text:span> puer, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mānus,</text:span> <text:span text:style-name="T3">A.</text:span>: vox obsol.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">God:</text:span></text:span> Varr., Paul. Diac.; <text:span text:style-name="Fraktur">enl.</text:span> Mcb. <text:span text:style-name="Fraktur">stamordet till</text:span> immanis.</text:p>
   <text:p text:style-name="P1">(<text:span text:style-name="T2">Măpāle,</text:span> is, <text:span text:style-name="T3">n.</text:span>: Vfl.)<text:line-break/><text:span text:style-name="T1">Măpālia</text:span>, ium, <text:span text:style-name="T3">n.</text:span>: (v. punica): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Herdehyddor, -tjäll, tält:</text:span></text:span> Vg., Mt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mappa,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">i allm.: tygstycke, duk:</text:span> <text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Servet:</text:span></text:span> sordida m.; m-ā compescere risum, Hor.; laticlavia (senatoris), Petr. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Duk, flagga,</text:span></text:span><text:span text:style-name="Fraktur"> hwarmed signalerades på Circus:</text:span> prætor mittit cretatam m-am, Juv.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărăthon, ōnis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">by i Attica.</text:span> <text:line-break/>Mărăthōnĭus, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Mărăthōnis, ĭdis, <text:span text:style-name="T3">A. f.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărăthos <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Mărăthus, i, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Phoenicien - äfwen personn.</text:span> <text:line-break/>Mărăthēnus, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">från Marathos.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mărăthrum,</text:span> i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Fenkål:</text:span></text:span> Pn.<text:line-break/><text:span text:style-name="T1">Mărăthrītes</text:span>, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">fenkålswin:</text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arcellīnus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">familjenamn i slägten</text:span> Lentulus.<text:line-break/><text:span text:style-name="T2">M</text:span>arcellus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">rom. familjenamn i slägten</text:span> Claudius. <text:line-break/>Marcellīa, ōrum, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">fest till en Marcelli ära (på Sicilien).</text:span> <text:line-break/>Marcelliānus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Marceo,</text:span> ēre:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wara wißnad, murken, skrumpen, hopfallen:</text:span></text:span> silva comis, St.; uvæ, Mt.; corpus annis, Lucr.; vir ab annis; guttur (veteris arietis), Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wara slapp, matt:</text:span></text:span> luxuriā, vino, epulis, L.; m-ens potor, Hor.; Vitellius deses et m-ens; Cherusci nimiam et m-entem diu pacem illacessiti nutriverunt, T.; visus, Sen.; color, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Marcesco</text:span>, ĕre: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wißna, twina; slappna, slappas, blifwa matt:</text:span></text:span> fagus, Pn.; desidiā et otio, L.; nimio vino, Ov.; stomachus onere cibi m-ens, Su.; morbo, Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Marcĭdus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wißnad, murken, hopskrumpen, slapp, matt:</text:span></text:span> lilia m-a demittunt caput, Ov.; m-i vetustate asseres, Vitr.; aures equis fessis m-æ; somno homo, Pn.; vina, St.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Marcor</text:span>, ōris, <text:span text:style-name="T3">m.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wißnadt</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">twinande tillstånd; murkenhet:</text:span></text:span> (e diluvio) vitium satis <text:span text:style-name="Fraktur">(af</text:span> sero) et segetum sine fruge surgentium m., Sen.; panni, Pn.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Slapphet, förtwinande:</text:span></text:span> ducis, Vell.; mæror m-que, Sen.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Commarceo</text:span>, 2. <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Commarcesco</text:span>, rcui, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wara, blifwa slapp:</text:span></text:span> Amm.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ēmarcesco</text:span>, rcui, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Twina bort, förswagas:</text:span></text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arcius, <text:span text:style-name="Fraktur">rom. gentilnamn.</text:span> <text:line-break/>Marcius <text:span text:style-name="Fraktur">och</text:span> <text:line-break/>Marciānus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arcodūrum, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">ort i Germanien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arcŏmāni <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Marcŏmanni, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">germaniskt folkslag (i Böhmen).</text:span> <text:line-break/>Marcŏmānia, ae, <text:span text:style-name="T3">f.</text:span> <text:line-break/>Marcŏmānĭcus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1">Marcor <text:span text:style-name="Fraktur">se</text:span> Marceo.<text:line-break/>Marculus <text:span text:style-name="Fraktur">se</text:span> I. Marcus.</text:p>
   <text:p text:style-name="P1">I. <text:span text:style-name="T2">Marcus,</text:span> i, <text:span text:style-name="T3">m.</text:span> (Isid.)<text:line-break/><text:span text:style-name="T1">Marcŭlus</text:span> <text:line-break/>(Martŭlus), i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hammare:</text:span></text:span> Pn., Mt.</text:p>
   <text:p text:style-name="P1">II. <text:span text:style-name="T2">M</text:span>arcus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">rom. prænomen.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ardi, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i Asien.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ardŏnius, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">persiskt namn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Măre,</text:span> is, (<text:span text:style-name="T3">pl.</text:span> marum, Næv., maribus, Cs. (semel), <text:span text:style-name="Fraktur">annars blott i formen</text:span> maria), <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Haf:</text:span></text:span> immensum; profundum; tempestivum ad navigandum; terra m-ique conquirere alqd; inferum (= Tyrrhenum), superum (= Adriaticum), C.; m. tutum reddere; m. scopulosum; m-i et terrā duces erant Lacedæmonii; m-i res gerere, N.; pacatum, turbatum m.; filios per ignotas terras, ignotiora m-ia in Græciam misit, L.; m-ia omnia cælo miscuit (Juno), Vg.; per m., trans m. currere; in m-e procurrit Apenninus, Hor.; casuum m-is ignarus; violentior cetero m-i Oceanus, T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mărīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">s. tillhör hafwet, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hafwets,</text:span></text:span><text:span text:style-name="Fraktur"> som bor i hafwet, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">hafs-,</text:span></text:span><text:span text:style-name="Fraktur"> är kommen ur hafwet:</text:span> humores; æstus, C.; monstra, Vg.; ros; Venus m-a <text:span text:style-name="Fraktur">(den ur hafwet födda),</text:span> Hor.; aqua, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Permărīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: Lares <text:span text:style-name="Fraktur">(s. skydda sjöfarande),</text:span> L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Transmărīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">som är </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">på</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">från</text:span></text:span><text:span text:style-name="Fraktur"> andra sidan hafwet:</text:span> res; doctrina; vectigalia, C.; gens, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mărĭtĭmus</text:span> <text:line-break/>(Mărĭtŭmus), <text:span text:style-name="T3">A.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur">s. är belägen, bor wid haf, sker på haf m. m., </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hafs-, sjö-, kust-, till sjös:</text:span></text:span> ora; gens; bellum; homo a rebus m-is remotissimus, C.; imperium m-um; prædo, N.; oppida, Cs.<text:line-break/>b. <text:span text:style-name="Fraktur">s. tillhör hafwet; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hafwets:</text:span></text:span> æstus, C., Cs.; fluctibus m-is jactari, N.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Bĭmăris</text:span>, <text:span text:style-name="T3">A.</text:span>: Corinthus, <text:span text:style-name="Fraktur">wid twenne haf beläget,</text:span> Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărĕa <text:span text:style-name="Fraktur">och</text:span> <text:line-break/><text:span text:style-name="T2">M</text:span>ărĕōta, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">sjö och stad i Aegypten.</text:span> <text:line-break/><text:soft-page-break/>Mărĕōtĭcus, <text:span text:style-name="T3">A.</text:span>: <text:line-break/>Mărĕōtis, ĭdis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">mareotisk (ægyptisk).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Marga,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">mergel:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Margărīta,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: (C.)<text:line-break/><text:span text:style-name="T1">Margărītum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: (T.), <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Perla.</text:span></text:span><text:line-break/><text:span text:style-name="T1">Margărītĭfer</text:span>, <text:span text:style-name="T3">A.</text:span>: cochlea, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Margo,</text:span> ĭnis, <text:span text:style-name="T3">m., f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Rand, ram, brädd</text:span></text:span><text:span text:style-name="Fraktur"> (gräns):</text:span> m-es fluminis lapidei, Varr.; fontis; ripæ; brachia longo m-e terrarum porrexerat Amphitrite, Ov.; imperii, Pn.; summi jam plena m-e libri scriptus et in tergo neque dum finitus Orestes, Juv.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Margĭno</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Omgifwa med rand</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">infattning:</text:span></text:span> vias glarea substernere et m. <text:span text:style-name="Fraktur">(förse med trottoir, upphöjd wäg för gående),</text:span> L.; tabula m-ta, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Commargĭno</text:span>, 1.: id.: Amm.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ēmargĭno</text:span>, 1.: ulcera, <text:span text:style-name="Fraktur">taga bort randen, skorpan från -,</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărīca, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">träsk i närheten af Minturnæ.</text:span></text:p>
   <text:p text:style-name="P1">Marinus <text:span text:style-name="Fraktur">se</text:span> Mare.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mărisca,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">ett slags dåliga </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Fikon:</text:span></text:span> Pn. - <text:span text:style-name="Fraktur">tagg i sätet:</text:span> Juv.</text:p>
   <text:p text:style-name="P1">Marĭtimus, -tumus <text:span text:style-name="Fraktur">se</text:span> Mare.<text:line-break/>Marīt . . . <text:span text:style-name="Fraktur">se</text:span> Mas.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărius, <text:span text:style-name="Fraktur">rom. slägtnamn.</text:span> <text:line-break/>Măriānus, <text:span text:style-name="T3">A.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>armărĭca, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">land i Africa.</text:span> <text:line-break/>Marmărĭcus, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Marmărĭdes, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">inw. i M.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Marmor,</text:span> ŏris, <text:span text:style-name="T3">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Marmor, -sten, -block; arbete af marmor:</text:span></text:span> simulacrum e m-e, C.; solido de m-e templa; læve m., Vg.; secare m-a; incisa notis m-a publicis <text:span text:style-name="Fraktur">(triumphbågar o. d.),</text:span> Hor.; m. tertium (= miliarium t.), Mt.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hafsskum;</text:span></text:span><text:span text:style-name="Fraktur"> det skummande </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">hafwet, wågen:</text:span></text:span> mare - vertitur in canos candenti m-e fluctus, Lucr.; spumant vada m-e verso, Vg.<text:line-break/><text:span text:style-name="T1">Marmŏrārius</text:span>, <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur">s. arbetar i marmor; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Marmorarbetare:</text:span></text:span> faber m.; m., Sen.<text:line-break/><text:span text:style-name="T1">Marmŏreus</text:span>, <text:span text:style-name="T3">A.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Af marmor, marmor-:</text:span></text:span> signum; tecta; solum, C.; m. Priapus <text:span text:style-name="Fraktur">(-bild);</text:span> thalamus, Vg.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Marmorlik</text:span></text:span><text:span text:style-name="Fraktur"> (-hwit, -klar, -fast):</text:span> cervix; æquor, Vg.; palma; pedes, Ov.<text:line-break/>3. subtilitas artis m-æ <text:span text:style-name="Fraktur">(konst att bearbeta m.),</text:span> Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Marmŏro</text:span>, 1.:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bekläda</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">belägga med marmor:</text:span></text:span> genus m-di, Lpd.; porticus m-ta, Petr.<text:line-break/>b. <text:span text:style-name="T3">part.</text:span>:<text:line-break/><text:span text:style-name="T1">Marmŏrātus</text:span>, <text:span text:style-name="Fraktur">af (stött) marmor tillredd:</text:span> tectorium, Varr., Pn. <text:line-break/><text:soft-page-break/><text:span text:style-name="T1">Marmŏrātum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">murbruk af m.:</text:span> Varr. <text:line-break/><text:span text:style-name="T1">Marmŏrātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Marmorbeläggning:</text:span></text:span> pavimenti, Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Marmŏrōsus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Marmorhård:</text:span></text:span> silex, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ăro, ōnis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">familjenamn (Virgilii).</text:span> <text:line-break/>Mărōnēus, <text:line-break/>Mărōniānus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>aroboduus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">germ. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărōnēa <text:line-break/>(Mărōnīa), ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stadsn.</text:span> <text:line-break/>Mărōnēus, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Mărōnītes, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">inw. i M.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arpessus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">berg på Paros.</text:span> <text:line-break/>Marpessĭus, <text:span text:style-name="T3">A.</text:span> = <text:span text:style-name="Fraktur">parisk.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Marra,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hacka, lukjern:</text:span></text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Marrŭbium,</text:span> i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">getmynta:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arrŭbium, <text:line-break/>Marrŭvium, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">marsisk stad.</text:span> <text:line-break/>Marrŭbius, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arrūcīni, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i Italien wid Adriatiska hafwet.</text:span> <text:line-break/>Marrūcīnus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ars, tis, <text:span text:style-name="Fraktur">eg. och arch.:</text:span> <text:line-break/><text:span text:style-name="T2">M</text:span>āvors, vortis, <text:span text:style-name="Fraktur">(i</text:span> Carm. Arval.: Marmar), <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T3">Mars,</text:span></text:span><text:span text:style-name="Fraktur"> krigsguden,</text:span> M. pater; <text:line-break/>Marspiter <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Maspiter, Varr. - <text:span text:style-name="Fraktur">met.</text:span> =<text:line-break/>a. <text:span text:style-name="Fraktur">krig, strid, stridssätt:</text:span> decennis, Sen.; et suo et alieno M-e pugnare <text:span text:style-name="Fraktur">(om rytteriet, s. sutit af),</text:span> L.; fora suo M-e vacant, Ov.<text:line-break/>b. <text:span text:style-name="Fraktur">stridskrafter, krafter:</text:span> hanc partem explebimus nullis adminiculis, sed, ut dicitur, M-e nostro, C.<text:line-break/>c. <text:span text:style-name="Fraktur">ställning i striden, stridens lycka, utgång:</text:span> varia victoria et velut æquo M-e [<text:span text:style-name="Fraktur">eg. med Mars opartisk (neutral</text:span>)], L.; parati prope æquo M-e ad dimicandum, Cs.; jam, æquato M-e, singuli supererant, L.; omnis belli M. communis, C.; vario M-e pugnare, Qu.<text:line-break/><text:span text:style-name="T2">M</text:span>āvortius, <text:line-break/><text:span text:style-name="T2">M</text:span>artius, <text:line-break/><text:span text:style-name="T2">M</text:span>artiālis, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">Mars tillhörig, åt Mars helgad; krigisk:</text:span> lupi M-i, M-les, Vg., Hor.; Mavortia moenia <text:span text:style-name="Fraktur">(Roms),</text:span> Vg.; Mavortia facta, Sil. - <text:span text:style-name="Fraktur">sersk.:</text:span> mensis Martius; Idus, Calendæ M-æ, <text:span text:style-name="Fraktur">månaden Mars, Idus, Calendæ i Mars.</text:span><text:line-break/><text:span text:style-name="T2">M</text:span>artĭcŏla, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">(Marsdyrkande), krigisk:</text:span> Getæ, Ov. <text:line-break/>Martĭgĕna, ae, <text:span text:style-name="T3">c.</text:span>: <text:span text:style-name="Fraktur">barn (son) af Mars:</text:span> Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Marsŭpĭum,</text:span> i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Pung:</text:span></text:span> numorum, Pt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arsus, <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Marsisk, Marser,</text:span></text:span><text:span text:style-name="Fraktur"> italiskt folkslagsnamn.</text:span> <text:line-break/>Marsĭcus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">M</text:span>arsi, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:line-break/>Marsigni, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">germaniska folk.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arsy̆as, ae, <text:span text:style-name="T3">m.</text:span>: v. gr.: <text:span text:style-name="Fraktur">flodn.; mythol. personn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>artulus <text:span text:style-name="Fraktur">se</text:span> I. Marcus.<text:line-break/>Mart . . . <text:span text:style-name="Fraktur">se för öfrigt</text:span> Mars.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ărullus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">rom. tillnamn.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>arus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">flod i Dacien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mās,</text:span> măris, <text:span text:style-name="T3">m.</text:span> (<text:span text:style-name="T3">n.</text:span> mare et femineum secus, Ap.), <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Han-, hanne, af man-</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">hankön; manlig, man:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg., blott om könet:</text:span> m. anguis; dii m-es et feminæ; m-bus hostiis immolare, C.; m-es (boves, agni), Vg.; m-em vitellum cohibent callosa ova, Hor.; vos, m-es, <text:span text:style-name="Fraktur">(ynglingar),</text:span> laudibus tollite Tempe, Hor.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.: till sinnet </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Manlig:</text:span></text:span> m-bus Curiis et Camillis decantata nænia; m-es animos versibus exacuit Tyrtæus, Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mărītus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">(liks.</text:span> <text:span text:style-name="T3">part. pf.</text:span> <text:span text:style-name="Fraktur">af ett</text:span> mario):<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förmäld,</text:span></text:span><text:span text:style-name="Fraktur"> om wäxter (sersk. winträd) = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">fastbunden</text:span></text:span><text:span text:style-name="Fraktur"> till stöd wid större träd:</text:span> arbores facito, ut bene m-æ sint, Cato; <text:span text:style-name="Fraktur">om det stödjande trädet:</text:span> m-a ulmus, Qu. - <text:span text:style-name="T3">Subst.</text:span> <text:line-break/><text:span text:style-name="T1">Mărītus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">någons </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Man:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">äkta:</text:span> <text:span text:style-name="T3">pl.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Äkta folk, makar:</text:span></text:span> m. optimæ mulieris, C.; forti m-o uxorem destinare, Hor.; nuptam esse m-o, Ov.; malus ingratusque m., Juv. - dare jura m-is <text:span text:style-name="Fraktur">(makar),</text:span> Hor.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Friare, älskare:</text:span></text:span> te nulli flexere m-i, Vg.; fronte proterva petere m-um, Hor.<text:line-break/>c. <text:span text:style-name="Fraktur">oeg.: om djur: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Man:</text:span></text:span> uxor olentis m-i <text:span text:style-name="Fraktur">(bockens),</text:span> Hor.<text:line-break/><text:span text:style-name="T1">Mărīta</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hustru:</text:span></text:span> Hor., Ov.<text:line-break/>2. <text:span text:style-name="Fraktur">s. har afseende på äktenskap, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Äktenskaps-; äkta, bröllops-:</text:span></text:span> lex (= l. Julia), Hor.; faces; torus, Ov.; domus m-æ <text:span text:style-name="Fraktur">(= familjer),</text:span> L.<text:line-break/><text:span text:style-name="T1">Mărītālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Äkta, äktenskaps-, bröllops-:</text:span></text:span> conjugium, Col.; vestis; fax, Ov.<text:line-break/><text:span text:style-name="T1">Mărīto</text:span>, 1.:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bortgifta, förmäla; genom giftermål förbinda:</text:span></text:span> principem, T.; filiam; ordines, Su.<text:line-break/>b. <text:span text:style-name="Fraktur">om djur: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Låta para sig:</text:span></text:span> capra post bimatum m-ri debet; <text:span text:style-name="Fraktur">äfwen i</text:span> <text:span text:style-name="T3">pass.</text:span> = <text:span text:style-name="Fraktur"><text:span text:style-name="T2">para sig, blifwa drägtig:</text:span></text:span> Col.<text:line-break/>c. <text:span text:style-name="Fraktur">om wäxter, träd: (till stöd) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hopbinda, omslingra; befrukta:</text:span></text:span> adulta vitium propagine altas m-at populos, Hor.; ulmi vitibus m-antur, Col.; (Favonio) m-antur vivescentia e terra, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Bĭmărītus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">twenne hustrurs man:</text:span> (”verbum fictum” ab accusatore quodam), C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Commărītus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">med - äkta - man (”swåger”):</text:span> Pt. Casina IV. 2. 18.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mascŭlus</text:span>, <text:span text:style-name="T3">A.:</text:span><text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Af mankön, manlig:</text:span></text:span> infans, L. - tura m-a, Vg., <text:span text:style-name="Fraktur">enl.</text:span> Pn. = <text:span text:style-name="Fraktur">runda rökelsekorn</text:span> [quod ex (arbore turifera) rotunditate guttæ pependit, m-um vocamus - a specie testium dictum]. - <text:span text:style-name="T3">Subst.</text:span>: bona femina et malus m., Pt.<text:line-break/><text:soft-page-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Manlig</text:span></text:span><text:span text:style-name="Fraktur"> till sinnet:</text:span> m-a proles (Sabinorum); m-a Sappho, Hor.<text:line-break/><text:span text:style-name="T1">Mascŭlesco</text:span>, ĕre: raporum duo genera, masculum femininumque - ex eodem semine - densiore satu m-unt, Pn. <text:line-break/><text:span text:style-name="T1">Mascŭlētum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">plantering af manlige winstockar</text:span> (i. e. <text:span text:style-name="Fraktur">s. ej toppas):</text:span> Pn.<text:line-break/><text:span text:style-name="T1">Mascŭlīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Af manligt kön; af manligt genus</text:span></text:span><text:span text:style-name="Fraktur"> (gramm.):</text:span> sexus, Pn.; nomina, Qu.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Commascŭlo</text:span>, 1. <text:span text:style-name="Fraktur">göra manlig l. modig:</text:span> Ap., Mcb.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ēmascŭlo</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Snöpa:</text:span></text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ăsĭnissa, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">numidiskt personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Massa,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Massa, klump, klimp:</text:span></text:span> picis, Vg.; lactis m. coacti <text:span text:style-name="Fraktur">(ost);</text:span> chalybis <text:span text:style-name="Fraktur">(i smältugnen),</text:span> Ov.; ferri, Col.<text:line-break/><text:span text:style-name="T1">Massŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>assæsȳli, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i Africa.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>assăgĕtæ, ārum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i HögAsien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>assĭcus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">berg i Campanien.</text:span> <text:line-break/>Massĭcum, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">massiskt win.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>assĭlia, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Gallien (Marseille).</text:span> <text:line-break/>Massĭliānus, <text:line-break/>Massĭliensis, <text:line-break/>Massĭliōtĭcus, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Massĭlienses, ium, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">inwånare i M.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>assŭrius <text:line-break/>(Māsurius), i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">rom. slägtnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>assȳli, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i Africa.</text:span> <text:line-break/>Massȳlus, <text:line-break/>Massȳlius, <text:span text:style-name="T3">A.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>astanăbal, ălis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">numidiskt personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mastĭchē</text:span> <text:line-break/>(Mastĭcē), es, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mastix</text:span></text:span><text:span text:style-name="Fraktur"> (kåda af mastixträdet):</text:span> Pn.<text:line-break/><text:span text:style-name="T1">Mastĭchātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">kryddad med -:</text:span> Lpd.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mastĭco,</text:span> 1.: <text:span text:style-name="Fraktur">tugga:</text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mastīgĭa,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">(som förtjenar stryk) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Slyngel:</text:span></text:span> Pt., Ter.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mastrūca,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Skinnpels</text:span></text:span><text:span text:style-name="Fraktur"> (sardiskt ord):</text:span> Qu. - <text:span text:style-name="Fraktur">sås. glåpord om person,</text:span> Pt. <text:line-break/><text:span text:style-name="T1">Mastrūcātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">klädd i skinnpels:</text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Matăra,</text:span> ae, <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Matăris</text:span>,<text:line-break/><text:span text:style-name="T1">Matĕris</text:span>, is, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">galliskt </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Kastspjut:</text:span></text:span> Cs., L., C.</text:p>
   <text:p text:style-name="P1">Matella, -tellio <text:span text:style-name="Fraktur">se</text:span> Matula.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mateŏla,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Slägga, jungfru:</text:span></text:span> m-ā adigere, Cato</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">Māter,</text:span> tris, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moder:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg.: (om mskor och djur):</text:span> m-e liberā esse; deā m-e nasci; m-i blandiri; filii in gremio - m-is educati, C.; Sabina m-e ortus, L.; m. timidi flere non solet, N.; m-e pulcrā filia pulcrior; m. pia, honesta Hor.; m. redit <text:span text:style-name="Fraktur">(modren hos ngn = moders-ömheten),</text:span> Sen.; m. familias <text:span text:style-name="Fraktur">(husmoder),</text:span> C,; prohibere a m-bus hædos, Vg.; m-es equorum, Hor.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">i tilltal till äldre qwinnor och öfwerhufwud</text:span> = matrona: o m. <text:span text:style-name="Fraktur">(Turnus till en prestinna),</text:span> Vg.; unxere m-es Iliæ - homicidam Hectorem, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">om gudinnor så wäl absol., som i förhållande till det, s. de frambringa, gifwa, skapa:</text:span> Magna M. = <text:span text:style-name="Fraktur">den phrygiska gudinnan, allmodren, gudamodren (Cybele);</text:span> genitor Mavors Vestaque m. ades, Ov.; M. Matuta, L.; m. florum (Flora), Ov.; m. sæva Cupidinum, Hor.<text:line-break/>c. <text:span text:style-name="Fraktur">om trädet, stammen i förhållande till ympqwisten:</text:span> plantas de corpore m-um abscisas deponere sulcis, Vg.; Col.<text:line-break/>d. <text:span text:style-name="Fraktur">om jorden ss. allt lefwandes moder:</text:span> gremium quasi m-is mortuo (humato) tribuitur, C.<text:line-break/>e. <text:span text:style-name="Fraktur">i allm. om concreta l. abstracta subject i förh. till det, s. de frambringa l. förorsaka:</text:span> apis m. mellis, Varr.; luxuries m. avaritiæ; m. omnium bonarum artium sapientia, C.; utilitas justi prope m. et æqui, Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātercŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: <text:span text:style-name="Fraktur">kär, öm, swag (stackars) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moder</text:span></text:span><text:span text:style-name="Fraktur"> (mamma):</text:span> m-æ suæ, aniculæ minime suspiciosæ, purgat se filius, C.; pueris m. pallet (mense Sextili), Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Māternus</text:span>, <text:span text:style-name="T3">A.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moders-, möderne; på mors-sidan</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">mödernet</text:span></text:span><text:span text:style-name="Fraktur"> (moder tillhörig l. af moder ärfd):</text:span> sanguis; nomen, C.; m-o genere impar <text:span text:style-name="Fraktur">(wanbördig),</text:span> Sa.; Tarquinio Tarquinii m-a tantum patria erat, L.; velat (Aeneas) m-ā <text:span text:style-name="Fraktur">(åt hans moder helgad)</text:span> myrto tempora; m. avus <text:span text:style-name="Fraktur">(morfar),</text:span> Vg.; rebus m-is atque paternis absumptis, Hor. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moderlig:</text:span></text:span> animus, Ter.; mens, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātertĕra</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moster:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ātrālia, ium, <text:span text:style-name="T3">n.</text:span>: Matris Matutæ <text:span text:style-name="Fraktur">festdag:</text:span> Varr., Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātrĭcīda</text:span>, ae, <text:span text:style-name="T3">m.</text:span>: (cædo): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Modermördare:</text:span></text:span> C.<text:line-break/><text:span text:style-name="T1">Mātrĭcīdium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Modermord:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātrĭmōnium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">hustrus stånd och rätt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Äktenskap:</text:span></text:span> jus m-i castum atque legitimum; dignitas m-i, C.; (Romulus promittebat Sabinis) in m-o, in societate fortunarum omnium - fore, L.; justum m., Js.; in m-um alicui filiam dare, Cs., N.; in m-o certo et stabili locare, C.; aliquam in m-um ducere <text:span text:style-name="Fraktur">(taga till äkta),</text:span> C., Cs.; m-o secum jungere, conjungere, Ct.; in m-um accipere, T.; aliquam in m-o habere; m-o tenere, C.; aliquam m-o dimittere, Su.; depellere; de m-o principis <text:span text:style-name="Fraktur">(med</text:span> p.) certare, T. - <text:span text:style-name="Fraktur">hos sednare förf.:</text:span> alicujus viri m., <text:span text:style-name="Fraktur">närmande sig till concret bet. = hustru:</text:span> m-a ac pecunias hostium prædæ (milites destinabant), T.; servis interfectorum m-a <text:soft-page-break/>pollicebantur; ut severius m-a sua viri coërcerent, virgines sine dote nubere jussit, Js.; omnium m-a corrumpere, Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātrīmus</text:span>, <text:span text:style-name="T3">A.</text:span>: (<text:span text:style-name="T3">plur. nom.</text:span> <text:span text:style-name="Fraktur">archaist.</text:span> <text:line-break/>matrimes): <text:span text:style-name="Fraktur">som har moder i lifwet, hwars mor lefwer:</text:span> puer patrimus et m., C., L., T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātrix</text:span>, īcis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moder,</text:span></text:span><text:span text:style-name="Fraktur"> blott</text:span> =<text:line-break/>a. <text:span text:style-name="Fraktur">moderdjur = s. hålles för afwels skull:</text:span> ad m-es LXX habeo tauros duo, Varr.; et m-es (sues) et juniores, Col.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Moderträd</text:span></text:span><text:span text:style-name="Fraktur"> i förh. till afläggare:</text:span> Su.<text:line-break/>c. vena m., <text:span text:style-name="Fraktur">en wiß ådra:</text:span> Veg.<text:line-break/><text:span text:style-name="T1">Mātrīcŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Lista, rulla, matrikel:</text:span></text:span> Veg., Jct.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātrōna</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">(jfr</text:span> patronus, -a): <text:span text:style-name="Fraktur">gift qwinna (af stånd, i synnerhet = gift dame, med afs. på hennes sociala ställning; deremot</text:span> uxor <text:span text:style-name="Fraktur">i förh. till mannen och</text:span> mater familias <text:span text:style-name="Fraktur">i förh. till huset), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T3">Matrona,</text:span></text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2"> fru, husfru:</text:span></text:span> dea, quæ partus m-arum tuetur -; m-æ optimates; sanctitas m-arum; ornamenta m-arum pudicitia, non vestes, C.; m-æ Brutum, ut parentem, luxerunt; m-æ ad Veturiam, matrem Coriolani, Volumniamque uxorem frequentes coëunt; plebejæ m-æ, L.; muros cinxere m-æ puerique, Vg.; m. potens, togata; m. meretrici dispar et discolor, Hor.; M. Juno, Hor. - <text:span text:style-name="Fraktur">poet.: någons hustru, gemål:</text:span> m. bellantis tyranni; m-æ nostræ, Hor.; magni m. Tonantis, Ov. <text:line-break/><text:span text:style-name="T1">Mātrōnālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">s. tillhör l. anstår gift qwinna:</text:span> decus, L.; habitus, Js.<text:line-break/><text:span text:style-name="T1">Mātrōnālia</text:span>, um, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">matronornas fest:</text:span> Ov.<text:line-break/><text:span text:style-name="T1">Mātrōnātus</text:span>, us, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">dames drägt l. utstyrsel: (om en smyckad brud),</text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātruēlis</text:span>, is, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">morbrorsson:</text:span> Jct.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Bĭmāter</text:span>, tris, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">som har 2 mödrar:</text:span> Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mātĕria,</text:span> ae, <text:span text:style-name="T3">f.</text:span>:<text:line-break/><text:span text:style-name="T1">Mātĕries</text:span>, ēi, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">(wäl af</text:span> mater; <text:span text:style-name="Fraktur">jfr</text:span> luxuries <text:span text:style-name="Fraktur">af</text:span> luxus): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Ämne, material:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i eg. men.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm. (för wäxt l. konstens behandling):</text:span> nostra physica <text:span text:style-name="Fraktur">(naturphilosophiska principer)</text:span> constant ex effectione et ex m-a <text:span text:style-name="Fraktur">(grundämnet, materien),</text:span> quam fingit et format effectio; (difficilius) si nihil valet m-es (in vitibus), nova sarmenta culturā excitantur, C.; m-em (aurum) superabat opus, Ov.; delata confestim omnis m. <text:span text:style-name="Fraktur">(byggnadsmaterialet)</text:span> infra Veliam, L.<text:line-break/>b. <text:span text:style-name="Fraktur">sersk. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Timmer, wirke:</text:span></text:span> proba, Pt.; non saxum, non m-es advecta est; m., calx, cæmenta convecta, C.; m. cæsa; afflictarum navium m-ā ad reliquas reficiendas utebatur; m. præacuta, bipedalis, Cs.; domorum, Sa.<text:line-break/>c. <text:span text:style-name="Fraktur">om djur: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Race:</text:span></text:span> generosa; mularis, Col.<text:line-break/>2. <text:span text:style-name="Fraktur">i oeg. men.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Ämne</text:span></text:span><text:span text:style-name="Fraktur"> för wäxt l. utbildning:</text:span> cognovit vir - quidam sapiens - quæ m-es et quanta ad res maximas opportunitas in animis inesset hominum, C.; puer ingentis decoris m., L. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Näringsämne, anledning, tillfälle, orsak:</text:span></text:span> m-a seditionis; seges et m-es gloriæ (Milonis Clodius); opes - bonitati ac moderationi facultatem et m-am dedit, C.; pecuniæ cupido omnium malorum m., <text:soft-page-break/>Sa.; belli m-em undique quærere, L.; parva res præbuit juveni m-em apiscendi favoris; m-em sceleri detrahere, T.; aurum m-es summi mali, Hor.; m. bene faciendi, Pn. <text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Ämne, föremål, stoff, material</text:span></text:span><text:span text:style-name="Fraktur"> för behandling i tanke, tal, skrift (ej = thema):</text:span> (sapientiæ) quasi m., quam tractet et in qua versetur, subjecta est veritas; m. artis ea est, in qua omnis ars et facultas, quæ conficitur ex arte, versatur (ut medicinæ - morbi); omnem artis - vim et m-am comprehendere; m. <text:span text:style-name="Fraktur">(materialet = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">innehållet)</text:span></text:span> physici, ornatus verborum oratoris putandus est; crescit mihi (scribenti) m.; m-am orationis omnibus locis descriptam, instructam, ornatam habere; duplex ad tractandum proposita m.; est facilis m. in te dicere; corporis deformitas bella est ad jocandum m., C.; sumite m-am vestris, qui scribitis, æquam ingeniis; publica m. privati juris erit, si -, Hor.; scribendi, Su. <text:line-break/><text:span text:style-name="T1">Mātĕriālis</text:span>, <text:span text:style-name="T3">A.</text:span>: influxio, m. <text:span text:style-name="Fraktur">(af materien, kroppen),</text:span> Mcb.<text:line-break/><text:span text:style-name="T1">Mātĕriārius</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Timmer-:</text:span></text:span> fabrica, Pn.<text:line-break/><text:span text:style-name="T1">Mātĕriārius</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Timmerman, byggmästare</text:span></text:span><text:span text:style-name="Fraktur"> (bildl.):</text:span> Pt.<text:line-break/><text:span text:style-name="T1">Mātĕrīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: terra m-a <text:span text:style-name="Fraktur">(hård?),</text:span> Cato.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātĕrio</text:span>, 1.: <text:span text:style-name="Fraktur">uppföra af trä:</text:span> ea ædificia minime sunt m-da, Vitr. - male m-tæ ædes, <text:span text:style-name="Fraktur">af dåligt timmer,</text:span> C.<text:line-break/><text:span text:style-name="T1">Mātĕrior</text:span>, 1.: <text:span text:style-name="T3">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hugga, hemta timmer:</text:span></text:span> Cs.<text:line-break/><text:span text:style-name="T1">Mātĕriātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Timmerwerk, träwirke, bjelklager:</text:span></text:span> Vitr. <text:line-break/><text:span text:style-name="T1">Mātĕriātūra</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Timmerbyggnad</text:span></text:span><text:span text:style-name="Fraktur"> (i mots. till stenbyggnad):</text:span> Vitr.</text:p>
   <text:p text:style-name="P1">Materis <text:span text:style-name="Fraktur">se</text:span> Matara.<text:line-break/>Maternus, -tertera <text:span text:style-name="Fraktur">se</text:span> Mater.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Măthēmătĭcus,</text:span> <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mathematisk:</text:span></text:span> disciplina, Gell.<text:line-break/><text:span text:style-name="T1">Măthēmătĭcus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mathematicus:</text:span></text:span> initia m-orum, C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Astrolog:</text:span></text:span> Su., Juv.<text:line-break/><text:span text:style-name="T1">Măthēmătĭca</text:span>, ae, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mathematik:</text:span></text:span> C.<text:line-break/>b. <text:span text:style-name="Fraktur">stjerntydarekonst, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Astrologi:</text:span></text:span> Tiberius addictus m-æ plenusque persuasionis cuncta fato agi, Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Măthēsis</text:span>, is, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mathematik, astrologi:</text:span></text:span> Cass., Sp.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ătīnus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">berg i Apulien.</text:span> <text:line-break/>Mătīnus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>atisco, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">galliskt stadsnamn.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>atius, <text:span text:style-name="Fraktur">rom. gentilnamn.</text:span> <text:line-break/>Matiānus, <text:span text:style-name="T3">A.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ātrŏna, ae, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">flod i Gallien (Marne).</text:span></text:p>
   <text:p text:style-name="P1">Matr . . . <text:span text:style-name="Fraktur">se</text:span> Mater.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Matta,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Matta:</text:span></text:span> scirpea, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mattĕa,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: (v. gr.; <text:span text:style-name="Fraktur">äfwen</text:span> <text:line-break/>mattya, <text:line-break/>mactea): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läckerbit:</text:span></text:span> Su., Mt.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">M</text:span>attium, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">germanisk ort wid Taunus.</text:span> <text:line-break/>Mattiăcus, <text:span text:style-name="T3">A.</text:span>: fontes M-i <text:span text:style-name="Fraktur">(Wiesbaden).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mattus</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T1">Mātus</text:span>, <text:span text:style-name="T3">A.</text:span> (= humectus; <text:span text:style-name="Fraktur">enl.</text:span> Isid. = madidus?): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Drucken:</text:span></text:span> Petr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mătŭla,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">kärl, sersk. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Nattpotta:</text:span></text:span> Pt.<text:span text:style-name="T3">;</text:span> <text:span text:style-name="Fraktur">om personer brukadt såsom skällsord:</text:span> nunquam ego te tam esse m-am credidi, Pt. Persa 533.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mătella</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: id.: Cato, Mt. <text:line-break/><text:span text:style-name="T1">Mătellio</text:span>, ōnis, <text:span text:style-name="T3">m.</text:span>: id.: C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mātūrus,</text:span> <text:span text:style-name="T3">A.</text:span>: p. tr. gr. (<text:span text:style-name="T3">Sup.</text:span> - turrimus, -turissimus):<text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mogen, fullmogen:</text:span></text:span><text:span text:style-name="Fraktur"> </text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">om frukter:</text:span> poma, frumenta, Cs., C.; uvæ, Vg.; seges m-a messi, L.; surculus m-simus, Col.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Fullgången</text:span></text:span><text:span text:style-name="Fraktur"> (om foster och barnaföderskor):</text:span> fetus, Ov.; partus, Hor.; venter, Ov.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">till år, sinne </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mogen,</text:span></text:span><text:span text:style-name="Fraktur"> så wäl</text:span> <text:line-break/>α. <text:span text:style-name="Fraktur">om yngre mskor = wuxen, utbildad för ngt:</text:span> m-a viro virgo, Vg.; militiæ m.; nondum Aeneæ filius imperio m. erat, L.; puer; m. rei faciendæ, Qu.; ad arma m., Sil. - <text:span text:style-name="Fraktur">som</text:span> <text:line-break/>β. <text:span text:style-name="Fraktur">om äldre menniskor = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mognad, stadgad, sansad:</text:span></text:span> Tiberius (morte Augusti) annis m. et militia bonus, T.; gravis annis et animi m., Vg.; m. animo et ævo, Ov.; intererit multum, m. senex loquatur an adhuc florente juventa fervidus; patres m-i, Hor. - <text:span text:style-name="Fraktur">i analogi härmed:</text:span> Thucydides si posterius fuisset, multo m-ior fuisset et mitior <text:span text:style-name="Fraktur">(i mots. till ungdomlig omogenhet),</text:span> C.<text:line-break/>b. <text:span text:style-name="Fraktur">om saker: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mogen</text:span></text:span><text:span text:style-name="Fraktur"> = färdig, beredd:</text:span> seditio m-a et prope erumpens, L.; vobis dis juvantibus omnia m-a sunt, victoria, præda, laus, Sa.; m-ā luce dies, Vg.<text:line-break/>II. <text:span text:style-name="Fraktur">s. sker i rätt tid, enl. naturens ordning; (om tider) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Rätt; läglig:</text:span></text:span> mors <text:span text:style-name="Fraktur">(en gammal mans),</text:span> L.; tempus m-um mortis; t. scribendi m-ius, C.; - <text:span text:style-name="Fraktur">deraf.</text:span> <text:line-break/>III. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tidig, snar, bråd, skyndsam:</text:span></text:span> in m-sima ætate virtutes comparare; spes m-æ decessionis; judicio m-o (ɔ: <text:span text:style-name="Fraktur">utan dröjsmål)</text:span> condemnari; facultas discendi major et m-ior <text:span text:style-name="Fraktur">(i tidigare ålder);</text:span> supplicium, C.; hiems, Cs.; m-a victoria; tædio regni m-ior venit libertas, L.; reditus m., Hor.; amplecti Britannicum (Narcissus), robur ætatis quam maturrimum precari <text:span text:style-name="Fraktur">(önska),</text:span> T.<text:line-break/><text:span text:style-name="T1">Mătūre</text:span>, <text:span text:style-name="T3">Adv.</text:span>: p. tr. gr.:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">I rätt</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">god tid, utan dröjsmål, raskt:</text:span></text:span> (m. nunc significat propere et cito. P. Nigidius: ”m.”, inquit, ”est, quod neque citius est neque serius”, Gell.): vigiles m. sentiunt; imperator vigilat, ut eo, quo intendit, m. perveniat, C.; m. noscere alqd, Ter.; ubi consulueris, m. facto opus est; m. exsequi mandata, Sa.; solve senescentem m. sanus equum, Hor.; Bibulus non satis m. occurrit; quibus rebus quam m-rime occurrendum putabat, Cs.; ut quæque res turpissima est, ita m-sime est judicanda, C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tidigt, snart:</text:span></text:span> m. fieri senem (dicunt), qui velit diu esse senex; ego omnium m-rime ad causas accessi, C.; urbem venalem et m. <text:soft-page-break/>perituram, Sa.; patere te vinci consilio, ut m-ius bello vincas, L.; pater m. decessit, N.; quod cupide petiit, m. plena reliquit, Hor.; tempus m-ius <text:span text:style-name="Fraktur">(förr)</text:span> me deserat, quam -, Sa.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātūresco</text:span>, rui, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mogna,</text:span></text:span><text:span text:style-name="Fraktur"> i eg. och oeg. bet.:</text:span> frumenta, Cs.; partus <text:span text:style-name="Fraktur">(bli fullgånget),</text:span> C.; virtus, L. - <text:span text:style-name="Fraktur">oeg.: = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">mjukna:</text:span></text:span> condita oliva muria, Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātūrĭtas</text:span>, ātis, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mogenhet, mognad:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">om frukter:</text:span> frugum; m-e tempestiva vietus et caducus; non potest esse in eo sucus diuturnus, quod nimis celeriter est m-em assecutum, C.<text:line-break/>2. gignendi m. <text:span text:style-name="Fraktur">(fullgångenhet),</text:span> C.<text:line-break/>3. <text:span text:style-name="Fraktur">om menniskor till ålder och sinne, så wäl i betyd. af fullt utwecklad kraft, som af (i ålderdomen) förminskad kraft och liflighet (öfwermogenhet, hopfallenhet):</text:span> adolescens non tam re et m-e, quam spe et exspectatione laudatus; ætatis m. ad prudentiam; et infirmitas puerorum et ferocitas juvenum et gravitas jam constantis ætatis et senectutis m. <text:span text:style-name="Fraktur">(liks. wißenhet)</text:span> naturale quiddam habet; vitam adolescentibus vis aufert, senibus m., C.<text:line-break/>4. <text:span text:style-name="Fraktur">i allm. med samma dubbelbetydelse:</text:span> virtutis, latine dicendi m.; omnium scelerum atque veteris furoris m. in nostri consulatus tempus erupit; ejus rei nondum venit m.; ipsa oratio (mea jam) canescebat habebatque suam quandam m-em et quasi senectutem, C.; Crassi (oratoris) m. <text:span text:style-name="Fraktur">(torrhet, prosaiskhet),</text:span> T.<text:line-break/>II. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läglighet</text:span></text:span><text:span text:style-name="Fraktur"> (tiders):</text:span> temporum, C., L.<text:line-break/>III. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Skyndsamhet:</text:span></text:span> poenæ m-em precari, Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātūro</text:span>, 1.:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bringa till mognad;</text:span></text:span> <text:span text:style-name="T3">pass.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">mogna:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">om frukter:</text:span> annus uvas, Tib.; amygdala pomum, Pn.; uva m-ta dulcescit, C.; sole m-ri, Pn.; <text:span text:style-name="Fraktur">(intransit.,</text:span> Pall.)<text:line-break/>b. <text:span text:style-name="Fraktur">om sår, om med konst tillredda saker m. m.:</text:span> suppurationes m-at (decocta); mustum m-tum <text:span text:style-name="Fraktur">(utjäst),</text:span> Pn.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Göra i god tid, i förwäg; påskynda, skynda:</text:span></text:span><text:line-break/>a. <text:span text:style-name="T3">trans.</text:span>: multa, forent quæ post cælo properanda <text:span text:style-name="Fraktur">(göra i hast)</text:span> sereno, m-re licet <text:span text:style-name="Fraktur">(under regn),</text:span> Vg.; mortem m-re alicui, C., N.; m-ate fugam <text:span text:style-name="Fraktur">(skynden på flykten),</text:span> Vg.; m. insidias alicui, Sa.; coepta <text:span text:style-name="Fraktur">(skyndsamt werkställa);</text:span> censum Serv. Tullius m-verat lege de incensis lata, L.<text:line-break/>b. <text:span text:style-name="T3">intr.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Skynda:</text:span></text:span> oro, ut m-es venire, C.; Cæsar m-dum sibi existimavit; Cæsar m-at ab urbe proficisci, Cs.; m-antes veniunt; m-at iter facere, Sa.; dic, age, m-et <text:span text:style-name="Fraktur">(skyndar hit),</text:span> Hor.; m-to opus est, L. <text:line-break/><text:span text:style-name="T1">Mātūrāte</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Skyndsamt:</text:span></text:span> exire, Pt.; sequi, L.<text:line-break/><text:span text:style-name="T1">Mātūrātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Skyndande:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Admātūro</text:span>, 1.: horum discessu a-ri <text:span text:style-name="Fraktur">(bringas till utbrott, påskyndas)</text:span> defectionem civitatis existimabat, Cs.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ēmātūresco</text:span>, rui, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Blifwa fullmogen:</text:span></text:span> semen, Pn. - <text:span text:style-name="Fraktur">bildl.:</text:span> ira Cæsaris e-uit <text:span text:style-name="Fraktur">(förmildrats),</text:span> Ov.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Immātūrus</text:span>, <text:span text:style-name="T3">A.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Omogen:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> fructus, Pn.; herbæ, Col.; vomica, Pt. <text:line-break/>b. <text:span text:style-name="Fraktur">oeg.:</text:span> puella i-a <text:span text:style-name="Fraktur">(ej fullwuxen, ej manbar),</text:span> Su.; consilia i-a ante tempus præcipere, L.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Otidig,</text:span></text:span><text:span text:style-name="Fraktur"> s. är l. sker i otid:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> abi hinc cum i-o amore (sponsi); tempus ad navigandum i-um <text:span text:style-name="Fraktur">(otjenlig),</text:span> L. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">I förtid</text:span></text:span><text:span text:style-name="Fraktur"> (död); </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">i förtid inträffad</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">för tidig</text:span></text:span><text:span text:style-name="Fraktur"> (om döden):</text:span> tibi i-o vita erepta est, Sa.; filius i. obiit, Hor.; mors non potest esse i-a consulari; i-o C. Gracchi interitu damnum res Romanæ fecerunt, C.; mors i-a, Vg.; i-a licet, tamen huc non noxia veni (ad Orcum), Ppt.<text:line-break/><text:span text:style-name="T1">Immātūre</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">I otid:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">I förtid:</text:span></text:span> præfestinatum nimis i. opus, Col.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sent:</text:span></text:span> haud i-ius redito, Ap.<text:line-break/><text:span text:style-name="T1">Immātūrĭtas</text:span>, ātis, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Omogenhet:</text:span></text:span> sponsæ <text:span text:style-name="Fraktur">(för stora ungdom),</text:span> Su.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Brådska, förhastande:</text:span></text:span> quæ hæc i. tanta significat, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Permātūrus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wäl mogen:</text:span></text:span> Col. <text:line-break/><text:span text:style-name="T1">Permātūresco</text:span>, rui, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Blifwa wäl mogen, fullmogen:</text:span></text:span> pomum, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Præmātūrus</text:span>, <text:span text:style-name="T3">A.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Brådmogen, i förtid mogen:</text:span></text:span> fructus, Col.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">För tidig:</text:span></text:span> denuntiatio, C.; hiems; jam non p-a nec sæva mors videtur (Britannici), T. <text:line-break/><text:span text:style-name="T1">Præmātūre</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">I förtid, för tidigt:</text:span></text:span> Pt.; quum - quid factum est - festinantius, rectius id p. quam mature factum dicitur, Gell.</text:p>
   <text:p text:style-name="P1">Matus <text:span text:style-name="Fraktur">se</text:span> Mattus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ātūta, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">(wäl af samme stam s.</text:span> maturus): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Morgonen</text:span></text:span><text:span text:style-name="Fraktur"> personificerad = morgonens gudinna:</text:span> M. - Auroram differt et lumina pandit, Lucr.; mater M., L. - <text:span text:style-name="Fraktur">äfwen dyrkad ss. hafsgudinna, identificerad med gr. Ino (Leucothea) och moder till Portunus (Palæmon) hamnguden:</text:span> C., Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mātūtīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Morgon-; tidig</text:span></text:span><text:span text:style-name="Fraktur"> (= s. är tidigt uppe):</text:span> tempus, tempora, salutatio <text:span text:style-name="Fraktur">(uppwaktning),</text:span> C.; m-i volucrum sub culmine cantus; m-us se agebat <text:span text:style-name="Fraktur">(satte sig tidigt i rörelse),</text:span> Vg.; m-a frigora; m. pater (Janus), Hor.; umbra, Pn.<text:line-break/><text:span text:style-name="T1">Mātūtīnum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Morgon, morgonstund:</text:span></text:span> ante m-um; m-o; m-is, Pn.; eodem m-o, Qu.<text:line-break/><text:span text:style-name="T1">Mātūtīnālis</text:span>, <text:span text:style-name="T3">A.</text:span>: tempus, Auct. carm. Phil.</text:p>
   <text:p text:style-name="P1">Mavors, -vortius <text:span text:style-name="Fraktur">se</text:span> Mars.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>aurus, <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur">maurisk, Maurer, africanskt folkslagsn.; (poet. = africansk öfwerhufwud).</text:span> <text:line-break/>Maurĭcus, <text:span text:style-name="T3">A.</text:span> <text:line-break/>Maurĭce, <text:span text:style-name="T3">Adv.</text:span> <text:line-break/>Maurītānia <text:line-break/>(Maurētania), ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">Maurernes land, Mauritanien.</text:span><text:line-break/><text:span text:style-name="T2">M</text:span>aurūsĭus, <text:span text:style-name="T3">A.</text:span> = Mauricus. <text:line-break/>Maurūsĭa, ae, <text:span text:style-name="T3">f.</text:span> = Mauritania. </text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">M</text:span>ausōlus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">carisk konung.</text:span> <text:line-break/>Mausōlēum, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">Mausoli grafwård. - sås. appellat. = storartad grafwård (kejsare-, konungagraf; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T3">Mausoleum</text:span></text:span><text:span text:style-name="Fraktur">).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Maxilla,</text:span> ae <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Käk:</text:span></text:span><text:span text:style-name="Fraktur"> enl.</text:span> C. <text:span text:style-name="Fraktur">den ursprungliga formen af</text:span> māla, q. v.<text:line-break/><text:span text:style-name="T1">Maxillāris</text:span>, <text:span text:style-name="T3">A.</text:span>: dens, <text:span text:style-name="Fraktur">kindtand,</text:span> Pn.</text:p>
   <text:p text:style-name="P1">Maxim . . . <text:span text:style-name="Fraktur">se</text:span> Magnus.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>azăca, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">hufwudstad i Cappadocien.</text:span><text:line-break/><text:span text:style-name="T2">M</text:span>azăces, um, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">numidiskt folk.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>azāgæ, ārum, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Indien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mazŏnŏmus,</text:span> i, <text:span text:style-name="T3">m.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Fat:</text:span></text:span> m-o pueri magno - ferentes membra gruis, Hor.</text:p>
   <text:p text:style-name="P1">Meabilis, Meatus <text:span text:style-name="Fraktur">se</text:span> Meo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mēchănĭcus,</text:span> <text:span text:style-name="T3">A.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mechanisk:</text:span></text:span> simulacrum disciplinā m-a factum, Gell. <text:line-break/><text:span text:style-name="T1">Mēchănicus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mechaniker:</text:span></text:span> Su. <text:line-break/><text:span text:style-name="T1">Mēchănĭcōs</text:span>, <text:span text:style-name="T3">Adv.</text:span>: (fig. gr.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mēcon,</text:span> ōnis, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">wild wallmon:</text:span> Pn.<text:line-break/><text:span text:style-name="T1">Mēcōnĭum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">-saft:</text:span> id.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Meddix</text:span> <text:line-break/>(medix), <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">(st. i</text:span> medeor?; <text:span text:style-name="Fraktur">jfr Curtius, Gr. Etym.): oskiskt ord, motsw. lat.</text:span> consul (magister populi): m. tuticus (= populi, publicus) est summus magistratus (annuus) apud Campanos, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ēdēa, ae, <text:span text:style-name="T3">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur">mythol. personnamn.</text:span> <text:line-break/>Mēdēis, ĭdis, <text:span text:style-name="T3">A. f.</text:span> = <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Trollsk:</text:span></text:span> Ov.</text:p>
   <text:p text:style-name="P1">Medela, -della <text:span text:style-name="Fraktur">se</text:span> Medeor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mĕdeor,</text:span> ēri: <text:span text:style-name="T3">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bota</text:span></text:span> (<text:span text:style-name="T3">alicui rei</text:span>; raro: <text:span text:style-name="T3">rem</text:span>):<text:line-break/>a. <text:span text:style-name="Fraktur">kroppsligen: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läka, bota, skänka bot, hjelpa:</text:span></text:span> alicui; oculis; capiti <text:span text:style-name="Fraktur">(lif);</text:span> vulneribus; morbo, C.; scire usum m-di, Vg.; id contra ictus m-etur, Pn.<text:line-break/>b. <text:span text:style-name="Fraktur">i andra hänseenden: så wäl </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bota, hjelpa, hjelpa till rätta</text:span></text:span><text:span text:style-name="Fraktur"> den lidande, som </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">afhjelpa, förmildra, förekomma</text:span></text:span><text:span text:style-name="Fraktur"> det onda:</text:span> reipublicæ; religioni; dies stultis m-etur; incommodis hominum m., C.; inopiæ frumentariæ, Cs.; fraternæ invidiæ <text:span text:style-name="Fraktur">(owiljan mot sin broder),</text:span> Sa.; satietati et ignorantiæ lectoris, N.; periculis, T. - <text:span text:style-name="Fraktur">med</text:span> <text:span text:style-name="T3">acc.</text:span>: cupiditates paulo, Ter.; <text:span text:style-name="Fraktur">derför ock:</text:span> corporibus m-dis animi multo prius imperatoribus reconciliabantur, L. (VIII. 36.) - <text:span text:style-name="Fraktur">i passiv betyd. impers. med dat.,</text:span> Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdella</text:span> <text:line-break/>(Mĕdēla), ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bot, läkedom, läkemedel:</text:span></text:span> facere m-am <text:span text:style-name="Fraktur">(bota),</text:span> Gell.; adhibere m-am, Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭcus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Botande, läkande; läke-, läkare-:</text:span></text:span> manus m-as adhibere, Vg.; ars, Ov., Tib.; vis, Pn.; laborum dulce lenimen m-umque, Hor. I. 32. 14. 15. <text:span text:style-name="Fraktur">Lachm.;</text:span> m. digitus <text:span text:style-name="Fraktur">l. absol.</text:span> m. (i. e. <text:span text:style-name="Fraktur">ringfingret),</text:span> C., Pn. (medicinalis, Mcb.)<text:line-break/><text:soft-page-break/><text:span text:style-name="T1">Mĕdĭcus</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkare:</text:span></text:span> m-um adducere, adhibere <text:span text:style-name="Fraktur">(tillkalla);</text:span> m-i leviter ægrotantes leniter curant, gravioribus morbis - curationes ancipites (adhibent); m. optimus et nobilissimus quæritur; m-i mali in aliis scientiam profitentur, ipsi se curare non possunt; m-o mercedem promittere, C.; celer et fidelis; fidus; m-i egere; quod m-orum est, promittunt m-i, Hor.; m. arte insignis - regit valetudines principis -, consilii copiam præbet, T. <text:line-break/><text:span text:style-name="T1">Mĕdĭca</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭcīnus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkare-:</text:span></text:span> ars, Varr. <text:line-break/><text:span text:style-name="T1">Medĭcīna</text:span>, ae, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkekonst, läkarekonst:</text:span></text:span> m-am exercere; eæ artes, quibus major prudentia inest, ut m., ut architectura; m. est ars valetudinis; est animi m. philosophia, C.; m-am profiteri, Su.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkares biträde; läkedom, bot, botemedel, hjelp:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">mot kroppslig sjukdom l. olägenhet:</text:span> a medico petere m-am; sine medico m-am dat Minerva; desperatis adhibere m-am, C.; Atticus annis XXX m-ā non indiguerat, N.; facere alicui m-am <text:span text:style-name="Fraktur">(bota, curera),</text:span> Phdr.; principiis obsta: sero m. paratur, Ps.<text:line-break/>b. <text:span text:style-name="Fraktur">för andra lidanden:</text:span> m-am temporis <text:span text:style-name="Fraktur">(af tiden)</text:span> exspectare; reipublicæ adhibere m-am; consilii m-am afferre; non egeo m-ā (doloris), me ipse consolor; his causis (invidiæ popularis) totidem m-æ opponuntur, C.; m. furoris (ɔ: amoris), Vg.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkarestuga:</text:span></text:span> (quæritare alqm) in m-is, in tonstrinis, apud omnes ædes sacras, Pt.<text:line-break/><text:span text:style-name="T1">Medĭcīnālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">s. anwändes af läkare och i läkarekonsten (medicinal):</text:span> herba, Pn.; digitus (se medicus, <text:span text:style-name="T3">A.</text:span>), Mcb.; ars, Ce.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭco</text:span>, 1.:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läka:</text:span></text:span> alqd, Col., Sil. <text:line-break/>2. <text:span text:style-name="Fraktur">(göra läkande, tillreda läkemedel) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Till-, uppblanda, tillreda, tillaga, bestryka, dränka</text:span></text:span><text:span text:style-name="Fraktur"> med l. i </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">läkande</text:span></text:span><text:span text:style-name="Fraktur"> medel, öfwerhufwud med ngt, som förändrar sakens utseende l. physicaliska egenskaper eller s. har en wiß werkan; deraf = färga, förgifta, (dränka) krydda:</text:span> (caulis) amnem (= aquam fluvialem) inficit occulte m-ans <text:span text:style-name="Fraktur">(uppblandande l. gifwande det läkekraft),</text:span> Vg.; semina suco sedi m-re <text:span text:style-name="Fraktur">(inlägga, uppmjuka i),</text:span> Col., Vg.; m-re capillos, Ov. - <text:span text:style-name="Fraktur">i synnerhet i</text:span> <text:span text:style-name="T3">part. pf.</text:span><text:line-break/><text:span text:style-name="T1">Mĕdĭcātus</text:span>, <text:span text:style-name="T3">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tillredd, blandad, kryddad, bestruken, -stänkt, färgad;</text:span></text:span><text:span text:style-name="Fraktur"> till sin werkan: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">läkande</text:span></text:span><text:span text:style-name="Fraktur"> (s. eger läkande kraft); </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">söfwande, giftig, förtrollande; troll-:</text:span></text:span> veneno m-us, Sil.; apes considunt m-is sedibus (aspersis saporibus), Vg.; lana fuco m-a, Hor.; vina, Col.; odor saporque lacus m-us <text:span text:style-name="Fraktur">(mineralhaltig),</text:span> Pn. ep.; fons m. <text:span text:style-name="Fraktur">(helso-),</text:span> Pn.; res m-ior, m-sima, Pn.; potio m-a, Ct.; offa m-is frugibus (Cerbero objicitur), Vg.; boletus m-us (Claudio offertur), Su.; virga m-a (Mercurii), Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭcor</text:span>, 1.: <text:span text:style-name="T3">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bota:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">kroppsl.:</text:span> senibus anhelis (plantā), Vg.; cuspidis ictum, Vg.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bota, hjelpa:</text:span></text:span> metum, Pt.; in hac re possum m-ri mihi, Ter.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭcābĭlis</text:span>, <text:span text:style-name="T3">A.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Botlig:</text:span></text:span> vulnus, Sil., amor, Ov.<text:line-break/><text:soft-page-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Helsosam,</text:span></text:span><text:span text:style-name="Fraktur"> s. har helande kraft:</text:span> sucus (tamaricis), Col. <text:line-break/><text:span text:style-name="T1">Mĕdĭcābŭlum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkemedel:</text:span></text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭcāmen</text:span>, ĭnis <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Mĕdĭcāmentum</text:span>, i, <text:span text:style-name="T3">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkemedel; skyddande medel:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i eg. men.:</text:span> curari - m-bus vinolentis; m-tum dare ad aquam intercutem; uti m-to; salutaria m-ta, C.; sumere m-ta <text:span text:style-name="Fraktur">(intaga),</text:span> Ct.; salubre m-tum, L.; pater ora nati sacro m-ne <text:span text:style-name="Fraktur">(salfwa)</text:span> contigit et - fecit patientia flammæ, Ov.; ulcerosa facies et - m-tis <text:span text:style-name="Fraktur">(plåsterlappar)</text:span> interstincta, T.<text:line-break/>b. <text:span text:style-name="Fraktur">oeg.:</text:span> doloris m-tum <text:span text:style-name="Fraktur">(ord - mot smärta);</text:span> laborum, C.<text:line-break/>2. <text:span text:style-name="Fraktur">i allm. ämne, s. förändrar en saks utseende l. physiska beskaffenhet, ss.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Färg, smink, krydda; gift; trollmedel, -dryck:</text:span></text:span> lanam m-tis sufficere; fucati ruboris m-ta, C.; m-na formæ (faciei), Ov.; vini, Cato; partum m-tis abigere, C.; malum m-tum, Sen.; bibere m-tum, Ct.; vis m-nis non statim intellecta, T.; amatorium m-tum, Su.; maximus ævo (aries) agnus m-ne (Medeæ) fiet, Ov.<text:line-break/><text:span text:style-name="T1">Mĕdĭcāmentārius</text:span>, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Apothekare:</text:span></text:span> Pn. - <text:span text:style-name="Fraktur">giftblandare:</text:span> Jct.<text:line-break/><text:span text:style-name="T1">Mĕdĭcāmentāria</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">apothekarekonst:</text:span> Pn.<text:line-break/><text:span text:style-name="T1">Mĕdĭcāmentōsus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">tjenlig ss. läkemedel; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Helso-:</text:span></text:span> aqua, Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭcātio</text:span>, ōnis <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Kryddande</text:span></text:span><text:span text:style-name="Fraktur"> med, dränkande i ett ämne:</text:span> seminis radice silphii trita cum aceto, Col.<text:line-break/><text:span text:style-name="T1">Mĕdĭcātus</text:span>, us, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Trollmedel:</text:span></text:span> Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdĭtrīna, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">helsans gudinna.</text:span> <text:line-break/>Mĕdĭtrīnālia, ium, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">hennes festdag.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Immĕdĭcābĭlis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Obotlig:</text:span></text:span> Vg., Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Immĕdĭcātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Osminkad:</text:span></text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Præmĕdĭcātus</text:span>, <text:span text:style-name="T3">A.</text:span>: isset anhelatos non p. <text:span text:style-name="Fraktur">(bestruken med skyddande salfwa)</text:span> in ignes (Iaso), Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Rĕmĕdium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Läkemedel, botemedel:</text:span></text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">kroppsligt:</text:span> salutare; acre; (morbo) r-a invenire; uti r-o, C.; lene r., L.; morbo celeria ac facilia r-a proponere, N.; præsens r.; r. morborum; vulneri adhibere r-a; id in r-o est, Pn.; r. efficax, Ce. <text:line-break/>b. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bote-, lindringsmedel, medel</text:span></text:span><text:span text:style-name="Fraktur"> mot ngt; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">bot, hjelp</text:span></text:span><text:span text:style-name="Fraktur"> (tröst):</text:span> r. quærere, invenire, comparare rei, ad rem; r. incommodorum; hoc est incommodis r.; in adversis rebus sine ullo r-o - permanere, C.; r-a dare, reperire malis, Cs.; miseriis r. exspectare, Sa.; (his temporibus) nec vitia nostra neque r-a pati possumus; id r. timori fuit, L.; naturā infirmitatis humanæ r-a tardiora sunt, quam mala, T.<text:line-break/><text:span text:style-name="T1">Rĕmĕdiālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">botande:</text:span> vis, Mcb.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Rĕmĕdio</text:span>,<text:line-break/><text:span text:style-name="T1">Rĕmĕdior</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Bota:</text:span></text:span> alqm, Scrib., Ap.<text:line-break/><text:span text:style-name="T1">Rĕmĕdiābĭlis</text:span>, <text:span text:style-name="T3">A.</text:span> = remedialis: Cass.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Irrĕmĕdiābĭlis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Obotlig, ohjelplig:</text:span></text:span> scelus, Pn.; factio tyranni <text:span text:style-name="Fraktur">(oundkomlig),</text:span> Mæc. ap. Sen.</text:p>
   <text:p text:style-name="P1">Medi, Media <text:span text:style-name="Fraktur">se</text:span> Medus.<text:line-break/>Medianus <text:span text:style-name="Fraktur">se</text:span> Medius.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">Mĕdiastīnus,</text:span> <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">(af</text:span> medius?): <text:span text:style-name="Fraktur">simpel </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Slaf</text:span></text:span><text:span text:style-name="Fraktur"> utan bestämd syssla; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">arbetshjon:</text:span></text:span> Hor., Cato.</text:p>
   <text:p text:style-name="P1">Mediator <text:span text:style-name="Fraktur">se</text:span> Medio, Medius.<text:line-break/>Mĕdic . . . <text:span text:style-name="Fraktur">se</text:span> Medeor.<text:line-break/>Mēdicus <text:span text:style-name="Fraktur">se</text:span> Medus.<text:line-break/>Medie, -dietas <text:span text:style-name="Fraktur">se</text:span> Medius.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mĕdimnus,</text:span> i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Mĕdimnum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">mått för säd och andra torra waror (ungf. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">halftuuna):</text:span></text:span> m-um tritici seritur in jugero; decuma XXXVI m-ûm (<text:span text:style-name="T3">gen. pl.</text:span>), C.; is modus mensuræ m-us Athenis appellatur, N.</text:p>
   <text:p text:style-name="P1">Medio, Mediocr . . . <text:span text:style-name="Fraktur">se</text:span> Medius.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdiōlānum, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">stadsn., Milano.</text:span> <text:line-break/><text:span text:style-name="T1">Mĕdiōlānensis</text:span>, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdiōmatrĭci, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">germ. folk.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdĭon, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Acarnanien.</text:span> <text:line-break/>Mĕdĭōnĭus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1">Medioximus <text:span text:style-name="Fraktur">se</text:span> Medius.<text:line-break/>Meditabundus, Meditam . . ., Meditat . . . <text:span text:style-name="Fraktur">se</text:span> Meditor. <text:line-break/>Mediterraneus <text:span text:style-name="Fraktur">se</text:span> Medius.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mĕdĭtor,</text:span> 1.: <text:span text:style-name="T3">Dep.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Öfwa</text:span></text:span><text:span text:style-name="Fraktur"> sig i, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">förbereda</text:span></text:span><text:span text:style-name="Fraktur"> sig till ngt; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">studera, inöfwa; tänka</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">sätta</text:span></text:span><text:span text:style-name="Fraktur"> sig in i ngt; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">instudera, betänka</text:span></text:span><text:span text:style-name="Fraktur"> sig (med</text:span> <text:span text:style-name="T3">acc.</text:span> <text:span text:style-name="Fraktur">l. med</text:span> <text:span text:style-name="T3">inf.</text:span>):<text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> Demosthenes perfecit m-do, ut nemo planius locutus esse videretur; Cæsar multos annos regnare m-tus erat; imprimis illud m-emur, ut patientia æquabilem se præbeat; alqd exercitatione ludicra prædiscere et m.; hæc multo ante m-re, C.; m-ans in proelia taurus; Musam silvestrem tenui avenā, Vg.; m-or esse affabilis, et bene procedit; m., quo pacto ferat ærumnam, Ter.; artem citharoedicam, Su.<text:line-break/>b. <text:span text:style-name="Fraktur">sersk.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T3">Meditera,</text:span></text:span><text:span text:style-name="Fraktur"> </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">öfwertänka, instudera,</text:span></text:span><text:span text:style-name="Fraktur"> (upptänka, sätta sig in i, öfwerläsa) ngt, som skall föredragas:</text:span> quum causam sit acturus, in itinere secum m-ri; Græci testes non jurisjurandi, sed lædendi verba m-antur; causam; accusationem; ad sententiam alicujus m. <text:span text:style-name="Fraktur">(förbereda sig på ett swar på -, på att bemöta);</text:span> m-bor, quo pacto loquar, C.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Tänka på</text:span></text:span><text:span text:style-name="Fraktur"> = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">påtänka, grunda ut, upptänka</text:span></text:span><text:span text:style-name="Fraktur"> (ngt, s. skall göras); </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">hafwa i sinnet, i tankarne</text:span></text:span><text:span text:style-name="Fraktur"> (åsyfta, anstifta; med</text:span> <text:span text:style-name="T3">obj. acc.</text:span> <text:span text:style-name="Fraktur">och med</text:span> <text:span text:style-name="T3">inf.</text:span>): fugam; poenam novam in fratrem Atreus; ne semper forum, subsellia, rostra curiamque m-ere <text:span text:style-name="Fraktur">(för att ej alltid hafwa - i tankarna),</text:span> C.; quum m-retur proficisci -, N.; Dido non m-atur furtivum amorem; insidias, dolum alicui, Vg.; obliquum ictum verres m-atur <text:span text:style-name="Fraktur">(tillärnar, ”är färdig till”);</text:span> nescio quid m-ans nugarum; non m-or te poculis tingere immunem, Hor.; edictum, Su. - <text:span text:style-name="T3">part.</text:span> <text:line-break/><text:span text:style-name="T1">Mĕdĭtātus</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">s. har förberedt sig, mediterat; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förberedd:</text:span></text:span> ad causam venire m-um, C.<text:line-break/>2. <text:span text:style-name="T3">pass.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur">som man förberedt sig på, tänkt sig in i: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Genom-, öfwertänkt; </text:span></text:span><text:soft-page-break/><text:span text:style-name="Fraktur"><text:span text:style-name="T2">beräknad</text:span></text:span><text:span text:style-name="Fraktur"> för ngt:</text:span> sint omnia homini humana m-a; accuratæ et m-æ commentationes, C.; m-a mihi sunt omnia, Ter.; ad hujus vitæ studium m-i sunt labores tui, C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Öfwerlagd, afsigtlig:</text:span></text:span> injuriæ; scelus, C.; consilium, T.<text:line-break/><text:span text:style-name="T1">Mĕdĭtāte</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Instuderadt, wäl, skickligt:</text:span></text:span> mores alicujus m. tenere, Pt.; pueros quidam mercantur, qui probra m. effundant, Sen. <text:line-break/><text:span text:style-name="T1">Mĕdĭtābundus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">som tänker, är betänkt på ngt:</text:span> bellum, Js.<text:line-break/><text:span text:style-name="T1">Mĕdĭtāmen</text:span>, ĭnis, <text:span text:style-name="T3">n.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:line-break/><text:span text:style-name="T1">Mĕdĭtāmentum</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förberedelse; förstudium:</text:span></text:span> belli, Sil., T.; tempora verborum et puerilia m-ta ignorare, Gell.<text:line-break/><text:span text:style-name="T1">Mĕdĭtātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Studium, förstudier, förberedelse, öfning;</text:span></text:span><text:span text:style-name="Fraktur"> bemödande att sätta sig in i l. göra sig förtrogen med:</text:span> m-e et exercitatione tollere vitium naturæ; locos commentatione et m-e paratos habere; cura et m. muneris obeundi; stultam futuri mali m-em (censet Epicurus), C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Öfwertänkande af</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">förberedelse</text:span></text:span><text:span text:style-name="Fraktur"> till, meditation af ett föredrag:</text:span> nulla m-is (in Antonio) suspicio, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Commĕdĭtor</text:span>, 1.: <text:span text:style-name="T3">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Grundligt studera:</text:span></text:span> locos, C. - carbasus perscissa furit petulantibus auris et fragiles sonitus chartarum c-atur, Lucr. VI. 112 <text:span text:style-name="Fraktur">(Munro; der man fattat det</text:span> = imitari).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Immĕdĭtātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Oöfwerlagd, okonstlad:</text:span></text:span> Ap.<text:line-break/><text:span text:style-name="T1">Immĕdĭtāte</text:span>, <text:span text:style-name="T3">Adv.</text:span>: Gell.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Permĕdĭtātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Wäl inöfwad;</text:span></text:span><text:span text:style-name="Fraktur"> som wäl studerat sin roll:</text:span> Pt. Ep. III. 2. 39 (inc. l.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Præmĕdĭtor</text:span>, 1.: <text:span text:style-name="T3">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förbereda sig; på förhand göra sig klart; betänka, öfwertänka:</text:span></text:span> quo animo accedam; alqd modice ferendum esse, C. - <text:span text:style-name="T3">part. pf.</text:span>: mala p-ta <text:span text:style-name="Fraktur">(s. man beredt sig på)</text:span> fiunt leviora, C.; nihil p-ti (ad dicendum) afferre, Qu. <text:line-break/><text:span text:style-name="T1">Præmĕdĭtātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Beredelse på:</text:span></text:span> futurorum malorum, C.</text:p>
   <text:p text:style-name="P1">Meditrina <text:span text:style-name="Fraktur">se</text:span> Medeor.<text:line-break/>Meditullium, Medium <text:span text:style-name="Fraktur">se</text:span> Medius.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mĕdius,</text:span> <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mellerst,</text:span></text:span><text:span text:style-name="Fraktur"> s. är i midten, midt emellan, s. utgör midten af -:</text:span><text:line-break/>I. <text:span text:style-name="Fraktur">eg.; ofta att öfwersätta: det mellersta, midten af, l. med adv.: midt, och med præp.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i rum:</text:span> m-us mundi locus; Ianus m., C.; m-am amplecti aliquam <text:span text:style-name="Fraktur">(om midjan),</text:span> Ter.; locum m-um utriusque <text:span text:style-name="Fraktur">(midt emellan härarne)</text:span> colloquio deligere; m-a acies; in m-o colle <text:span text:style-name="Fraktur">(på midten af l. midt på kullen),</text:span> Cs.; ex m-o monte; cohortem m-os in hostes inducere <text:span text:style-name="Fraktur">(midt in ibland),</text:span> Sa.; sensit m-os delapsus in hostes; regina se m-am locavit; lucus in urbe fuit m-ā, Vg.; m-is in undis; m-um dividere alqm <text:span text:style-name="Fraktur">(hugga midt af)</text:span> securi, Hor.; m. digitus, Pn.; <text:span text:style-name="Fraktur">bildl.:</text:span> in m-as res rapit auditorem (Homerus), Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">i tid l. handling:</text:span> tempus proximum, m-um, ultimum, C.; m-a nox <text:span text:style-name="Fraktur">(midnatt),</text:span> Cs.; m. dies, Col.; m-a ætas <text:span text:style-name="Fraktur">(medelåldren);</text:span> duorum fratrum ætatibus m. interjectus; mulier in m-a potione exclamavit se mori, C.; in m-o honore deûm <text:span text:style-name="Fraktur">(midt under);</text:span> incipit effari m-āque in voce resistit, Vg.; in m-os dies dormire; chorus m-os actus intercinit; primo ne m-um, m-o ne discrepet imum <text:span text:style-name="Fraktur">(i en dikt),</text:span> Hor.<text:line-break/><text:soft-page-break/>c. medius <text:span text:style-name="Fraktur">(= middags-),</text:span> Varr.; m-um occidit sidus <text:span text:style-name="Fraktur">(midt på dagen),</text:span> Col. <text:line-break/>d. = <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Half:</text:span></text:span> m-ā plus parte erectus in auras (serpens), Ov.; aurum totum Italicis, m-um provincialibus reddidit, Cap.<text:line-break/>II. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">till beskaffenhet, ställning, tänkesätt, wärde m. m.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.: s. står midt emellan (motsatser); af mellanslag:</text:span> inter pacem et bellum nihil m-um est; oratores grandes, tenues, m-i, C.; via consilii m-a <text:span text:style-name="Fraktur">(medelwäg);</text:span> m-um erat in Anco ingenium, et Romuli et Numæ memor, L.; Galbæ m-um ingenium, magis extra vitia, quam cum virtutibus, T.; pacis et belli m. <text:span text:style-name="Fraktur">(färdig till både -),</text:span> Hor.<text:line-break/>b. <text:span text:style-name="Fraktur">om person: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Opartisk, likgiltig</text:span></text:span><text:span text:style-name="Fraktur"> (neutral, indifferent), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">obestämd; jemkande:</text:span></text:span> non licet nos esse m-os, C.; pacem utrique parti, ut decet m-os amicos, optant; m-um se gerendo nec plebis vitavit odium nec apud patres gratiam iniit, L.; m-i plurimi <text:span text:style-name="Fraktur">(s. hwarken warit för l. emot),</text:span> T.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Måttlig, sansad:</text:span></text:span> libertas; oratio, L.<text:line-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Twetydig,</text:span></text:span><text:span text:style-name="Fraktur"> (indifferent), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">obestämd:</text:span></text:span> responsum, L.; artes; vocabulum (μέσον), Qu.; m-a <text:span text:style-name="Fraktur">i sedl. hänsigt = likgiltiga ting</text:span> (ἀδιάφορα), C.<text:line-break/>e. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Medelmåttig, wanlig</text:span></text:span><text:span text:style-name="Fraktur"> (ordinär), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">half:</text:span></text:span> m-a officia <text:span text:style-name="Fraktur">(mots.</text:span> perfecta), C.; nihil m-um, nec spem nec curam, volvebant animo; bella m-a <text:span text:style-name="Fraktur">(i mots. till det galliska);</text:span> imperatores m-i, L.<text:line-break/>2. <text:span text:style-name="Fraktur">i uttr. för ett förhållande emellan twenne:</text:span> hos inter m-os venit furor, Vg.<text:line-break/><text:span text:style-name="Fraktur">ss. subst. (wanl. i fören. med præp.):</text:span><text:line-break/><text:span text:style-name="T1">Mĕdium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Midt,</text:span></text:span><text:span text:style-name="Fraktur"> (rum, rymd emellan -):</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i egentl. men.:</text:span> omnes partes (sphæræ) in m-um vergunt: m-um autem in sphæra infimum est, C.; ager in m-o arenosus, Sa.; m-o ædium (senes) eburneis sellis sedēre; Ligures in m-o positi; procedere in m-um campi; jam diei m. erat, L.; m-o tutissimus ibis, Ov.; in m-o solis et terræ, Pn.; m-um cæli nox tenebat, Hor.; scillæ m. <text:span text:style-name="Fraktur">(det mellersta af -),</text:span> Varr.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Medelwäg; medelmåtta:</text:span></text:span> virtus est m. vitiorum et utrinque reductum; certis m-um ac tolerabile rebus recte concedi, mediocribus esse poētis non dii, non homines - concessere, Hor.<text:line-break/>b. in m-o, in m-um, e, de m-o <text:span text:style-name="Fraktur">i uttryck för det allom synliga l. tillgängliga, offentliga, wanliga, hwardagliga, gemensamma:</text:span> tabulæ <text:span text:style-name="Fraktur">(handlingarna i målet)</text:span> sunt in m-o <text:span text:style-name="Fraktur">(framför oß),</text:span> C.; in m-um venire, procedere <text:span text:style-name="Fraktur">(komma fram);</text:span> in m-um vocari <text:span text:style-name="Fraktur">(kallas fram, för rätten);</text:span> proferre in m-um <text:span text:style-name="Fraktur">(framdraga, bekantgöra);</text:span> recedere de m-o <text:span text:style-name="Fraktur">(träda tillbaka från ett uppdrag);</text:span> verba tollere de m-o <text:span text:style-name="Fraktur">(upptaga);</text:span> de m-o pellere <text:span text:style-name="Fraktur">(aflägsna);</text:span> de m-o tollere, <text:span text:style-name="Fraktur">rödja ur wägen (aflägsna l. döda),</text:span> C., Cs.; alqd sumere de m-o <text:span text:style-name="Fraktur">(från det hwardagligas område),</text:span> C.; transvolare in m-o posita <text:span text:style-name="Fraktur">(för fötterne eller ögonen);</text:span> tantum de m-o sumptis <text:span text:style-name="Fraktur">(hwardaglig)</text:span> accessit honoris; comoedia ex m-o res arcessit <text:span text:style-name="Fraktur">(hemtar sina ämnen från hwardagslifwet),</text:span> Hor.; communes utilitates in m-um afferre <text:span text:style-name="Fraktur">(till det allmännas tjenst),</text:span> C.; in m-um conferre, in m-um consulere <text:span text:style-name="Fraktur">(för det helas bästa),</text:span> L., Vg.; in m-um quærere, Vg.; <text:soft-page-break/>in m-um cedere, T.<text:line-break/>c. in m-o relinquere, <text:span text:style-name="Fraktur">lemna oafgjordt,</text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdiānus</text:span>, <text:span text:style-name="T3">A.</text:span>: testudo <text:span text:style-name="Fraktur">(midskepp i byggnad),</text:span> Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdie</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur">midt emellan, medelmåttigt:</text:span> Eutr., Ap.<text:line-break/><text:span text:style-name="T1">Mĕdiĕtas</text:span>, ātis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Midt:</text:span></text:span> vix audeo dicere m-es, quas Græci μεσότητας, C. - <text:span text:style-name="Fraktur">hälft:</text:span> Pall. - <text:span text:style-name="Fraktur">medelwäg:</text:span> Jct.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdio</text:span>, 1.: <text:span text:style-name="Fraktur">dela midt itu:</text:span> Apic. <text:line-break/><text:span text:style-name="T1">Mĕdiātor</text:span>, ōris, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Medlare:</text:span></text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdiŏcris</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Medelmåttig, wanlig</text:span></text:span><text:span text:style-name="Fraktur"> (oftast = obetydlig, simpel, ringa):</text:span> homo, Ter.; orator; non m-es viri, sed maximi; res summæ, minimæ, m-es; si in m-i statu sermonis ac prædicationis res nostræ essent, nihil a te postularetur eximium; non m-e munus; non m-es artes, sed pæne maximæ; non m-e telum ad res gerendas existimare oportet benevolentiam civium, C.; m-e castellum; non m. animus (ɔ: <text:span text:style-name="Fraktur">stolt, ärelysten),</text:span> Sa.; spatium; copiæ, Cs.; industria non m.; m. statura, N.; m-bus esse poētis (non licet), Hor.<text:line-break/><text:span text:style-name="T1">Mĕdiŏcrĭcŭlus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: Cato.<text:line-break/><text:span text:style-name="T1">Mĕdiŏcrĭtas</text:span>, ātis, <text:span text:style-name="T3">f.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Medelmåtta, -tighet; obetydlighet, ringhet:</text:span></text:span> m. virtutum, dicendi; m. ingenii; mea gestus m., C.; nostra m., Vell.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Måtta, lagom:</text:span></text:span> m-em tenere, quæ est inter nimium et parum; m-is regula optima est; rem m-e moderari, C.; auream diligere m-em, Hor.<text:line-break/><text:span text:style-name="T1">Mĕdiŏcrĭter</text:span>, <text:span text:style-name="T3">Adv.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Medelmåttigt</text:span></text:span><text:span text:style-name="Fraktur"> (obetydligt, icke just l. serdeles):</text:span> m. delectare; m. literatus, C.; non m., Cs.; rerum m. utilium spes, Hor.; doctus, Pn.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Lagom, med måtta, sans:</text:span></text:span> omnia m., Ter.; ferre alqd m. <text:span text:style-name="Fraktur">(med lugn, sås. en småsak);</text:span> hoc vellem m-ius (faceret): cetera egregia, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Permĕdiŏcris</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mycket måttlig</text:span></text:span><text:span text:style-name="Fraktur">(lugn):</text:span> motus animi p-es vel potius leves esse debent, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdioxĭmus</text:span>, <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">(superl., archaist.): </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mellerst:</text:span></text:span> uxor m-a <text:span text:style-name="Fraktur">(till tiden),</text:span> Pt.; dii m-i <text:span text:style-name="Fraktur">(till rum l. rang),</text:span> Pt., Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭterrāneus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Midt</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">inne i landet</text:span></text:span><text:span text:style-name="Fraktur"> (i motsats till kusten) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">belägen</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">boende:</text:span></text:span> urbs; homines, C.; regio, Cs.; locus, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕdĭtullium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur">(förmodl. bildadt liks. med en grekisk deminutivändelse): </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Midt, medelpunkt:</text:span></text:span> C., Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕrīdies</text:span>, ēi, <text:span text:style-name="T3">m.</text:span>: (= medi-dies; meridies ab eo, quod medius dies; D antiqui, non R in hoc dicebant, ut Præneste incisum in solario vidi, Varr. l. l. V. 4; meridies cur non medidies? credo, quod erat insuavius, C. Or. §. 157; <text:span text:style-name="Fraktur">jfr</text:span> Qu. I. 6. 30): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Middag:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> circiter m-em, Pt.; m-e ipso, Ter.; ante m-em paulum quiescere, C.; inclinare m-em sentis, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Söder:</text:span></text:span> versus ad m-em, C.; villa magna sui parte m-em spectat, Pn.<text:line-break/><text:span text:style-name="T1">Mĕrīdiālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sydlig:</text:span></text:span> Gell., Amm.<text:line-break/><text:span text:style-name="T1">Mĕrīdiānus</text:span>, <text:span text:style-name="T3">A.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Middags-,</text:span></text:span><text:span text:style-name="Fraktur"> som är midt på dagen:</text:span> tempus m-um in acerrima cogitatione posuit Crassus, C.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sydlig:</text:span></text:span> Varr., Pn.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Mĕrīdio</text:span> <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T1">Mĕrīdior</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sofwa middag:</text:span></text:span> Su., Ce.<text:line-break/><text:span text:style-name="T1">Mĕrīdiātio</text:span>, ōnis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Middagssömn:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Mĕrīdiōnālis</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Sydlig:</text:span></text:span> Fm.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Antĕmĕrīdiānus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Förmiddags-:</text:span></text:span> non est paucorum libellorum hoc munus neque Tusculani aut hujus ambulationis a-æ aut nostræ pomeridianæ sessionis, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Postmĕrīdiānus</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T1">Pōmĕrīdiānus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Eftermidags-:</text:span></text:span> pomeridianas quadrigas, quam postmeridianas libentius dixerim; inclinante in p-um tempus die; sessio, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Dīmĭdius</text:span>, <text:span text:style-name="T3">A.</text:span>: (dis <text:span text:style-name="Fraktur">och</text:span> medius): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Half,</text:span></text:span><text:span text:style-name="Fraktur"> isynn. i uttrycket</text:span> d-a pars = <text:span text:style-name="Fraktur">hälft (jfr</text:span> dimidiatus): heres ex parte d-a; luna major, quam d-a pars terræ; d-æ partes frumenti veneunt, C.; rex d-æ partis Eburonum, Cs.; d. modius, L.; confecerat d-um fere spatium, N.; operæ <text:span text:style-name="Fraktur">(dagswerken)</text:span> sex et d-a, Col.; Curii (ɔ: Curiorum statuæ) jam d-i <text:span text:style-name="Fraktur">(blott halfwa = stympade),</text:span> Juv.<text:line-break/><text:span text:style-name="T1">Dīmĭdium</text:span>, i, <text:span text:style-name="T3">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Hälften:</text:span></text:span> dixit se d-um ejus rei, quod pactus esset, daturum esse; d-o plus <text:span text:style-name="Fraktur">(en half gång till så mycket);</text:span> d-o stultior; d-o carius emere; d-o minoris constare, C.; serves animæ d-um meæ; d-um facti, qui coepit, habet: sapere aude, Hor.<text:line-break/><text:span text:style-name="T1">Dīmĭdiātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur">delad midt itu, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">Half</text:span></text:span><text:span text:style-name="Fraktur"> (enl.</text:span> Varr. <text:span text:style-name="Fraktur">och</text:span> Gell. <text:span text:style-name="Fraktur">skulle</text:span> d-tus <text:span text:style-name="Fraktur">sägas om det hela, s. är tudeladt,</text:span> dimidius <text:span text:style-name="Fraktur">om delen,</text:span> quæ ex d-o pars altera est): digitus d., Cato; vas vini d-um, Enn.; porcus d., Lucil.: mensis unus d-usque; plus d-i mensis cibaria; exesis partibus versiculorum d-is fere, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Intermĕdius</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Mellanstående; mellerst:</text:span></text:span> columna, Varr.</text:p>
   <text:p text:style-name="P1">Mediusfidius = (ita = <text:span text:style-name="Fraktur">så wißt)</text:span> me dius fidius <text:span text:style-name="Fraktur">(se</text:span> Fidius, Fido) juvet <text:span text:style-name="Fraktur">l.</text:span> juvabit. <text:line-break/>Medix <text:span text:style-name="Fraktur">se</text:span> Meddix.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>edoācus <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Meduācus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">flodn.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>edobrēga, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Lusitanien.</text:span> <text:line-break/>Medobrēgenses, ium, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">inw. i M.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdon, ontis, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Mĕdulla,</text:span> ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">(af</text:span> medius, <text:span text:style-name="Fraktur">liks.</text:span> <text:span text:style-name="T3">Dem.</text:span> Fabulla <text:span text:style-name="Fraktur">af</text:span> Fabia?): <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Märg; kärne:</text:span></text:span> ossa cum albis m-is (Cyclops) condebat in alvum, Ov.; e caule buglossi m-am eximere, Pn.; nucis, Petr. - <text:span text:style-name="Fraktur">sersk.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">märg = det innersta af kroppen, såsom lifskraftens, känslans (l. sinlighetens) säte, (”nerver”, ”märg och ben”):</text:span> omne bonum in visceribus m-isque condere <text:span text:style-name="Fraktur">(om en wällustling);</text:span> fervor animi in venis m-isque insedit, C. - est (edit) mollis flamma m-as; calor intravit m-as, Vg. - <text:span text:style-name="Fraktur">häraf bildl.:</text:span> hærere alicui in m-is, in m-is alicujus et visceribus hærere <text:span text:style-name="Fraktur">(ligga någon ömt om hjertat),</text:span> C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Märg, kärne</text:span></text:span><text:span text:style-name="Fraktur"> = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T2">det innersta, det ädlaste, kraftigaste</text:span></text:span><text:span text:style-name="Fraktur"> af ngt:</text:span> montis m-is fodere alqd, Catl.; Suadæ m., Enn.; lini; lanæ, Pn.<text:line-break/><text:span text:style-name="T1">Mĕdullāris</text:span>, <text:span text:style-name="T3">A.</text:span>: dolor <text:span text:style-name="Fraktur">(s. går till märgen, djup),</text:span> Ap. <text:line-break/><text:soft-page-break/><text:span text:style-name="T1">Mĕdullĭtus</text:span>, <text:span text:style-name="T3">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">I sitt innersta (i märg och ben), af hjertat:</text:span></text:span> m. servare frigedinem, Varr.; amare, Ap.; uri invidia, Amm. <text:line-break/><text:span text:style-name="T1">Mĕdullōsus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Märgfull:</text:span></text:span> Ce.<text:line-break/><text:span text:style-name="T1">Mĕdullŭla</text:span>, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="T3">Dem.</text:span>: mollior cuniculi capillo vel anseris m. <text:span text:style-name="Fraktur">(märg)</text:span> vel imula auricilla, Catl.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Ēmĕdullātus</text:span>, <text:span text:style-name="T3">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T2">Beröfwad märgen:</text:span></text:span> radix, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdullia ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">stad i Latium.</text:span> <text:line-break/>Mĕdullīnus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ēdus, <text:span text:style-name="T3">A.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T3">Subst.</text:span>: <text:span text:style-name="Fraktur">medisk, Meder (poet. = österländsk öfwerhufwud).</text:span> <text:line-break/>Mēdĭa, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">Medien.</text:span> <text:line-break/>Mēdĭcus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕdūsa, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">mythol. personn.</text:span> <text:line-break/>Mĕdūsæus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1">Mefitis <text:span text:style-name="Fraktur">se</text:span> Mephitis.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgăbocchus, i, <text:span text:style-name="T3">m.</text:span>: <text:line-break/><text:span text:style-name="T2">M</text:span>ĕgăbyzus, i, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">persiska personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgæra, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">mythol. personn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgălensis, <text:span text:style-name="T3">A.</text:span>: ludi M-es = ludi magnæ Matris (Cybelæ). <text:line-break/>Mĕgălensia, ium, <text:span text:style-name="T3">n.</text:span> = ludi M-es. <text:line-break/>Mĕgălēsiăcus, <text:span text:style-name="T3">A.</text:span>: id.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgălŏpŏlis, is, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">gr. stadsn.</text:span> <text:line-break/>Mĕgălŏpŏlītæ, ārum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">inwånare i M.</text:span> <text:line-break/>Mĕgălŏpōlītānus, <text:span text:style-name="T3">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgăra, ae, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">och</text:span> <text:line-break/>Mĕgăra, ōrum, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. stadsn.</text:span> <text:line-break/>Mĕgărus, <text:line-break/>Mĕgărēĭus, <text:line-break/>Mĕgărensis, <text:line-break/>Mĕgărēus, <text:line-break/>Mĕgărĭcus, <text:span text:style-name="T3">A.</text:span><text:line-break/><text:span text:style-name="T2">M</text:span>ĕgăreus (3:<text:span text:style-name="Fraktur">stafw.),</text:span> ĕi <text:span text:style-name="Fraktur">och</text:span> ĕos:<text:line-break/>a. <text:span text:style-name="Fraktur">som är ifrån Megara.</text:span><text:line-break/>b. <text:span text:style-name="Fraktur">myth. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgăris, ĭdis, <text:span text:style-name="T3">f.</text:span>: <text:span text:style-name="Fraktur">gr. landskapsn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">M</text:span>ĕgas, ae, <text:span text:style-name="T3">m.</text:span>: <text:line-break/><text:span text:style-name="T2">M</text:span>ĕgasthĕnes, is, <text:span text:style-name="T3">m.</text:span>: <text:span text:style-name="Fraktur">gr. personn.</text:span></text:p>
