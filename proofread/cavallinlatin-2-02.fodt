   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T3">P</text:span>hĕrĕcȳdes, is, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span> <text:line-break/>Phĕrĕcȳdēus, <text:line-break/>Phĕrĕcȳdīus, <text:span text:style-name="T1">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hĕres, ētis, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">gr. myth. personnamn.</text:span> <text:line-break/>Phĕrētĭădes, ae, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">son af Ph.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">Phĭăla</text:span>, ae, <text:span text:style-name="T1">f.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T3">Skål:</text:span></text:span> Pn., Juv., Mt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hīdĭas, ae, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">Greklands berömdaste bildhuggare, 5:te seklet f. Chr.</text:span> <text:line-break/>Phīdĭăcus, <text:span text:style-name="T1">A.</text:span>: <text:span text:style-name="Fraktur">Phidias tillhörig, från Ph. härstammande.</text:span> </text:p>
