   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hĕnĕos <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Phĕnĕus, ei, <text:span text:style-name="T1">f.</text:span>: <text:span text:style-name="Fraktur">gr. stadsnamn.</text:span> <text:line-break/>Phĕnĕātæ, ārum, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">inwånare i Ph.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">Phengītes,</text:span> æ, <text:span text:style-name="T1">m.</text:span>: v. gr.: p. lapis, <text:span text:style-name="Fraktur">ett slags genomskinlig ädelsten:</text:span> Pn., Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hĕræ, ārum, <text:span text:style-name="T1">f.</text:span>: <text:span text:style-name="Fraktur">gr. stadsnamn (i Thessalien och annorstädes).</text:span><text:line-break/>Phĕræus, <text:span text:style-name="T1">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hĕrĕclus, i, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">gr. myth. personnamn.</text:span> <text:line-break/>Phĕrĕclēus, <text:span text:style-name="T1">A.</text:span></text:p>
