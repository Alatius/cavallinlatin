   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hīdy̆lē, es, <text:span text:style-name="T1">f.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hĭla, ae, <text:span text:style-name="T1">f.</text:span>: <text:span text:style-name="Fraktur">stad i Macedonien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T3">P</text:span>hĭlădelphīa, ae, <text:span text:style-name="T1">f.</text:span>: <text:span text:style-name="Fraktur">stad i Lydien.</text:span> <text:line-break/>Phĭlădelphēni, ōrum, <text:span text:style-name="T1">m.</text:span>: <text:span text:style-name="Fraktur">inwånare i P.</text:span></text:p>
