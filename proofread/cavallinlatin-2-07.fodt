 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <office:forms form:automatic-focus="false" form:apply-design-mode="false"/>
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
   </text:sequence-decls>
   <text:p text:style-name="P2"><text:span text:style-name="Fraktur"><text:span text:style-name="T1">offerstycken:</text:span></text:span> Ov.<text:line-break/><text:span text:style-name="T3">Prō</text:span><text:span text:style-name="T2">sectus</text:span>, us, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afskärande:</text:span></text:span> Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsĕco</text:span>, cui, ctum, 1.:<text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Skära upp, skära lös</text:span></text:span><text:span text:style-name="Fraktur"> (klippa af):</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i eg. men.:</text:span> Regulus r-tis palpebris necabatur; quorum linguæ faucibus inhærent, eæ r-tæ <text:span text:style-name="Fraktur">(uppskurna)</text:span> scalpello liberantur, C.; unguem ad vivum, Col. <text:line-break/>2. <text:span text:style-name="Fraktur">bildl.:</text:span> ad vivum r. aliquid = <text:span text:style-name="Fraktur">skära upp ända till det friska köttet = taga strängt; strängt granska, nagelfara med ngt,</text:span> C. (de Am. 5).<text:line-break/>II. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Skära undan</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">bort, af, stäcka</text:span></text:span><text:span text:style-name="Fraktur"> (beskära, klippa):</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> barbam; capillos; alas, Ov.; truncum, Vg.; vineam, Col. <text:line-break/>b. <text:span text:style-name="Fraktur">oeg.:</text:span> nimia r-ri oportet, naturalia relinqui; quæ r-da erunt, non patiar ad perniciem civitatis manere; libidines ex parte aliqua r. <text:span text:style-name="Fraktur">(qwäsa);</text:span> de vivo <text:span text:style-name="Fraktur">(friska köttet)</text:span> aliquid <text:span text:style-name="Fraktur">(skära bort, hwad som ej bort l. fick tagas),</text:span> C.; spatio brevi spem longam r-es <text:span text:style-name="Fraktur">(stäck = inskränk),</text:span> Hor.<text:line-break/><text:span text:style-name="T2">Rĕsectio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Uppskärning, afskärning:</text:span></text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsegmĭna</text:span>, um, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afskurna stycken, bitar</text:span></text:span><text:span text:style-name="Fraktur"> (flisor, spån, remsa, lapp):</text:span> unguium; papyri, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsex</text:span>, ĭcis, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Beskuren winqwist:</text:span></text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Irrĕsectus</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Obeskuren:</text:span></text:span> rodere unguem i., Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subsĕco</text:span>, cui, ctum, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nedantill afskära, beskära:</text:span></text:span> herbam falce; manipulum, Varr.; papavereas comas ungue, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subsĕcīvus</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T2">Subsĕcīsīvus</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">eg. som faller af wid skärning l. huggning; oeg. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Som blifwer öfwer</text:span></text:span><text:span text:style-name="Fraktur"> wid delning, mätning, räkning o. s. w.:</text:span> tempora, <text:span text:style-name="Fraktur">(från nödwändiga sysslor) lediga stunder;</text:span> operæ s-æ <text:span text:style-name="Fraktur">(arbete wid sidan),</text:span> C.; philosophia non est res s. <text:span text:style-name="Fraktur">(bisak),</text:span> ordinaria est, Sen.; relictus s. <text:span text:style-name="Fraktur">(som ett öfwerflödigt bihang),</text:span> Ap.<text:line-break/><text:span text:style-name="T2">Subsĕcīvum</text:span>, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öfwerblifwet stycke, öfwerskott</text:span></text:span><text:span text:style-name="Fraktur"> wid landmätning:</text:span> Varr., Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subtersĕco</text:span>, 1.: <text:span text:style-name="Fraktur">undertill </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afskära, dela:</text:span></text:span> C. poēt.</text:p>
   <text:p text:style-name="P1">Secret . . . <text:span text:style-name="Fraktur">se</text:span> Secerno, Cerno.<text:line-break/>Secta, -tator, -tor (ari) <text:span text:style-name="Fraktur">se</text:span> Sequor.<text:line-break/>Sectarius, -tilis, -tio, -tivus, -tor (oris), -torius, -trix, -tura <text:span text:style-name="Fraktur">se</text:span> Seco.<text:line-break/>Secubitus <text:span text:style-name="Fraktur">se</text:span> Secubo, Cubo. <text:line-break/>Secula <text:span text:style-name="Fraktur">se</text:span> Seco.<text:line-break/>Secularis, Seculum <text:span text:style-name="Fraktur">se</text:span> Sæculum.<text:line-break/>Secund . . . <text:span text:style-name="Fraktur">se</text:span> Sequor. <text:line-break/>Secure <text:span text:style-name="Fraktur">se</text:span> Securus, Cura.<text:line-break/>Securicla, -clatus, Securicula, -rifer, -riger <text:span text:style-name="Fraktur">se</text:span> Seeuris, Seco.<text:line-break/>Securitas, Securus <text:span text:style-name="Fraktur">se</text:span> Cura.</text:p>
   <text:p text:style-name="P1">I. <text:span text:style-name="T1">Sĕcus,</text:span> <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Kön</text:span></text:span><text:span text:style-name="Fraktur"> (jfr</text:span> sexus), <text:span text:style-name="Fraktur">blott förekommande i denna ena form och med attributen</text:span> virile <text:span text:style-name="Fraktur">och</text:span> muliebre, <text:span text:style-name="Fraktur">såsom ett slags absolut</text:span> <text:span text:style-name="T5">acc.,</text:span> <text:span text:style-name="Fraktur">i samma betydelse som en</text:span> gen. qualitatis = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">af manligt, qwinligt,</text:span></text:span><text:span text:style-name="Fraktur"> (man-, qwinno-), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">kön:</text:span></text:span> virile s. nunquam ullum habui, Pt.; liberorum <text:soft-page-break/>capitum v. s. ad X milia capta, L.; multitudo omnis ætatis, virile et muliebre s., T.</text:p>
   <text:p text:style-name="P1">II. <text:span text:style-name="T1">Sĕcus,</text:span> <text:span text:style-name="T5">Comp.</text:span><text:line-break/><text:span text:style-name="T2">Sēcius</text:span> <text:span text:style-name="Fraktur">(besl. med</text:span> sequor? <text:span text:style-name="T5">Comp.</text:span> <text:span text:style-name="Fraktur">äfw. i codices skrifw.</text:span> <text:line-break/>setius, <text:line-break/>sequius; <text:span text:style-name="Fraktur">enl.</text:span> Gell., <text:span text:style-name="Fraktur">hos</text:span> Pt. <text:line-break/>sectius; <text:span text:style-name="Fraktur">jfr Corssen, Beitr. p.</text:span> 5):<text:line-break/>I.<text:line-break/><text:span text:style-name="T2">Sĕcus</text:span>, <text:span text:style-name="T5">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Annorlunda</text:span></text:span><text:span text:style-name="Fraktur"> (än</text:span> = <text:span text:style-name="T5">ac, quam</text:span>):<text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> si eveniet, gaudebimus: sin s. <text:span text:style-name="Fraktur">(men om annorlunda</text:span> ɔ: <text:span text:style-name="Fraktur">hwarom icke),</text:span> patiemur animis æquis, Pt.; nunquam eam habui <text:span text:style-name="Fraktur">(bemött)</text:span> s., ac si esset ex me nata, Ter.; non multo s.; non s. dixi, ac sentiebam; paulo s. a me atque ab illo distributa; recte secusne <text:span text:style-name="Fraktur">l.</text:span> an s., nihil ad nos; longe s. est <text:span text:style-name="Fraktur">(det förhåller sig långt -),</text:span> C.; non s. ac <text:span text:style-name="Fraktur">(alldeles som),</text:span> N.; haud s. atque in mari; haud multo s., quam -, Sa.; haud s., quam dignum erat, infensi domum redeunt, L.; haud s., ac jussi, faciunt, Vg.; in medias res haud s. ac notas auditorem rapit, Hor.; non s. exarsit, quam quum Balearica plumbum funda jacit, Ov.; precatus sum, ne s. quam suum sanguinem foveret (fratris filios), T.<text:line-break/>b. <text:span text:style-name="Fraktur">prægnant = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Illa, ofördelaktigt:</text:span></text:span> s. dicere, existimare, judicare de aliquo, C.; res cessit <text:span text:style-name="Fraktur">(gick, aflopp),</text:span> processit s., Sa.; scribere, L.; loqui de aliquo, T.; s. admissa, Su.<text:line-break/>II.<text:line-break/><text:span text:style-name="T2">Sĕcus</text:span> <text:span text:style-name="Fraktur">såsom nomen = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Mindre:</text:span></text:span> non multo s. virium, T. Ann. IV. 5.<text:line-break/>III.<text:line-break/><text:span text:style-name="T2">Sĕcus</text:span>, <text:span text:style-name="T5">Præp.</text:span> = secundum: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bredwid, wid sidan af</text:span></text:span><text:span text:style-name="Fraktur"> (enl.</text:span> Charisius: novum et sordidum): foramina utrinque s. laminas, Cato; s. fluvios, Pn.; s. viam stare, Qu.<text:line-break/>IV.<text:line-break/><text:span text:style-name="T2">Sēcius</text:span> (sequius), <text:span text:style-name="T5">Adv.</text:span>: <text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Annorlunda,</text:span></text:span><text:span text:style-name="Fraktur"> wanligen med negation:</text:span> non s., neque eo s., nihilo s. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">icke mindre, icke desto mindre;</text:span></text:span><text:span text:style-name="Fraktur"> äfwen</text:span> quo s. = quominus (ne): nihilo s., Pt., Ter., Cs., N.; impedimento est, quo s. lex feratur, C. (ad Her.); neque eo s. Atheniensibus officia præstabat, N.; instat non sēcius -; toto non sēcius aëre <text:span text:style-name="Fraktur">(som från hela)</text:span> ningit, Vg.; trepidant haud s. omnes, quam solet urbs (oppugnata); scythicā non s. it sagittā <text:span text:style-name="Fraktur">(flyga ej annorlunda än = snabbt som),</text:span> Ov.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sämre, illa:</text:span></text:span> sequius loqui de aliquo, Sen.</text:p>
   <text:p text:style-name="P1">Secutor <text:span text:style-name="Fraktur">se</text:span> Sequor.</text:p>
   <text:p text:style-name="P1">Sēd <text:span text:style-name="T5">abl.</text:span> <text:span text:style-name="Fraktur">af pron. refl.</text:span> = Se.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕd</text:span> <text:line-break/>(set), <text:span text:style-name="T5">Conj. adversativa</text:span>:<text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Men, dock,</text:span></text:span><text:span text:style-name="Fraktur"> inledande ngt, som upphäfwer l. inskränker det föregående (jfr</text:span> at, autem); <text:span text:style-name="Fraktur">serskildt märkes:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">efter negation = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Men wäl:</text:span></text:span> non videt, quum repente in tam - perturbatum domicilium immigravit, s. quum se collegit, tum agnoscit, C.<text:line-break/>b. <text:span text:style-name="Fraktur">efter uttryck för medgifwande (med l. utan ett</text:span> quidem): vere et jure possum, s. quid necesse est?; non perfectum illud quidem, s. tolerabile; multa præclara, s. illud præstantissimum; erant literati, s. <text:soft-page-break/>et alii, C.; plurima quidem proferre possumus, s. modus adhibendus est, N.; durum, s. levius fit patientiā, Hor. <text:line-break/>c. <text:span text:style-name="Fraktur">i inkast</text:span> (sed, sed enim) = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Men se, men ju:</text:span></text:span> s. <text:span text:style-name="Fraktur">(säger man)</text:span> quæstiones urgent Milonem -, C. <text:span text:style-name="Fraktur">(jfr</text:span> L. V. 53. Vg. Aen. I. 19). <text:line-break/>d. <text:span text:style-name="Fraktur">i öfwergångar af talet, afbrytande (afslutande l. liksom hejdande, rättande) l. inledande ngt nytt: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Men, dock, emellertid:</text:span></text:span> s. concrepuit ostium; s. eccum egreditur, Pt.; s. hæc hactenus; s. hæc alia quæstio est: nos ad propositum revertamur; s. de primo officii fonte satis dictum est; s. quid agimus? oblitine sumus - (Tusc. I. §. 81); s. hoc ipsum concedatur -; s. tempus est abire -; s. quid Socratem commemoro?; s. quid singulorum opiniones animadvertam? (ibdm §. 87. 99. 100. 108 - <text:span text:style-name="Fraktur">på alla dessa ställen afbrytande; - mera blott förmedlande öfwergången</text:span> §. 7. 8. 109; de Off. I. 36. 30), C.; s. quid ego hæc - recordor?; quos ego - s. motos præstat componere fluctus, Vg.; N. (XXIII. 13. 4. - <text:span text:style-name="Fraktur">blott öfwergångspartikel</text:span> XV. 6. 4. XIV. 6. 1.); Hor. (Sat. I. 1. 27). <text:line-break/>e. <text:span text:style-name="Fraktur">häraf ock återknytande en genom parentheser afbruten period:</text:span> sed, sed tamen = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Säger jag:</text:span></text:span> si quis est paulo ad voluptates propensior, modo ne sit ex pecudum genere (sunt enim quidam homines non re, sed nomine), s. si quis est paulo erectior - occultat - appetitum voluptatis (de Off. c. 30; <text:span text:style-name="Fraktur">jfr</text:span> de Or. II. 90. III. 12), C.<text:line-break/>II. <text:span text:style-name="Fraktur">efter negation: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Utan, utan ock</text:span></text:span> [non modo (non), sed etiam (ne - quidem)]: non suā, s. patriæ gloriā splendorem assecutus est; non cognomen solum Athenis deportasti, s. humanitatem et prudentiam; non modo familiaritates exstingui, s. etiam bella gigni sempiterna, C.</text:p>
   <text:p text:style-name="P1">Sedameu, Sedat . . . <text:span text:style-name="Fraktur">se</text:span> Sedo, Sedeo. <text:line-break/>Sedecies, -decim <text:span text:style-name="Fraktur">se</text:span> Sex.<text:line-break/>Sedecula (<text:span text:style-name="T5">Dem.</text:span> <text:span text:style-name="Fraktur">af</text:span> Sedes), Sedentarius <text:span text:style-name="Fraktur">se</text:span> Sedeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕdeo,</text:span> sēdi, sessum, 2.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta:</text:span></text:span><text:line-break/>I. <text:span text:style-name="Fraktur">i eg. uttryck i allm.:</text:span> hi stant ambo, non s-ent, Pt.; senem sessum <text:span text:style-name="Fraktur">(till att sitta)</text:span> receperunt; s. in sella, in solio; apud, supra, infra aliquem; in puppi; pro æde, C.; in acie s-re Galli consuerunt, Cs. (b. G. VIII. 15); in ara s., N.; in regia sede pro curia; <text:span text:style-name="Fraktur">(med ensam</text:span> <text:span text:style-name="T5">abl.</text:span>) carpento, L.; eques in primis sedilibus <text:span text:style-name="Fraktur">(på theatren);</text:span> fautoris - aulæa manentis et usque sessuri <text:span text:style-name="Fraktur">(som will sitta qwar),</text:span> donec cantor vos plaudite dicat, Hor.; super arma, Vg.; in culmine bubo; humo nudā; solio; ante fores; prope, post alqm, Ov.; supra leonem, Pn.<text:line-break/>II. <text:span text:style-name="Fraktur">i serskilda och oegentliga anwändningar:</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">om personer:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta, hafwa sin plats</text:span></text:span><text:span text:style-name="Fraktur"> någorstädes:</text:span> ad gubernacula reipublicæ; ad medium Janum s-ent <text:span text:style-name="Fraktur">(hafwa sina kontor -</text:span> argentarii); in faucibus macelli, C.; in Græcia materfamilias non s-et, nisi in interiore parte ædium, N.; celsā s-et <text:span text:style-name="Fraktur">(thronar)</text:span> Aeolus arce sceptra tenens, Vg. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta</text:span></text:span><text:span text:style-name="Fraktur"> såsom domare</text:span> (judex) <text:span text:style-name="Fraktur">l. senator, ordförande, embetsman</text:span> (in rostris) <text:span text:style-name="Fraktur">wid en offentlig förhandling:</text:span> s. in tribunali, in consilio alicujus; s. in judicio, judicem <text:span text:style-name="Fraktur">(såsom domare)</text:span> in <text:span text:style-name="Fraktur">(mot)</text:span> alqm, inter aliquos, de re; <text:span text:style-name="Fraktur">äfwen absolut = sitta såsom domare:</text:span> præsens ac s-ens meam orationem lacrimis suis adjuvit; s-ens (in senatu) iis assensi; Scævola in rostris s-ente <text:span text:style-name="Fraktur">l. ensamt</text:span> s-ente lex lata est, C.; sedi cogniturus, Pn. ep. <text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta</text:span></text:span><text:span text:style-name="Fraktur"> = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">rida,</text:span></text:span><text:span text:style-name="Fraktur"> äfwen</text:span> <text:span text:style-name="T5">trans.</text:span>: in equo, C.; frenato delphine, Ov.; <text:soft-page-break/>equus s-etur, Sp. - <text:span text:style-name="Fraktur">(bildl.:</text:span> post equitem s-et atra cura, Hor.). <text:line-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta</text:span></text:span> = morari, quiescere: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">uppehålla sig, dröja, sitta, ligga stilla, owerksam</text:span></text:span><text:span text:style-name="Fraktur"> (serskildt i motsats till militäriska rörelser):</text:span> domi, Ter.; tot dies in villa; Corcyræ; nos s-emus in Italia <text:span text:style-name="Fraktur">(neutrale),</text:span> C.; uno loco, N.; stultitia est s-do aut votis debellari credere posse; s-do Hannibalem superaturi sumus?, L. <text:line-break/>e. <text:span text:style-name="Fraktur">sitta = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bida; blifwa wid, hålla i</text:span></text:span><text:span text:style-name="Fraktur"> (jfr</text:span> assiduus): Romanus s-do vincit, Varr. <text:line-break/>f. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta, ligga,</text:span></text:span><text:span text:style-name="Fraktur"> om l. med en belägrande, bewakande här</text:span> (obsideo): ad urbem; ad Romana moenia; urbem expugnare s-do, L.; montana s-et circum castella sub armis, Vg. <text:line-break/>2. <text:span text:style-name="Fraktur">om döda subject:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta, ligga:</text:span></text:span> nebula densior campo s-bat <text:span text:style-name="Fraktur">(låg),</text:span> quam montibus, L.; in ovis aliquid; nix, Pn.; pallor in ore, Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta fast:</text:span></text:span> <text:line-break/>α. <text:span text:style-name="Fraktur">i yttre men.:</text:span> nunc s-et Ortygie (quæ olim erravit in undis); ossa in cerebro; plaga s-et (ɔ: <text:span text:style-name="Fraktur">tränger in),</text:span> Ov.; aliquid in ore alicujus, St.<text:line-break/>β. <text:span text:style-name="Fraktur">i någons sinne, minne:</text:span> id s-et pio Aeneæ <text:span text:style-name="Fraktur">(är hans fasta beslut);</text:span> (si) s-et hoc animo, patet isti janua leto, Vg.; Cressa in ingenio alicujus, Ov.; aliquid in ingenio alicujus, Sen.; bellum, sententia alicui, Fl.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta wäl, passa,</text:span></text:span><text:span text:style-name="Fraktur"> eg. och oeg.:</text:span> toga melius, Qu.; esca s-et alicui <text:span text:style-name="Fraktur">(bekommer wäl),</text:span> Hor.; imperium s-et humeris alicujus, Pn.<text:line-break/>d. <text:span text:style-name="Fraktur">om orter: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ligga lågt:</text:span></text:span> urbs, Mela, Sil.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sīdo</text:span>, (sidi), sēdi, sessum, 3.: (: sedeo = sisto: sto): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg. om menniskor och djur, poet.:</text:span> marmoreo superi sēdēre recessu, Ov. (Met. I. 177); columbæ; aves super arbore s-unt, Ov., Vg.; - si s-rit in nostro cauta noverca toro, Ppt. (IV. 11. 86). <text:line-break/>2. <text:span text:style-name="Fraktur">oeg. om saker:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gå till botten, sänka sig, sjunka:</text:span></text:span> navis coepit s-re, N.; caelum s-et inferius mari, Hor.; clava in ore <text:span text:style-name="Fraktur">(trängde in),</text:span> Ov.; in cineres arx, Ppt.; ovum in aqua, ad imum vasis s-it <text:span text:style-name="Fraktur">(mots.</text:span> innatat), Pn.; quum pix siderit -, Col.; montes immensi s-runt, T.<text:line-break/>b. <text:span text:style-name="Fraktur">bildl. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta, lägga sig</text:span></text:span> (sedari): s-ente paulatim metu, T.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig fast, fastna;</text:span></text:span><text:span text:style-name="Fraktur"> serskildt om skepp: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sätta sig, stöta på grund:</text:span></text:span> pallia in lecto non s-unt <text:span text:style-name="Fraktur">(= komma i ordning, jfr</text:span> sedeo, II. 2. c.), Ppt.; ancora s. <text:span text:style-name="Fraktur">(griper),</text:span> Pn.; navis s-it, Cs., N., Ppt.; navis s-it reciproco mari <text:span text:style-name="Fraktur">(mots.</text:span> innat); navis, planā carinā, s-it sine noxa, T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sĕdentārius</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">som befinner sig eller sker i sittande ställning:</text:span> sutor, Pt.; opera s-a <text:span text:style-name="Fraktur">(sittandes arbete),</text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sēdes</text:span>, is, <text:span text:style-name="T5">f.</text:span>: (<text:span text:style-name="T5">gen. plur.</text:span> sedium, C.; sedum, L.): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Säte:</text:span></text:span><text:line-break/>I. <text:span text:style-name="Fraktur">det ställe, redskap, hwarpå man sitter:</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i eg. men.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittplats</text:span></text:span><text:span text:style-name="Fraktur"> (thron, stol, soffa o. s. w.):</text:span> consederunt in s-bus, quæ erant sub platano; s. honoris sella curulis, C.; in s-e regiā sedere, L.; s. columbis nota, Hor.; s-bus hæret in isdem, Vg.; alta, Ov.; celsa, Ps.; inter deos, Pn.; s. remigum (= transtra), Luc.<text:line-break/>2. <text:span text:style-name="Fraktur">i allm. = ställe, der ngn l. ngt befinner sig:</text:span><text:line-break/>a. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Boning, bostad, hem,</text:span></text:span><text:span text:style-name="Fraktur"> i inskränktare och widsträcktare mening: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">hembygd, hemland,</text:span></text:span><text:span text:style-name="Fraktur"> lika wäl som </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">hus, boningsort,</text:span></text:span><text:span text:style-name="Fraktur"> ett folks så wäl som en enskilds, i båda fallen både i</text:span> <text:span text:style-name="T5">plur.</text:span> <text:span text:style-name="Fraktur">och i</text:span> <text:span text:style-name="T5">sing.</text:span>: s-em incolere, mutare, alicui præbere; s-em deligere, aliquo loco constituere; s-em stabilem non habere; immissi sunt, qui me in s-bus meis <text:span text:style-name="Fraktur">(mitt hus </text:span><text:soft-page-break/><text:span text:style-name="Fraktur">och hem)</text:span> trucidarent, C.; populus s-es petit, habet alicubi, Cs., Sa.; revertitur in s-es suas, Cs.; Trojani Aenea duce incertis s-bus vagabantur, Sa.; quærebant s-es Trojani; certā stabilique s-e errorem finire; in Italia bellum gerimus in s-e ac solo nostro; servata urbs est (Capua), ut esset aliqua aratorum s., L.; fata locum s-emque dederunt, Vg.; piorum lætæ s-es; lucidas s-es (Olympum) inire; s. senectæ meæ, Hor.; patriæ s-es; infernæ s. <text:span text:style-name="Fraktur">(underjorden),</text:span> Ov.; Chatti initium s-is ab Hercynio saltu inchoant <text:span text:style-name="Fraktur">(deras land widtager på gränsen af -),</text:span> T.; s-em figere Cumis, Juv.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Grund,</text:span></text:span><text:span text:style-name="Fraktur"> (fäste) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">grundwal,</text:span></text:span><text:span text:style-name="Fraktur"> (fast) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">mark,</text:span></text:span><text:span text:style-name="Fraktur"> hwarpå ngn l. ngt står, fotar, stödjer sig, har sin hållpunkt, är bygdt (grundadt) o. s. w., i eg. och oeg. men.:</text:span> Roma prope convulsa s-bus suis; verba s-em habere non possunt, si rem subtraxeris; summo imperio domicilium ac s-em præbuit (Roma); nulla est horum criminum s.; domicilium superbiæ, s. luxuriæ <text:span text:style-name="Fraktur">(tillhåll),</text:span> C.; Vejos s-em belli <text:span text:style-name="Fraktur">(utgångs- och stödjepunkt)</text:span> capere; montes s-e sua moliri, L.; mare totum a s-bus imis ruunt (venti), Vg.; solidis s-bus <text:span text:style-name="Fraktur">(på fast grund)</text:span> astare; Athos s-e sua revulsus; ima de s-e terræ emissum, Ov.; belli s-em (urbem) rescindere, T.<text:line-break/>c. <text:span text:style-name="Fraktur">i allm.: ngns l. ngts </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ställe, rum, plats,</text:span></text:span><text:span text:style-name="Fraktur"> oftast med bibetydelse af rätt plats, hwarifrån saken ej bör rubbas l. wika:</text:span> s. animi (in corpore); voluptatem ponere in summi boni s-e; nomen tuum stabilem s-em non habebit; omnibus, quæ sub aspectum cadunt, s. opus est, C.; nec mens mihi nec color certā s-e manet; suā s-e cedere; priores s-es tenet Mæonius (ɔ: Homerus); deus hæc benignā vice in s-em reducet, Hor.; regni s. <text:span text:style-name="Fraktur">(hufwudstad),</text:span> Vg.; s. animi (corpus), Ov.<text:line-break/>II. = <text:span text:style-name="Fraktur">den del af kroppen, hwarpå man sitter</text:span> (podex, anus): s. procidua, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sēdēcŭla</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="T5">Dem.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Liten sittplats:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sedĭcŭlum</text:span>, i, <text:span text:style-name="T5">n.</text:span>: (Varr.) = sedile.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sĕdīle</text:span>, is, <text:span text:style-name="T5">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittplats, säte, hwiloplats</text:span></text:span><text:span text:style-name="Fraktur"> (naturlig l. af menniskohand - stol, soffa, bänk o. s. w.):</text:span> vivo - s-a saxo; gramineo s-i locare aliquos, Vg.; s-a <text:span text:style-name="Fraktur">(på theatren)</text:span> spissa; in primis s-bus (theatri) sedere, Hor.; membra senex jussit posito relevare s-i, Ov.; avium s. <text:span text:style-name="Fraktur">(i hönshus),</text:span> Varr.<text:line-break/>2. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittande, sittning:</text:span></text:span> Ce.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sĕdĭmentum</text:span>, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bottensats:</text:span></text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sēdo</text:span>, 1.:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stilla, lugna, mildra, lindra:</text:span></text:span> alqm s. <text:span text:style-name="Fraktur">(stilla ngns hunger),</text:span> Pt.; calamitatem, Ter.; tempestatem; motus animi; lites; infamiam; bellum; appetitus omnes; măla, C.; tumultum, Cs.; sitim, Lucr.; pulverem s. = <text:span text:style-name="Fraktur">afkyla</text:span> (humum æstuantem) <text:span text:style-name="Fraktur">genom wattenstänkning,</text:span> Phdr.; lassitudinem; impetum populi incendere, s., N.; fletus, Ppt.; proelium, L.; jejunia carne, Ov.; rabiem indomitam, Hor.<text:line-break/>2. <text:span text:style-name="T5">intrans.</text:span> = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lägga sig, lugnas:</text:span></text:span> tempestas, scriptor ap. Gell. XVIII. 12. 6.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">Sēdātus</text:span>, <text:span text:style-name="T5">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sakta, stilla, lugn:</text:span></text:span> vox s-sima (ad Her.); animus s-ior; tempus, C.; homo <text:span text:style-name="Fraktur">(mots.</text:span> celer), Hor.; amnis, Vg.; venti, Ov.<text:line-break/><text:span text:style-name="T2">Sēdāte</text:span>, <text:span text:style-name="T5">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lugnt, stilla, saktmodigt:</text:span></text:span> loqui; ferre aliquid, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sēdāmen</text:span>, ĭnis, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Medel att stilla, lugna, mildra:</text:span></text:span> mali, Sen.<text:line-break/><text:span text:style-name="T2">Sēdātio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stillande, lugnande:</text:span></text:span> perturbationum animi; animi, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sēdŭlus</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">(med afseende på stamstafwelsens längd jfr</text:span> sēdo, sēdes, <text:span text:style-name="Fraktur">samt t. ex.</text:span> coāgulum <text:span text:style-name="Fraktur">af</text:span> ăgo, rēgula <text:span text:style-name="Fraktur">af</text:span> rĕgo): <text:span text:style-name="Fraktur">(som gör sig beswär, brådt med ngt) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Flitig, ifrig, sträfsam, idog;</text:span></text:span><text:span text:style-name="Fraktur"> (oftast med bibetydelse af beskedlig wälmening, som föga uträttar, eller af fjesk), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">beställsam:</text:span></text:span> eloquentes <text:span text:style-name="Fraktur">(werkliga wältalare)</text:span> videbare, non s-os - <text:span text:style-name="Fraktur">som gjort sig beswär (för att bli l. synas det),</text:span> C.; hospes; spectator <text:span text:style-name="Fraktur">(uppmärksam, fängslad, mots.</text:span> lentus = <text:span text:style-name="Fraktur">kall, likgiltig),</text:span> Hor.; anus, Ov., Tib.; nutrix male s.; apis, Ov.<text:line-break/><text:span text:style-name="T2">Sēdŭlĭtas</text:span>, ātis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Oförtrutenhet; trägna, trogna bemödanden; nit; beställsamhet, fjesk:</text:span></text:span> hominis s-em et integritatem videtis; s. mea et mihi et reipublicæ fructum tulit; - s. insidiosa, impudens, arguta, C.; officiosa s. et opella forensis; s. stulte quem diligit, urget, Hor.; non sentitur s-e labor; placere s-e, Ov.<text:line-break/><text:span text:style-name="T2">Sēdŭlo</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:line-break/><text:span text:style-name="T2">Sēdŭle</text:span> (Col.), <text:span text:style-name="T5">Adv.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Med all flit, flitigt, träget; troget, ifrigt, angeläget, beställsamt:</text:span></text:span> servire; volui s. nobilitatem meam occultare, Pt.; eniti; celare, Ter.; faciam omnia s.; s. argumentaris, quid sit sperandum, C.; s. <text:span text:style-name="Fraktur">(med sorgfällig beräkning)</text:span> tempus terere; s. opera data est, ut -, L.; s-e circumire alvearia, Col.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Med flit, med afsigt:</text:span></text:span> si citius agi vellet agmen, tardius s-o incedere, L. II. 58.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ärligt, redligt:</text:span></text:span> s. hunc dixisse credo, Ter. (Phorm. 453).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sella</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: (sed-(u)-la): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stol:</text:span></text:span> in s-a assidĕre, Pt.; in s-a requiescere; s. curulis <text:span text:style-name="Fraktur">(elfenbensstol utan ryggstöd, på hwilken högre embetsmän sutto i tribunalet),</text:span> C., L.; locus s-æ <text:span text:style-name="Fraktur">(handtwerkares)</text:span> et operis quotidiani; s. in ludo <text:span text:style-name="Fraktur">(lärares i skola),</text:span> C.; s. familiarica, pertusa <text:span text:style-name="Fraktur">(= nattstol),</text:span> Varr., Cato; s-ā <text:span text:style-name="Fraktur">(wagnssäte)</text:span> primā sedens jugum flagello temperat, Phdr.; = <text:span text:style-name="Fraktur">sadel,</text:span> Veg., Jct.; s-ā <text:span text:style-name="Fraktur">(bärstol)</text:span> gestari, per publicum incedere, vehi, T., Su., Pn.; s. gestatoria, Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sellārius</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">som hör till, sitter på stol, sker i stol:</text:span> gestatio, Cael.<text:line-break/><text:span text:style-name="T2">Sellāria</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sal</text:span></text:span><text:span text:style-name="Fraktur"> (försedd med stolar):</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sellisternium</text:span>, i, <text:span text:style-name="T5">n.</text:span>: (sterno): <text:span text:style-name="Fraktur">(stolbäddning), religiös fest, hwarwid gudabilder sattes på</text:span> sellæ <text:span text:style-name="Fraktur">kring bord med rätter (jfr</text:span> lectisternium): T. (Ann. XV. 44).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sellŭla</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Liten stol:</text:span></text:span> s-ā <text:span text:style-name="Fraktur">(bärstol)</text:span> deferri domum, T.<text:line-break/><text:span text:style-name="T2">Sellŭlārius</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">och</text:span> <text:line-break/><text:span text:style-name="T2">Sellŭlārius</text:span>, i, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">som sitter på</text:span> s., <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Handtwerkare:</text:span></text:span> artifex; quæstus, Gell. - <text:span text:style-name="T5">Subst.</text:span>: L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subsellium</text:span>, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">låg sittplats, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bänk:</text:span></text:span><text:span text:style-name="Fraktur"> </text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i allm.:</text:span> imi s-i vir, Pt.<text:line-break/><text:soft-page-break/>2. <text:span text:style-name="Fraktur">serskildt:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittplats</text:span></text:span><text:span text:style-name="Fraktur"> (fast), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">rad</text:span></text:span><text:span text:style-name="Fraktur"> på theatren och amphitheatren (jfr</text:span> gradus): conquistores singula in s-a eant per totam caveam spectatoribus, Pt.; senatoria, C., Su.<text:line-break/>b. <text:span text:style-name="Fraktur">wanl.</text:span> <text:span text:style-name="T5">pl.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bänkar,</text:span></text:span><text:span text:style-name="Fraktur"> hwarpå senatorerne sutto i curian:</text:span> s-a senatus; <text:span text:style-name="Fraktur">meton.:</text:span> longi s-i <text:span text:style-name="Fraktur">(senats-session)</text:span> judicatio, C.<text:line-break/>c. <text:span text:style-name="Fraktur">wanl.</text:span> <text:span text:style-name="T5">pl.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bänkar</text:span></text:span><text:span text:style-name="Fraktur"> för nämnd</text:span> (judices), <text:span text:style-name="Fraktur">wittnen, åklagare o. s. w. wid domstolarne; meton. = domstol, rättegångsförhandlingar, werksamhet såsom sakförare (mots.</text:span> tribunal, <text:span text:style-name="Fraktur">der præsidenten satt):</text:span> accusatorum s-a; versari in utrisque s-is <text:span text:style-name="Fraktur">(såsom domare och sakförare)</text:span> summā fide; in s-is habitat (causidicus); a s-is in otium se conferre; ne semper forum, rostra, s-a meditere, C.<text:line-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bänkar</text:span></text:span><text:span text:style-name="Fraktur"> i en auctionssal:</text:span> Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sessĭbŭlum</text:span>, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stol:</text:span></text:span> Pt., Ap.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sessĭlis</text:span>, <text:span text:style-name="T5">A.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Egnad, beqwäm att sitta på</text:span></text:span><text:span text:style-name="Fraktur"> -:</text:span> tergum, Ov.<text:line-break/>b. <text:span text:style-name="Fraktur">liksom formad till att sitta, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Med bred bas; bred, låg:</text:span></text:span> pirum; lactuca, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sessĭmōnium</text:span>, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittplats, samlingsställe:</text:span></text:span> deorum, Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sessio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittande, sittning:</text:span></text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> status, incessus, s. teneant illud decorum; quædam s-es <text:span text:style-name="Fraktur">(sätt att sitta)</text:span> contra naturam sunt; pomeridiana s. - <text:span text:style-name="Fraktur">eftermiddags- (-sittning) -session, underhållning,</text:span> C.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sölande, owerksamhet:</text:span></text:span> C.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittplats, hwiloplats:</text:span></text:span> hæc porticus et palæstra et tot locis s-es - gymnasiorum Græcorum memoriam commovent, C.<text:line-break/>3. <text:span text:style-name="Fraktur">den del, hwarpå ngn l. ngt sitter, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Säte, bas:</text:span></text:span> Cael. <text:line-break/><text:span text:style-name="T2">Sessiuncŭla</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="T5">Dem.</text:span>: <text:span text:style-name="Fraktur">(sittning), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sammankomst</text:span></text:span><text:span text:style-name="Fraktur"> för nöje, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">underhållning:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sessĭto</text:span>, 1.: <text:span text:style-name="T5">Frequ.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ständigt sitta, pläga sitta:</text:span></text:span> Suada in labris Periclis, C.<text:line-break/><text:span text:style-name="T2">Sessĭtātio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>: Ce.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sessor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">sittare:</text:span><text:line-break/>a. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Åskådare</text:span></text:span><text:span text:style-name="Fraktur"> (på theatren):</text:span> Hor.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ryttare:</text:span></text:span> Sen. <text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Innebyggare, inwånare:</text:span></text:span> N.<text:line-break/><text:span text:style-name="T2">Sessōrium</text:span>, i, <text:span text:style-name="T5">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stol:</text:span></text:span> Cael.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Näste:</text:span></text:span> viperæ, Petr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Assĭdeo</text:span>, sēdi, sessum, 2.:<text:line-break/>1. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta hos, bredwid, wid</text:span></text:span><text:span text:style-name="Fraktur"> ngn l. ngt</text:span> (<text:span text:style-name="T5">alicui,</text:span> <text:span text:style-name="Fraktur">mera sällan</text:span> <text:span text:style-name="T5">aliquem, aliquid</text:span>); <text:span text:style-name="Fraktur">kan ofta i sw. återgifwas med blott </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sitta:</text:span></text:span> simul; non a-ens et attente audiens, sed uno aspectu et præteriens, C.; adolescentes ibi nobiles, L.; Jovi, Ov.<text:line-break/>2. <text:span text:style-name="Fraktur">serskildt:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta hos</text:span></text:span><text:span text:style-name="Fraktur"> en sjuk l. ngn, som af annan orsak behöfwer wård l. tröst, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">wid</text:span></text:span><text:span text:style-name="Fraktur"> ngns </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sida</text:span></text:span><text:span text:style-name="Fraktur"> (säng):</text:span> lacrimans in carcere mater noctes <text:soft-page-break/>diesque, C.; ægro, L., Sen.; si - casus te lecto afflixit, habes, qui a-eat <text:span text:style-name="Fraktur">(har du någon, som sitter wid din säng?);</text:span> a-ens implumibus pullis avis, Hor.; a-ente amantissima uxore, T.; ægrotum, Ap. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta wid sidan af, wara bisittare hos, sitta såsom biträde för</text:span></text:span><text:span text:style-name="Fraktur"> domare l. part wid en domstol l. embetsförrättning i allm.:</text:span> principes - hujus periculo commoti huic a-ent, pro hoc laborant; magistratui, C.; judiciis, T., Su.; a-eant fratres (Aeaco), Ppt.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta wid</text:span></text:span><text:span text:style-name="Fraktur"> ett arbete:</text:span> literis totā vitā, Pn., Sen.<text:line-break/>d. <text:span text:style-name="Fraktur">om en här: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ligga, wara lägrad wid, utanför,</text:span></text:span><text:span text:style-name="Fraktur"> för att bewaka l. belägra, med</text:span> <text:span text:style-name="T5">dat.</text:span> <text:span text:style-name="Fraktur">och</text:span> <text:span text:style-name="T5">acc.</text:span>: urbi; muris, L.; muros, Vg.; castellum, T.<text:line-break/>e. <text:span text:style-name="Fraktur">sitta hos = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stå nära,</text:span></text:span><text:span text:style-name="Fraktur"> wara lik (mots.</text:span> dissideo): parcus ob heredis curam a-et insano, Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Assīdo</text:span>, sēdi, sessum, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig bredwid, hos, wid</text:span></text:span><text:span text:style-name="Fraktur"> (ngns) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sida</text:span></text:span><text:span text:style-name="Fraktur"> (i sw. ofta att återgifwa med blott: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sätta sig ned):</text:span></text:span> in sella, Pt.; a-amus, si placet; peroravit (accusator), assedit, surrexi ego (patronus); super aspidem; in scholā, C.; dextrā Hiempsalem <text:span text:style-name="Fraktur">(till höger om)</text:span> assedit, Sa.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Assessio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittande, (besök)</text:span></text:span><text:span text:style-name="Fraktur"> hos en sjuk l. bedröfwad:</text:span> a., confirmatio fracti animi, C.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bisittande</text:span></text:span><text:span text:style-name="Fraktur"> i en rätt:</text:span> Jct.<text:line-break/><text:span text:style-name="T2">Assessor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>:<text:line-break/><text:span text:style-name="T2">Assestrix</text:span>, īcis, <text:span text:style-name="T5">f.</text:span>: (Afran.): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bisittare, biträde</text:span></text:span><text:span text:style-name="Fraktur"> wid domstol eller embetsförrättning i allm.:</text:span> Lacedæmonii regibus augurem a-em dederunt, C.; prætoris urbani a., Sen.<text:line-break/><text:span text:style-name="T2">Assessōrius</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">som angår bisittare:</text:span> Jct.<text:line-break/><text:span text:style-name="T2">Assessūra</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: = assessio 2.: Jct.<text:line-break/><text:span text:style-name="T2">Assessus</text:span>, us, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittande bredwid</text:span></text:span><text:span text:style-name="Fraktur"> ngn, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">i</text:span></text:span><text:span text:style-name="Fraktur"> ngns </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sällskap:</text:span></text:span> turpior a-u non erit ulla meo, Ppt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Assĭduus</text:span>, <text:span text:style-name="T5">A.</text:span>: p. tr. gr.:<text:line-break/>I. <text:span text:style-name="Fraktur">om personer: </text:span><text:line-break/>1. <text:span text:style-name="Fraktur">som jemnt wistas på ett (sitt) ställe eller </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sitter wid</text:span></text:span><text:span text:style-name="Fraktur"> ett arbete; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">stadigt, ständigt hemma</text:span></text:span><text:span text:style-name="Fraktur"> l. </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">närwarande; trägen (huslig), påpaßlig, idog, stadig, ständig</text:span></text:span><text:span text:style-name="Fraktur"> (i sw. ofta att öfwersätta med ett adv.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">jemnt, ständigt, stadigt, städse):</text:span></text:span> bonus a-que dominus <text:span text:style-name="Fraktur">(husbonde);</text:span> a. agricola; a. in prædiis, Romæ, mecum; rhetores a-i uno opere eandem incudem dies noctesque tundentes, C.; urbani a-i cives <text:span text:style-name="Fraktur">(”gathängare”, stadsinventarier),</text:span> quos scurras vocant, Pt.; mulier a-uior <text:span text:style-name="Fraktur">(husligare),</text:span> Varr.; custos; flamen Jovi a.; templi antistes a., L.; a-o ruptæ lectore columnæ, Juv.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besuten,</text:span></text:span><text:span text:style-name="Fraktur"> serskildt, i mots. till</text:span> proletarii, <text:span text:style-name="Fraktur">om de första servianska classernas medborgare (af Aelius Stilo härledt</text:span> <text:span text:style-name="T5">ab asse dando</text:span>): Cic. de R. II. 22.; quibus erat satis pecuniæ, a-os vocabant, contrarios proletarios, Varr. - <text:span text:style-name="Fraktur">oeg.:</text:span> scriptor a. = <text:span text:style-name="Fraktur">god, klassisk,</text:span> Gell.<text:line-break/>II. <text:span text:style-name="Fraktur">om saker: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Jemn, stadig, ständig, ihållande, beständig, oafbruten, idkelig, trägen, flitig:</text:span></text:span> febricula; frequentia <text:span text:style-name="Fraktur">(stadig);</text:span> fletus; labor; scriptura; recordatio, C.; Hannibal a-is patris obtestationibus eo perductus est, ut interire, quam Romanos non experiri, mallet, N.; imber; consuetudo, Cs.; bella a-a, L.; ver, Vg.; a-o splendeat igne focus, Tib.; motus; nubes; cædes; campus a-is pulsatus equis (i. e. <text:span text:style-name="Fraktur">ständigt - af hästar),</text:span> Ov.<text:line-break/><text:soft-page-break/><text:span text:style-name="T2">Assĭdue</text:span>, <text:line-break/><text:span text:style-name="T2">Assĭduo</text:span>, <text:span text:style-name="T5">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stadigt, ständigt, oafbrutet, flitigt, träget:</text:span></text:span> sic a-e canunt galli -, ut nihil intermittant; frequenter et a. studio et exercitatione consequi alqd; mecum ille fuit a-sime, C.; a-e venire, Vg.; a-o esse cum aliquo, Pt.<text:line-break/><text:span text:style-name="T2">Assĭduĭtas</text:span>, ātis, <text:span text:style-name="T5">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">om personer: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ständig, stadig, oafbruten närwaro; påpaßlighet, ihållighet, ihärdighet, trägenhet:</text:span></text:span> qualem hunc putent, a-e (in judicio) testimonioque declarant; hic fructus est a-is (= assidue Romæ esse, assidue petere magistratum -); a-is et operarum quotidianarum (in foro) consulatus est; medici; Terentiæ pergrata est a. tua <text:span text:style-name="Fraktur">(din uppmärksamhet att flitigt besöka henne),</text:span> C.; fastidium a-is vitare, Su.<text:line-break/>2. <text:span text:style-name="Fraktur">om saker: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Beständighet, ihållighet, oafbrutenhet:</text:span></text:span> bellorum; molestiarum; literæ ejusdem a. <text:span text:style-name="Fraktur">(ständigt upprepande af -);</text:span> literarum a. <text:span text:style-name="Fraktur">(ständig brefwexling),</text:span> C.; contubernii, T.; spectaculorum, Su.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Circumsĭdeo</text:span> <text:line-break/>(Circumsĕdeo), sēdi, sessum, 2.: <text:line-break/>1. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta omkring:</text:span></text:span> alqm amici, Sen. <text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Omhwärfwa, -ringa, omsluta, belägra:</text:span></text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">med trupper:</text:span> vallo, castris, copiis alqm; imperator ab hostibus c-batur, C.; urbem copiis, L.; in castello c-ri, N.<text:line-break/>b. <text:span text:style-name="Fraktur">bildl.:</text:span> ab hominibus (lacrimantibus) me c-sum videtis, C.; muliebribus blanditiis, ab invidiā finitimorum c-ri, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Circumsīdo</text:span>, sēdi, sessum, 3.: <text:span text:style-name="Fraktur">med här </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Omringa, -sluta:</text:span></text:span> oppidum, Sa., L.; vallo et armis, T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Circumsessio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Omhwärfning, -ringning:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Consĭdeo</text:span>, 2.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta stilla:</text:span></text:span> L. VIII. 8.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Consīdo</text:span>, sēdi (sīdi), sessum, 3.:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig tillsammans, i ro, i ordning;</text:span></text:span><text:span text:style-name="Fraktur"> i perf.-former äfwen = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sitta:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> legati certo in loco c-rant <text:span text:style-name="Fraktur">(sutto);</text:span> itur in silvam et ibi c-itur; in sedibus - c-isse <text:span text:style-name="Fraktur">(satt sig)</text:span> omnes, dicebat, C.; in ara c-edit supplex, N.; in sede regis Tarquinius; c-rant utrimque pro castris duo exercitus, L.; in herba, sub arguta c-rat ilice; medicatis sedibus apes c-unt; transtris, Vg.; in umbra; hoc poteras mecum c-re saxo; tergo c-re tauri, Ov.; novis c-re in hortis (aves), Hor.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig</text:span></text:span><text:span text:style-name="Fraktur"> till doms, på domaresäte:</text:span> ut primum judices consedēre, diffidere boni coeperunt; c. in reum, C.; Druides in loco consecrato; in munitione castrorum imperator, Cs.; ad jus dicendum, L.; consedēre duces - vulgi stante corona, Ov.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">om personliga subject:</text:span> <text:line-break/>α. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta, slå sig ned, till ro; stanna, bosätta sig:</text:span></text:span> dubito, hic an Antii c-am; antequam aliquo loco c-ro, literas non exspectabis, C.; in finibus Gallorum Germani, Cs.; Tarquiniis, L.: vultis his mecum c-re regnis, urbem quam statuo, vestra est, Vg. - <text:span text:style-name="Fraktur">bildl.:</text:span> in otio, C.<text:line-break/>β. <text:span text:style-name="Fraktur">(om en här) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fatta posto, stanna, slå läger, lägra sig:</text:span></text:span> sub monte; ad ripas; in eo loco; contra alqm, Cs.; duorum milium intervallo <text:soft-page-break/>exercitus c-rant; superioribus locis, Sa.; in insidiis, L.<text:line-break/>b. <text:span text:style-name="Fraktur">om sakliga subject:</text:span> <text:line-break/>α. <text:span text:style-name="Fraktur">yttre och inre: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sjunka tillsammans, sänka sig; lägga sig, lugna sig:</text:span></text:span> Alpes; junctura verborum c-it - <text:span text:style-name="Fraktur">perioden sänker sig mot slutet;</text:span> ardor animi, C.; terra ingentibus cavernis, L.; ignis nondum c-rat, Ov.; omne mihi visum c-re in ignes Ilium, Vg.; præsentia satis c-iderant, T. (Ann. I. 30. <text:span text:style-name="Fraktur">Halm).</text:span><text:line-break/>β. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig fast, stanna, slå sig till ro</text:span></text:span><text:span text:style-name="Fraktur"> i, wid något:</text:span> in ejus mente c-edit <text:span text:style-name="Fraktur">(fäst sitt bo)</text:span> justitia; ludorum - Magnæ matris - religio ex ultimis arcessita terris in hac urbe c-edit; ejus nomen in quæsturā <text:span text:style-name="Fraktur">(slagit sig till ro wid</text:span> ɔ: <text:span text:style-name="Fraktur">upphört att widare winna ryktbarhet),</text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Consessor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">som sitter tillsammans med ngn i en rätt</text:span> (in judicio), <text:span text:style-name="Fraktur">på theatren, i gästabud o. s. w.:</text:span> C.<text:line-break/><text:span text:style-name="T2">Consessus</text:span>, us, <text:span text:style-name="T5">m.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sittande tillsammans:</text:span></text:span> in ludo talario, C.<text:line-break/>2. <text:span text:style-name="Fraktur">sittande </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Församling</text:span></text:span><text:span text:style-name="Fraktur"> af domare, wid gästabud, skådespel o. s. w.:</text:span> frequens vester c.; theatrales gladiatoriique; a cuncto c-u plausus datur, C.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Rätt att samlas:</text:span></text:span> Jct.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Dēsĭdeo</text:span>, sēdi, 2.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta syßlolös:</text:span></text:span> tam diu, Pt.; totum diem, Ter.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Dēsīdo</text:span>, sēdi, 3.:<text:line-break/>I. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig ned,</text:span></text:span><text:span text:style-name="Fraktur"> spec. på nattstol:</text:span> Ce.<text:line-break/>II. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sjunka ned, sjunka:</text:span></text:span><text:span text:style-name="Fraktur"> </text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg.:</text:span> ovum, Varr.; terra ad ingentem altitudinem desedit, C.; terra cavernā ingenti, L.; quod ex urinā d-it; tumor, Ce.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sjunka</text:span></text:span><text:span text:style-name="Fraktur"> = försämras, slappas:</text:span> mores, L. (præf.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Dēses</text:span>, ĭdis, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Syßlolös, orklös, owerksam, slapp</text:span></text:span><text:span text:style-name="Fraktur"> (okrigisk):</text:span> sedere d-em domi; d-em inter aras agere regnum; nunquam tam d. aut imbellis fuit res Romana, L.; longā pace, T.; vita, St.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Dēsĭdia</text:span>, ae, <text:span text:style-name="T5">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sänkning, sjunkande:</text:span></text:span> maris, Ap.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Syßlolöshet, owerksamhet, lätja:</text:span></text:span> nihil magis cavendum est senectuti, quam ne languori se d-æque dedat; homo plenus d-æ; propter d-am in otio vivere; confugere in portum non inertiæ neque d-æ, sed otii moderati atque honesti, C.; socordiā atque d-ā bonum otium conterere, Sa.; vitanda est improba Siren d., Hor.; vobis d-æ (<text:span text:style-name="T5">plur.</text:span> - <text:span text:style-name="Fraktur">dagdrifwerier)</text:span> cordi (sunt), Vg. <text:line-break/>3. <text:span text:style-name="Fraktur">en åkers </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hwila</text:span></text:span><text:span text:style-name="Fraktur"> (liggande i träde):</text:span> Col. <text:line-break/><text:span text:style-name="T2">Dēsĭdiābŭlum</text:span>, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">dagdrifweri:</text:span> Pt. <text:line-break/><text:span text:style-name="T2">Dēsĭdiōsus</text:span>, <text:span text:style-name="T5">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lätjefull, slapp:</text:span></text:span> otium d-simum et inertissimum; d-a <text:span text:style-name="Fraktur">(beqwäm)</text:span> delectatione vestigare alqd; d-am artem dicimus (per denominationem s. metonymiam), quod d-os facit, C.; vir; puer d. (Amor), Ov. <text:line-break/><text:span text:style-name="T2">Dēsĭdiōse</text:span>, <text:span text:style-name="T5">Adv.:</text:span> <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lätjefullt:</text:span></text:span> ætatem agere, Lucr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Indēses</text:span>, ĭdis, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ej owerksam, werksam:</text:span></text:span> Gell.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Dissĭdeo</text:span>, sēdi, sessum, 2.:<text:line-break/>1. <text:span text:style-name="Fraktur">i rummet </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wara skild, aflägsen</text:span></text:span><text:span text:style-name="Fraktur"> ifrån:</text:span> quantum Hypanis d-et Eridano, Ppt.<text:line-break/><text:soft-page-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wara söndrad, skilja sig</text:span></text:span><text:span text:style-name="Fraktur"> från, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">wara oense</text:span></text:span><text:span text:style-name="Fraktur"> med</text:span> (<text:span text:style-name="T5">a, cum</text:span>): ab aliquo d. animo et voluntate; capitali odio; odio et discidio; consiliis; studiis; armis; a senatu d.; leviter inter se de <text:span text:style-name="Fraktur">l.</text:span> in aliqua re; non cum homine, sed cum causa d.; a se ipso d.; re, non verbis d. cum aliquo, C.; inimici (inter se) d-ntes, N.; virtus plebi d-ens; Medus armis (inter se) d-et, Hor.; hostes d-ent in Arminium et Segestum <text:span text:style-name="Fraktur">(äro söndrade i A-ii och S-i parti),</text:span> T.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Icke stämma öfwerens,</text:span></text:span><text:span text:style-name="Fraktur"> (om kläder: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sitta</text:span></text:span><text:span text:style-name="Fraktur"> illa), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">wara skiljaktig med, afwika ifrån</text:span></text:span><text:span text:style-name="Fraktur"> -:</text:span> a sententia d-et scriptum <text:span text:style-name="Fraktur">(texten);</text:span> opinio d-ens <text:span text:style-name="Fraktur">(afwikande),</text:span> C.; sententia d-ens, Ov.; toga d-et impar, Hor.; quercus et olea hac re d., Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Dissĭdentia</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Olikhet:</text:span></text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Insĭdeo</text:span>, sēdi, sessum, 2.:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta på, i:</text:span></text:span> dii penates dicti, quod penitus i-ent, C.; virgo i-ens equo, L.; toro, Ov.; in sella, Pn.; manus i-ens capulo <text:span text:style-name="Fraktur">(hwilande på -),</text:span> T.; equus i-etur <text:span text:style-name="Fraktur">(rides),</text:span> Gell.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hålla besatt, bewaka:</text:span></text:span> locum monstrabit, quem i-eatis; viæ hostium præsidiis i-entur; Porsena Janiculum, L.; urbem (Romam) i-bat proprius miles, T.<text:line-break/>3. <text:span text:style-name="Fraktur">bildl. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta, wara fästad, sitta fast</text:span></text:span><text:span text:style-name="Fraktur"> (intryckt) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">i, wid, på:</text:span></text:span> ipsius in mente i-bat species pulcritudinis eximiæ; i-et in animo oratio, suspicio, fictum crimen; i-et in memoria alqd; macula in nomine; voluptas penitus in omni sensu implicata i-et, C.; deorum assidua i-ens cura - pietate omnium animos imbuerat, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Insīdo</text:span>, sēdi, sessum, 3.:<text:line-break/>1. <text:span text:style-name="Fraktur">i allm.:</text:span> <text:span text:style-name="T5">intr.</text:span> <text:span text:style-name="Fraktur">med</text:span> <text:span text:style-name="T5">dat.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig på</text:span></text:span><text:span text:style-name="Fraktur"> (fast i) ngt;</text:span> <text:span text:style-name="T5">trans.</text:span> = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">taga plats på -, besätta:</text:span></text:span> quum in locis semen insedit, rapit omnem fere cibum ad sese, C.; currum, Enn. ap. Varr.; vapor Apuliæ <text:span text:style-name="Fraktur">(lägger sig öfwer),</text:span> Hor.; deus (Amor) Elissæ <text:span text:style-name="Fraktur">(i hennes knä);</text:span> apes floribus i-unt, Vg.; digiti membris i-unt <text:span text:style-name="Fraktur">(tryckas in i),</text:span> Ov.; fastigio Capitolii insedit examen apum; aram i-rat (supplex); i-sum est diris avibus Capitolium, T.<text:line-break/>2. <text:span text:style-name="Fraktur">i militärisk mening: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fatta posto;</text:span></text:span> <text:span text:style-name="T5">trans.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">besätta, intaga:</text:span></text:span> silvis, Vg.; transitum; saltus; tumulos; montibus i-sis, L.; arcem milite insedit; juga; campum i-erat hostis; Alpibus i-sis, T.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bosätta sig; taga till boning:</text:span></text:span> agris Etruscis gens Lydia, Vg.; agros; insulam, T.<text:line-break/>4. <text:span text:style-name="Fraktur">oeg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fästa sig</text:span></text:span><text:span text:style-name="Fraktur"> i ngns sinne, minne:</text:span> oratio in animo, in memoria alicujus penitus insedit; cogitatio, furor mentis in venis medullisque, C.; memoriæ verba i-unt, Qu.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Insēdābĭlĭter</text:span>, <text:span text:style-name="T5">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Utan ro:</text:span></text:span> Lucr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Insĭdiæ</text:span>, ārum, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bakhåll,</text:span></text:span><text:span text:style-name="Fraktur"> i eg. och oeg. uttryck, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">försåt:</text:span></text:span> esse <text:span text:style-name="Fraktur">(ligga)</text:span> in i-is, Ter.; alicui i-as facere, ponere <text:span text:style-name="Fraktur">(ställa, lägga försåt),</text:span> C., Cs., N.; collocare, struere, tendere, comparare; milites in i-is locare; i-is, per i-as circumvenire, interficere alqm, C., Cs.; ex i-is <text:span text:style-name="Fraktur">(från = genom)</text:span> interire; paci, quæ nihil habitura sit i-arum, semper est consulendum; ex i-is, de i-is agere alqd; occultiores i-æ, quæ latent in simulatione officii; aures i-is capere; compositæ orationis i-is fidem alicujus attentare, C.; i-as intrare <text:span text:style-name="Fraktur">(i bakhåll);</text:span> latere in i-is; ex i-<text:soft-page-break/>is consurgere, adoriri alqm, Cs.; in i-as inducere <text:span text:style-name="Fraktur">(locka i försåt),</text:span> N.; i-as parare alicui; undique simul ex i-is invaditur, Sa.; partem militum subsidere in i-is jussit; hostes studio sequendi - trahuntur ad locum i-arum; ex i-is exoriuntur, concurrunt milites; in i-as præcipitant <text:span text:style-name="Fraktur">(falla i),</text:span> L.; tutus ab i-is, Hor.; per i-as iter est; i-is petere alqm, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Insĭdior</text:span>, 1.: <text:span text:style-name="T5">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ligga i bakhåll, ställa försåt för</text:span></text:span><text:span text:style-name="Fraktur"> någon</text:span> (<text:span text:style-name="T5">alicui, alicui rei</text:span>), <text:span text:style-name="Fraktur"><text:span text:style-name="T1">lura</text:span></text:span><text:span text:style-name="Fraktur"> (passa) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">på</text:span></text:span><text:span text:style-name="Fraktur"> -, i eg. och oeg. uttryck: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">stämpla emot</text:span></text:span><text:span text:style-name="Fraktur"> -:</text:span> sica Pompejo; somno, bonis alicujus; (oratori auditor) i-atur et observat ɔ: <text:span text:style-name="Fraktur">söker att uppfånga oriktigheter, ”stockar ord”,</text:span> C.; alicui, Sa., Cs.; Piræeo i-ri (ɔ: <text:span text:style-name="Fraktur">lura på att bemäktiga sig),</text:span> N.; tempori <text:span text:style-name="Fraktur">(tillfälle),</text:span> L.; lupus ovili, Vg.; hosti, Ov.; apris, Mt. <text:line-break/><text:span text:style-name="T2">Insĭdianter</text:span>, <text:span text:style-name="T5">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Försåtligt:</text:span></text:span> Js.<text:line-break/><text:span text:style-name="T2">Insĭdiātor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>:<text:line-break/><text:span text:style-name="T2">Insĭdiātrix</text:span>, īcis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Försåtställare;</text:span></text:span><text:span text:style-name="Fraktur"> som ligger i bakhåll, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">stämplar</text:span></text:span><text:span text:style-name="Fraktur"> emot, på (stråtröfware, lönnmördare):</text:span> viæ; in foro collocatus, C.; imperii, N.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Insĭdiōsus</text:span>, <text:span text:style-name="T5">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Försåtlig, arglistig, lömsk;</text:span></text:span><text:span text:style-name="Fraktur"> om saker: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">full af försåt, osäker, farlig:</text:span></text:span> apertis inimicis obsistere, i-is amicis non credere; i-a simulatio; bellum tantum et tam i-um, C.; leno, Hor.; verba; poculum; limen, Ov.; condicio, Pn.; latro, Mt.; loca, Jct.<text:line-break/><text:span text:style-name="T2">Insĭdiōse</text:span>, <text:span text:style-name="T5">Adv.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Försåtligt:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Obsĭdeo</text:span>, (sēdi, sessum), 2.:<text:line-break/>I. <text:span text:style-name="T5">intr.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta för</text:span></text:span><text:span text:style-name="Fraktur"> (i wägen för, framför); </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">sitta på wakt, sitta och wänta:</text:span></text:span> certum est domi o-re, donec redierit, Ter.<text:line-break/>II. <text:span text:style-name="T5">trans.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hålla besatt, intaga, upptaga</text:span></text:span><text:span text:style-name="Fraktur"> en plats:</text:span> aram, Pt.; Apollo Delphicus umbilicum terræ o-et; omnis locus o-etur corporibus, C.<text:line-break/>2. <text:span text:style-name="Fraktur">i militärisk mening:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ligga framför</text:span></text:span><text:span text:style-name="Fraktur"> en ort, för att hindra tillförsel l. undsättning, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">belägra, blockera:</text:span></text:span> urbem, C., Cs.; Capitolium a Gallis o-sum est, C.; turrim; oppidum, Sa.; clausi ab hostibus o-bantur, N.; o-sam Trojam accendit, Hor.; Mutinam, Ov.; filium principis, T.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hålla besatt, beherrska, innesluta:</text:span></text:span> arcem Syracusis munierat Dionysius ad urbem o-dam, N.; Italiam præsidiis o.; quoniam superum mare o-etur, infero navigabimus; senatum armis; alqm ferro, metu, C.; vias, Cs.; loca armatis hominibus; armis o-sus teneor, Sa.<text:line-break/>3. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägra, upptaga:</text:span></text:span> pericula o-ent alqm; tribunatus afflictus et o-sus; tempus alicujus o., C.; corpus frigore o-sum <text:span text:style-name="Fraktur">(gripen af -),</text:span> Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lura på:</text:span></text:span> stuprum, C.<text:line-break/>c. palude o-sa <text:span text:style-name="Fraktur">(omslutna)</text:span> Trachas, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Obsīdo</text:span>, sēdi, sessum, 3.: <text:span text:style-name="Fraktur">(börja att) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägra, besätta, taga i besittning:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i eg. men.:</text:span> domus o-sa, C.; pontem o-unt, Sa.; o-so Scipione, Cs.; Italos fines, Vg.<text:line-break/>b. <text:span text:style-name="Fraktur">bildl.:</text:span> is, qui audit, jam ab oratore o-sus (ɔ: <text:span text:style-name="Fraktur">wunnen)</text:span> est; dictatura vim regiæ potestatis o-rat, C.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">Obses</text:span>, ĭdis, <text:span text:style-name="T5">c.</text:span>: <text:span text:style-name="Fraktur">som med sin person answarar för ngt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gislan, underpant</text:span></text:span><text:span text:style-name="Fraktur"> för wissa förbindelsers uppfyllande:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> alicui imperare <text:span text:style-name="Fraktur">(affordra)</text:span> o-des, C.; o-des dedere alicui, Sa.; o-des poscere, extorquere, dare, mittere, accipere, habere ab aliquo; dare alicui alqm o-is loco, Cs.; alqm o-em <text:span text:style-name="Fraktur">(som gislan)</text:span> retinere; o-em esse alicujus rei <text:span text:style-name="Fraktur">(med sin person answara för ngt),</text:span> N.; Cloelia virgo una ex o-bus; o-des deposcere, dedere, L.; me accepta o-e, Ov.; o-des accipere, exigere, T.<text:line-break/>b. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Underpant:</text:span></text:span> Stalenus hanc damnationem o-em dederat Balbo; habet a M. Cælio resp. duas accusationes vel o-des periculi vel pignora voluntatis; habemus a Cæsare hanc sententiam (quam dixit in Catilinarios) tamquam o-em, C. <text:line-break/><text:span text:style-name="T2">Obsĭdātus</text:span>, us, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">medelst </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">gislan</text:span></text:span><text:span text:style-name="Fraktur"> gifwen säkerhet:</text:span> Amm.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Obsessio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägring:</text:span></text:span> templorum, C.; urbis, Cs.<text:line-break/><text:span text:style-name="T2">Obsessor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>:<text:line-break/>a. <text:span text:style-name="Fraktur">som håller något besatt, wistas på ett ställe:</text:span> fori, Pt.; aquarum, Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägrare, -rande:</text:span></text:span> curiæ, C.; urbis, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Obsĭdio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägring, blockering:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i eg. men.:</text:span> urbes partim vi, partim o-e cepit, C.; o-e premere alqm; alqm in o-e habere, Cs.; alqm o-e claudere; in o-e esse, teneri, N., L.: o-e liberare, Cs., N., L.; o-e eximere, L.; o-em solvere <text:span text:style-name="Fraktur">(upphäfwa),</text:span> L.; o. erat magis, quam oppugnatio, L. (XXI. 8.); o-e urguere, Vg.<text:line-break/>b. <text:span text:style-name="Fraktur">oeg. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Nöd, fara:</text:span></text:span> feneratores ex o-e exemit; remp. o-e liberare, C.<text:line-break/>2. <text:span text:style-name="Fraktur">egenskap af </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gislan, fångenskap:</text:span></text:span> Parthorum <text:span text:style-name="Fraktur">(hos P.)</text:span> o., Js. <text:line-break/><text:span text:style-name="T2">Obsĭdiōnālis</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">belägrings-, som har afseende på, anwändes wid belägring:</text:span> corona <text:span text:style-name="Fraktur">(hederskrans åt den, som befriat en här från belägring),</text:span> L.; machinæ, Amm.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Obsĭdior</text:span>, 1.: <text:span text:style-name="T5">Dep.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägra, lura på:</text:span></text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Obsĭdium</text:span>, i, <text:span text:style-name="T5">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Belägring:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> facere, Pt.; o-o urgere; circumdare, subigere; o-um exsolvere, T.<text:line-break/>b. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Försåt, fara:</text:span></text:span> Pt., Col.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gislan,</text:span></text:span><text:span text:style-name="Fraktur"> medelst gislan gifwen säkerhet:</text:span> Meherdates o-o nobis datus, T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Persĕdeo</text:span> <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T2">Persĭdeo</text:span>, sēdi, sessum, 2.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Länge sitta, blifwa sittande:</text:span></text:span> in equo, L.; apud alqm, Sen.; pruina, Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Persīdo</text:span>, sēdi, sessum, 3.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig</text:span></text:span><text:span text:style-name="Fraktur"> på ngt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">tränga igenom:</text:span></text:span> humor aquai, Lucr.; frigidus imber ad vivum altius p-edit, Vg.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Possĭdeo</text:span>, (sēdi, sessum), 2.: <text:span text:style-name="Fraktur">(jfr</text:span> positus <text:span text:style-name="Fraktur">af</text:span> po- <text:span text:style-name="Fraktur">och</text:span> sino):<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besitta,</text:span></text:span><text:span text:style-name="Fraktur"> i juridisk men., med l. utan egande rätt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">innehafwa</text:span></text:span><text:span text:style-name="Fraktur"> (jfr</text:span> possessio), <text:span text:style-name="Fraktur">eg. om jord, fastighet:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> agri p-entur ab aliquo; amplissimam pecuniam, C.; agros latissimos feracissimosque, Cs.; non p-entem multa vocaveris recte beatum, Hor.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besitta</text:span></text:span><text:span text:style-name="Fraktur"> utan l. med omtwistad eganderätt:</text:span> ex edicto bona p., C.; <text:soft-page-break/>lex lata est, ne quis plus quingenta agri (publici) p-ret, L. (VI. 35.); <text:span text:style-name="Fraktur">jfr</text:span> Dig. XLII. II. 1. <text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hålla besatt</text:span></text:span><text:span text:style-name="Fraktur"> (med wåld, krigsstyrka):</text:span> forum armatis catervis, C.; partem finitimi agri per vim occupatam p., Cs.<text:line-break/>3. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besitta, hafwa, ega, beherrska:</text:span></text:span> plus artis, quam fidei in se p-et (homo); popina te p-et; inverecundum animi ingenium p.; magnam p-et religionem maternus paternusque sanguis, C.; lubido p-et alqm, Sa.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Possīdo</text:span>, sēdi, sessum, 3.:<text:line-break/>1. <text:span text:style-name="Fraktur">i juridisk mening: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Taga i besittning, komma i besittning af:</text:span></text:span> bona sine testamento, C.; locum p-it, Lucr.; ager (publicus) injuriā p.; regnum usu p-rat, L.; illam partem Numidiæ Adherbal p-rat, Sa.; non p-rat alter latius, Ov.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besätta</text:span></text:span><text:span text:style-name="Fraktur"> (med wåld):</text:span> agros armis, Cs.; oppida vi et armis, L.; ipso transitu p-sa (est) Vicetia, T.<text:line-break/>3. <text:span text:style-name="Fraktur">i allm. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Taga i besittning, intaga, bemäktiga sig, få i sitt wåld, göra sig till herre öfwer, besätta:</text:span></text:span> totum hominem totamque ejus p-rat præturam, C.; possedit cetera pontus; Herse medium thalamum p-rat, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Possessio</text:span>, ōnis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besittning:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">i abstract mening = besittande, innehafwande (med l. utan egande rätt,</text:span> dominium, Dig. XLII. II. 1.: p. appellata est a sedibus quasi positio, quia naturaliter tenetur ab eo, qui ei insistit): in bonorum p-e esse, permanere; annorum p-es movere; p. permansit alicui; prætor dat <text:span text:style-name="Fraktur">(tilldömer)</text:span> p-em; p-em rei usurpare, recuperare; alqd in p-e retinere; p-e cedere, depelli, deturbari, demoveri, dejici, C.; liberam rei p-em tradere alicui; perpetua p., Cs.<text:line-break/>2. <text:span text:style-name="Fraktur">i concret mening: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Besittning,</text:span></text:span><text:span text:style-name="Fraktur"> i synn. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">fastighet, gods;</text:span></text:span><text:span text:style-name="Fraktur"> (herrskares) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">land:</text:span></text:span> p-es urbanæ, rusticæ; æstimare p-es; paternas p-es tenere, augere; habere pretiosas p-es; iter facere per alicujus p-em; irruere in alienas p-es; involare in p-em vacuam et caducam, C.; ex p-bus solvere æs alienum, Sa.; cur in suas p-es veniret (Cæsar, quæsivit Ariovistus), Cs. <text:line-break/><text:span text:style-name="T2">Possessiuncŭla</text:span>, æ, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Liten besittning:</text:span></text:span> C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Possessīvus</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">som utmärker egendom l. egare, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Possessiv:</text:span></text:span> nomen, pronomen, Charis. 128. 159.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Possessor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>: <text:line-break/>(<text:span text:style-name="T2">Possestrix</text:span>, īcis, <text:span text:style-name="T5">f.</text:span>: Afr.): <text:span text:style-name="Fraktur">som tagit i besittning, besitter, med l. utan egande rätt, fastighet l. sak i allm., </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Innehafware</text:span></text:span><text:span text:style-name="Fraktur"> (brukare):</text:span> legem agrariam tentare, ut suis sedibus pellantur p-es; bonorum; invidiæ et pestilentiæ p-es <text:span text:style-name="Fraktur">(innehafware af gods, som blott skänka afund och osund luft),</text:span> C.; agros (publicos) ab injustis p-bus liberos habere, L.; agelli, Vg.; valeat p. <text:span text:style-name="Fraktur">(egaren)</text:span> oportet, si comportatis rebus bene cogitat uti, Hor.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Præsĭdeo</text:span>, sēdi, (sessum), 2.:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Innehafwa försätet, wara föredragande, föra ordet</text:span></text:span><text:span text:style-name="Fraktur"> i en domstol, præsidera i annan församling:</text:span> consules in curia, C.; comitiis <text:span text:style-name="Fraktur">(wid walmöte),</text:span> Pn.; sellā curuli; ludis, Su.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hålla wakt öfwer, skydda, wärna, förestå, styra</text:span></text:span><text:span text:style-name="Fraktur"> (med</text:span> <text:span text:style-name="T5">dat.;</text:span> <text:span text:style-name="Fraktur">hos </text:span><text:soft-page-break/><text:span text:style-name="Fraktur">senare</text:span> <text:span text:style-name="T5">acc.</text:span>):<text:line-break/>a. <text:span text:style-name="Fraktur">om en wakthafwande truppstyrka:</text:span> centuriones militesque judicio (Milonis) p-entes, C.; Italiam duæ classes p-bant, T.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Föra befälet, stå i spetsen för</text:span></text:span><text:span text:style-name="Fraktur"> en här, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">styra, förestå</text:span></text:span><text:span text:style-name="Fraktur"> en provins:</text:span> provinciæ, C.; in Piceno, Sa.; exercitum, T.; arci; itineri, Ct.<text:line-break/>c. <text:span text:style-name="Fraktur">om gudar: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Beskydda, beherrska:</text:span></text:span> dii patrii, qui huic urbi atque imperio p-etis, C.; Gradivus pater, Geticis qui p-et arvis, Vg.<text:line-break/>d. <text:span text:style-name="Fraktur">i allm.:</text:span> senatus orbi terrarum p-et <text:span text:style-name="Fraktur">(styr);</text:span> Gallia libertati communi et huic imperio semper p-edit, C.; rebus urbanis (Pompejus), Cs.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Præses</text:span>, ĭdis, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">som förestår, som råder öfwer, för ngt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Skyddande, herrskande:</text:span></text:span> locus p. <text:span text:style-name="Fraktur">(fristad),</text:span> Pt.; deus, Ov., T. - <text:span text:style-name="T5">Subst. c.</text:span>: <text:line-break/>1. <text:span text:style-name="Fraktur">som har försätet wid, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Ordförande:</text:span></text:span> publici consilii, L.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Föreståndare, beskyddare, beherrskare</text:span></text:span><text:span text:style-name="Fraktur"> (-</text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">inna):</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">i allm.:</text:span> senatus reip. custos, p., propugnator; tribunus libertatis p. et custos; Mercurius (palæstræ) p., C.; p. belli Tritonia virgo, Vg.; pinūs p. <text:span text:style-name="Fraktur">(skeppets förare);</text:span> p. rerum <text:span text:style-name="Fraktur">(werldens),</text:span> Ov.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Höfding</text:span></text:span><text:span text:style-name="Fraktur"> öfwer en provins:</text:span> provinciæ, L.; <text:span text:style-name="Fraktur">absol.,</text:span> T., Su.<text:line-break/><text:span text:style-name="T2">Præsĭdālis</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">provinshöfding tillhörig, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Höfdinge-:</text:span></text:span> jus, Treb.; officium, Jct.<text:line-break/><text:span text:style-name="T2">Præsĭdātus</text:span>, us, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Höfdingedöme, -embete:</text:span></text:span> regere, administrare, Vop., Treb.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Præsĭdium</text:span>, i, <text:span text:style-name="T5">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">militärisk </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Betäckning, wakt, skydd:</text:span></text:span> legiones duæ - p-o impedimentis erant, Cs.; p. agitare, Sa.; esse in p-o <text:span text:style-name="Fraktur">(på wakt),</text:span> ne - -, N.<text:line-break/>2. <text:span text:style-name="Fraktur">concret: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Betäckning</text:span></text:span><text:span text:style-name="Fraktur"> = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">skyddswakt, -trupp, besättning,</text:span></text:span><text:span text:style-name="Fraktur"> som ligger framför, förswarar en ort l. sak i allm.:</text:span> urbem, coloniam p-is munire, confirmare; p. loco deducere, C.; p-a disponere; p-o montem occupare, firmare; p-a urbibus imponere <text:span text:style-name="Fraktur">(inlägga, förlägga);</text:span> p-a arcessere <text:span text:style-name="Fraktur">(draga till sig),</text:span> Sa.; p-a constituere; locum p-is tenere; relinquere, Cs.; p. ei dedit, ut tuto eo, quo vellet, perveniret; p. mittere alicui; venire sine p-o; p. ponere alicubi; p. <text:span text:style-name="Fraktur">(besättning)</text:span> pellere, depellere, interficere, N.; p. regale loco dejecit, Hor.<text:line-break/>3. <text:span text:style-name="Fraktur">ställe, som genom byggnader l. besättning tjenar ss. skydd, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Fästning</text:span></text:span><text:span text:style-name="Fraktur"> (garnison), </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">läger; förswars-, anfallslinjer, skans, förskansning, waktort, -post:</text:span></text:span> in alicujus p-is esse <text:span text:style-name="Fraktur">(läger),</text:span> C., Cs.; p. occupare; milites in p-is disponere; non erat oppidum, non p., Cs.; armatos in p-is collocare; injussu imperatoris de p-o decedere; p. relinquere, C.; recipere se intra sua p-a; ex p-is alicujus effugere, N.; in p-is esse, Sa.; in p-o relinqui; p. tutari; urbem p-is sæpiunt, L.<text:line-break/>4. <text:span text:style-name="Fraktur">oeg., i abstr. och concret men.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Wärn, skydd, wakt; skydds-, hjelpmedel; skyddswakt:</text:span></text:span> omnes urbanæ res latent in p-o ac tutela bellicæ virtutis; ubi libido dominatur, leve innocentiæ p. est; qui mortem non timet, magnum sibi p. ad beatam vitam comparat; nullis p-is sæptus; necessaria vitæ p-a debentur (propinquis) maxime; Gracchi omnibus vel naturæ vel doctrinæ p-is ad dicendum parati; p. salutis, pudoris <text:span text:style-name="Fraktur">(för lifwet, äran);</text:span> petere p. ex aliqua re, C.; p. in aliquo (positum) putare; legis p.; generis <text:span text:style-name="Fraktur">(slägtens)</text:span> p.; p-a parare; p-a amicorum circum se habere, Sa.; spem p-i offerre; p. in fuga sibi ponere; p-o literarum, Cs.; p. ferre alicui, Cs., L.; non satis est p-i in aliquo, N.; et p. et dulce decus meum (Mæcenas); p. mæstis reis, <text:soft-page-break/>Hor. <text:line-break/><text:span text:style-name="T2">Præsĭdiārius</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Till skydd, betäckning tjenande:</text:span></text:span> milites, L.; palmes, Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Prōsĕda</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">(jfr</text:span> prostituo): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Offentlig sköka:</text:span></text:span> Pt.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsĭdeo</text:span>, sēdi, sessum, 2.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta stilla, fast; sitta, stanna qwar; hwila:</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">eg.:</text:span> in villa, C.; in ara; in tergo equi; monte suo r-ens, Ov.<text:line-break/>2. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>a. ferias r. = <text:span text:style-name="Fraktur">fira hwilodag,</text:span> C.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hwila, throna:</text:span></text:span> in ejus nutu r-bat auctoritas, C.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stanna, finnas qwar, öfwer, öfrig:</text:span></text:span> suspicio in aliquo; nullas reliquias simultatis r-isse -; nullus sensus in corpore mortuo; amor in te erga me; periculum in venis reip.; culpa rei in te, C.; in consilio pristinæ virtutis memoria, Cs.; ira ex certamine, L.<text:line-break/>d. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Hwila</text:span></text:span><text:span text:style-name="Fraktur"> = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">bero, grundas på:</text:span></text:span> spes in te, C.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsīdo</text:span>, sēdi, 3.:<text:line-break/>I. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig ned, fast; stanna, rasta:</text:span></text:span> r-amus, si placet; ita negligens (erat), ut - r-ret, deinde spatiaretur; in oppido, C.; resedit, ut si vellet quiescere, N.; lassa r-edit; solio subnixa resedit, Vg.; fessa humi; orba inter natos (Niobe); medio rex agmine, in solio r-edit, Ov.; cruribus pelles, Hor.<text:line-break/>II. <text:span text:style-name="Fraktur">oeg.:</text:span><text:line-break/>1. <text:span text:style-name="Fraktur">om personer:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bosätta sig:</text:span></text:span> in arvis, Vg. <text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lugna sig, återgå till lydnad:</text:span></text:span> Brigantes - rebelles - resedēre, T.<text:line-break/>2. <text:span text:style-name="Fraktur">om saker:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sjunka, sänka sig:</text:span></text:span> montes, C.; aqua, Ov.: flamma, Ov., T.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta sig</text:span></text:span><text:span text:style-name="Fraktur"> = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">lägga, lugna sig:</text:span></text:span> tumor animi; furens petulantia; impetus, C.; mentes a bello r-runt, Cs.; terror; iræ, L.; flatus, Vg.; bellum r-edit, Hor.; dolor, Pn. ep.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsēdo</text:span>, 1.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Åter stilla:</text:span></text:span> morbum, Pn. <text:line-break/><text:span text:style-name="T2">Rĕsēda</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">en wäxt, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Reseda:</text:span></text:span> r. discutit inflammationes, Pn. (XXVII. 106.).</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕses</text:span>, ĭdis, <text:span text:style-name="T5">A.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Som sitter, står, blifwit stilla, stannat qwar, hwilat sig:</text:span></text:span> plebs in urbe r., L.; aqua r. <text:span text:style-name="Fraktur">(stillastående);</text:span> caseus in corpore r. <text:span text:style-name="Fraktur">(osmält),</text:span> Varr.; r-des jubemur rursus inire fretum, Ov.<text:line-break/>2. <text:span text:style-name="Fraktur">serskildt:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lat, owerksam, feg, okrigisk:</text:span></text:span> r-em terere tempus; clamorem pugnantium exaudimus r-des ac segnes, L.; r-des viros ad arma movere, Vg.<text:line-break/>b. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lugn, likgiltig:</text:span></text:span> novo prævertere amore jam pridem r-des animos, Vg.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Rĕsĭduus</text:span>, <text:span text:style-name="T5">A.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Öfrig, qwarblifwen</text:span></text:span><text:span text:style-name="Fraktur"> (ifrån, efter ngt):</text:span> odium; sollicitudo, C.; r-æ bellorum iræ; r-æ prioris anni causæ, L. <text:line-break/>2. <text:span text:style-name="Fraktur">om penningar: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Innestående, resterande:</text:span></text:span> pecuniis r-is exactis, L. <text:line-break/>residuum, i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">rest:</text:span> Jct.<text:line-break/>3. = reses, C. ap. Fs.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">Subsīdo</text:span>, sēdi, sessum, 3.:<text:line-break/>1. <text:span text:style-name="Fraktur">eg.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sätta, huka, luta sig, sjunka ned, under, för</text:span></text:span><text:span text:style-name="Fraktur"> något (med</text:span> <text:span text:style-name="T5">dat.</text:span>): s-ite, quasi solent triarii <text:span text:style-name="Fraktur">(tredje</text:span> acies <text:span text:style-name="Fraktur">af den äldre romerska härställningen),</text:span> Pt. ap. Varr. <text:span text:style-name="Fraktur">(jfr</text:span> L. VIII. 8—10. - triarii - genu dextro innixi nutum consulis ad consurgendum exspectabant, c. 9. fin.); Hispani adversus emissa tela s-bant, L.; in poplite s. <text:span text:style-name="Fraktur">(sjunka ned),</text:span> Vg.; in ara ante fores, Ov. - equa mari, tigris cervis s-it <text:span text:style-name="Fraktur">(parar sig med -),</text:span> Lucr., Hor.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Stanna</text:span></text:span><text:span text:style-name="Fraktur"> och wänta, inwänta, lura på ngn:</text:span><text:line-break/>a. <text:span text:style-name="T5">intr.</text:span>: s. et exspectare; in ipsa via; cur non ante occurrit Milo, ne in villa resideret Clodius, nec subsedit, quo ille venturus esset?, C.; calones in castris, Cs.; in insidiis s., L.<text:line-break/>b. <text:span text:style-name="T5">trans.</text:span> = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lura på, möta</text:span></text:span><text:span text:style-name="Fraktur"> ngns </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">anfall</text:span></text:span> (<text:span text:style-name="T5">syn.</text:span> subsisto, excipio): leonem, Amm.<text:line-break/>3. <text:span text:style-name="Fraktur">wara reserv för, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">(hämna,</text:span></text:span> ἐφεδρεύειν): devictam Asiam subsedit adulter (Aegisthus Agamemnona obtruncans), Vg.<text:line-break/>4. <text:span text:style-name="Fraktur">om sakliga subject: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sjunka, sänka, lägga sig:</text:span></text:span><text:line-break/>a. <text:span text:style-name="Fraktur">concreta:</text:span> fæx, Lucr.; navicula in Nilo <text:span text:style-name="Fraktur">(satte sig fast),</text:span> L.; galeā imā <text:span text:style-name="Fraktur">(i bottnen af hjelmen)</text:span> s-edit sors, Vg.; valles; venti; mare, Ov.; montes s-ent, Luc.<text:line-break/>b. <text:span text:style-name="Fraktur">abstracta:</text:span> impetus oratoris, Qu.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subsessa</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bakhåll:</text:span></text:span> Veg. <text:line-break/><text:span text:style-name="T2">Subsessor</text:span>, ōris, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">som lurar på ngn, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Jägare:</text:span></text:span> Petr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subsīdentia</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Bottensats:</text:span></text:span> Vitr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Subsĭdium</text:span>, i, <text:span text:style-name="T5">n.</text:span>:<text:line-break/>1. <text:span text:style-name="Fraktur">sittande i beredskap att bistå en stridande; ställning l. tjenst såsom </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Reserv, bakhåll, undsättning</text:span></text:span><text:span text:style-name="Fraktur"> (jfr</text:span> subsīdo 1. 2): in s-is <text:span text:style-name="Fraktur">(i bakhåll, såsom eftertrupp, reserv)</text:span> collocavit veteranas cohortes, Sa.; s-o <text:span text:style-name="Fraktur">(till undsättning)</text:span> alicui proficisci, venire, ire; s-o milites mittere, adducere, C., Cs., N., L.; s. ferre alicui, Cs.<text:line-break/>2. <text:span text:style-name="Fraktur">i concret mening: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Reserv</text:span></text:span> [<text:span text:style-name="Fraktur">enkannerligen om den eftersta linien</text:span> (novissima acies) <text:span text:style-name="Fraktur">af en härställning; enl. det äldre romerska bruket</text:span> = triarii, <text:span text:style-name="Fraktur">se</text:span> Liv. VIII. 8-10); <text:span text:style-name="Fraktur"><text:span text:style-name="T1">eftertrupp;</text:span></text:span><text:span text:style-name="Fraktur"> äfwen i allm. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">undsättning, undsättningstrupper:</text:span></text:span> s-a collocare, Cs.; locare, L.; triplicia s-a, Sa.; s-um, s-a submittere alicui, Cs.; in mediam primum aciem illati - ad s-a Afrorum pervenerunt; subtracta s-a mittunt ad castra oppugnanda, L. <text:span text:style-name="Fraktur">(jfr</text:span> V. 38); præcipuum robur <text:span text:style-name="Fraktur">(kärnen af romerska hären)</text:span> Rhenum juxta, commune in Germanos Gallosque s., octo legiones, T.<text:line-break/>3. <text:span text:style-name="Fraktur">oeg. = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Undsättning, hjelp, stöd,</text:span></text:span><text:span text:style-name="Fraktur"> som ngn har i bakhåll, sparar till nödfall; (sista) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">tillflykt, fristad, hjelpmedel, utwäg:</text:span></text:span> s. generis, <text:span text:style-name="Fraktur">slägtens hopp - om en son -;</text:span> s-a industriæ et instrumenta virtutis; s. senectutis in eorum, qui consultum veniant, multitudine ponere; s. bellissimum existimo esse senectuti otium; sibi s. ad omnes vitæ status parare, comparare, C.; his difficultatibus duæ res erant s-o; s-a inopiæ <text:span text:style-name="Fraktur">(emot brist),</text:span> Cs.; fidissimum annonæ s., L.; quod aliud s. (militibus), si imperatorem sprevissent?; id s. sæpe habuerat; vix modicis navigiis (<text:span text:style-name="T5">dat.</text:span>) pauca s-a <text:span text:style-name="Fraktur">(tillflyktsorter, hamnar),</text:span> T.<text:line-break/><text:span text:style-name="T2">Subsĭdiālis</text:span> (Amm.) <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T2">Subsĭdiārius</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur">som tjenar, är bestämd till reserv, undsättning: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Reserv</text:span></text:span><text:span text:style-name="Fraktur">-, </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">undsättnings-:</text:span></text:span> cohortes, Cs., L., T.<text:line-break/><text:soft-page-break/><text:span text:style-name="T2">Subsĭdiārii</text:span>, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Reservsoldater, -trupper:</text:span></text:span> L. - palmes s-ius <text:span text:style-name="Fraktur">(som sparas, ej afqwistas),</text:span> Col.<text:line-break/><text:span text:style-name="T2">Subsĭdior</text:span>, 1.: <text:span text:style-name="T5">Dep.</text:span>: <text:span text:style-name="Fraktur">tjena såsom (undsättning) reserv, wid reserven:</text:span> Cs.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sŭpersĕdeo</text:span> <text:span text:style-name="Fraktur">l.</text:span><text:line-break/><text:span text:style-name="T2">Sŭpersĭdeo</text:span>, sēdi, sessum, 2.:<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sitta ofwanpå:</text:span></text:span> aquila tentorio, Sn. <text:line-break/>2. <text:span text:style-name="Fraktur">(sätta sig öfwer) </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Afstå ifrån, åsidosätta, afhålla sig ifrån, ej bry sig om,</text:span></text:span><text:span text:style-name="Fraktur"> constr. med</text:span> <text:span text:style-name="T5">abl.</text:span> <text:span text:style-name="Fraktur">(sällan</text:span> <text:span text:style-name="T5">acc.</text:span> <text:span text:style-name="Fraktur">l.</text:span> <text:span text:style-name="T5">dat.</text:span>) <text:span text:style-name="Fraktur">eller med</text:span> <text:span text:style-name="T5">inf.</text:span>: s-de <text:span text:style-name="Fraktur">(håll inne med)</text:span> istis verbis, Pt.; labore; narratione: causa non visa est supersedenda (ad Her.), C.; Cæsar proelio <text:span text:style-name="Fraktur">(undwika);</text:span> pugnæ (Ht.), Cs.; litibus, delectu s.; loqui, certare, L.; ea in vulgus edita ejus (Senecæ) verbis invertere s-o, T.</text:p>
   <text:p text:style-name="P1">Sedes <text:span text:style-name="Fraktur">se</text:span> Sedeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ēdētāni, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i Hispania.</text:span> <text:line-break/>Sēdētānia, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">deras land.</text:span></text:p>
   <text:p text:style-name="P1">Sediculum <text:span text:style-name="Fraktur">se</text:span> Sedeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ēdĭgĭtus, i,<text:span text:style-name="T5"> m.</text:span>: <text:span text:style-name="Fraktur">rom. binamn, eg. = sexfingrad af</text:span> sex <text:span text:style-name="Fraktur">och</text:span> digitus.</text:p>
   <text:p text:style-name="P1">Sedile, Sedimentum <text:span text:style-name="Fraktur">se</text:span> Sedeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sēdĭtio,</text:span> ōnis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">(af</text:span> sē = <text:span text:style-name="Fraktur">afsides, åtskils och</text:span> ire?; <text:span text:style-name="Fraktur">jfr</text:span> secessio):<text:line-break/>1. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Borgerlig twedrägt; partistrid, parti; uppror, upplopp; twist, twedrägt, söndring</text:span></text:span><text:span text:style-name="Fraktur"> mellan medborgare, mellan regering och borgare, soldater och befäl; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">borgaretwist:</text:span></text:span> Solon capite sanxit, si qui in s-e non alterutrius partis fuisset; s-em facere, reprimere; multæ sæpe s-es e re publica et jure factæ sunt; etsi omnes molestæ s-es, justæ tamen nonnullæ et prope necessariæ; s. militum sedata, C.; orta s., Cs.; s-em conflare, concitare, commovere, afferre, lenire, exstinguere; multitudo Henetûm - s-e e Paphlagonia pulsi; nullo loco deest s-is voluntarius comes; ne prædictum negetis, Patres conscripti, adest ingens s., L.; in magno populo coorta est s.; s-e potens, Vg.; s-e, dolis, scelere atque libidine et ira Iliacos muros intra peccatur et extra, Hor.; coeptare; comprimere; componere s-em; s. crebrescit, exardescit, deflagrat, T.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Upprorisk folkmassa:</text:span></text:span> incursio, C. Clu. c. 36. <text:line-break/>3. <text:span text:style-name="Fraktur">i allm.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Twedrägt, uppror, oenighet:</text:span></text:span> filiam dare adulescenti in s-em, Ter.; domestica <text:span text:style-name="Fraktur">(huslig),</text:span> L.; iracundia est animi s., C. <text:line-break/><text:span text:style-name="T2">Sēdĭtiōsus</text:span>, <text:span text:style-name="T5">A.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Upprorisk, orolig:</text:span></text:span> civis s. et turbulentus; contio; vita, C.; voces, Ct.; oratio, Cs.; vox, L.; civis s-ior, Qu.<text:line-break/><text:span text:style-name="T2">Sēdĭtiōse</text:span>, <text:span text:style-name="T5">Adv.</text:span>: p. tr. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Upproriskt, i upprorisk afsigt:</text:span></text:span> contiones s. concitatæ; dicere s-sime, C.; agere s-ius, T.</text:p>
   <text:p text:style-name="P1">Sedo <text:span text:style-name="Fraktur">se</text:span> Sedeo.<text:line-break/>Seduct . . . <text:span text:style-name="Fraktur">se</text:span> Seduco, Duco.<text:line-break/>Sedul . . . <text:span text:style-name="Fraktur">se</text:span> Sedeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕdum,</text:span> i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">en wäxt:</text:span> Col.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>edūni, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">helvetiskt folkslag.</text:span> </text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>edusii, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">germaniskt folkslag.</text:span></text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T1">Sĕgĕs,</text:span> ĕtis, <text:span text:style-name="T5">f.</text:span>: [<text:span text:style-name="Fraktur">wäl af roten i</text:span> sĕro, sēvi <text:span text:style-name="Fraktur">(jfr</text:span> Seja), <text:span text:style-name="Fraktur">såsom</text:span> strāges <text:span text:style-name="Fraktur">af</text:span> strā <text:span text:style-name="Fraktur">i</text:span> sterno]:<text:line-break/>1. <text:span text:style-name="Fraktur">(utsäde) wäxande </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Gröda, säd:</text:span></text:span> frumentum in s-bus <text:span text:style-name="Fraktur">(på rot),</text:span> areis, horreis; s. spicis uberibus et crebris; lætæ s-tes, C.; s. matura, Cs.; in agro Tarquiniorum erat s. farris matura messi, L.; illa s. votis respondet agricolæ, bis quæ solem, bis frigora sensit; altæ s-tes; quid faciat lætas s-tes - canere; s. lini, Vg.; s-tes occare; s. sentit rubiginem, Hor.; ager fert s-tes, Ov.; multā curā sata producuntur ad s-em, Sen.; metere, Sil.; sola terræ s. imperatur (apud Germanos), T.<text:line-break/>2. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Sädesfält, teg:</text:span></text:span> s-tes fecundæ et uberes effundunt fruges et herbas, C.; probæ fruges in deteriorem s-em datæ, Acc. ap. C.; mittere cohortes frumentatum in proximas s-tes, Cs.; s-tes feraces, Hor.<text:line-break/>3. <text:span text:style-name="Fraktur">bildl.:</text:span><text:line-break/>a. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Utsäde</text:span></text:span><text:span text:style-name="Fraktur"> = orsak:</text:span> s. et materia gloriæ, C.; hæc s. ingratos tulit et feret omnibus annis, Hor.<text:line-break/>b. = <text:span text:style-name="Fraktur">gröda, skörd = </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Inkomst, nytta:</text:span></text:span> Ov., Juv.<text:line-break/>c. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Mängd, massa:</text:span></text:span> telorum, Vg.; virorum, Ov.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕgĕtia, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">sädens gudinna:</text:span> Varr.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕgesta, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">stad på Sicilien.</text:span> <text:line-break/>Sĕgestānus, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egestes, is, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">germaniskt personnamn (Arminii swärfar).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕgestīva, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">stadsnamn (i Spanien).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕgestre,</text:span> is, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T2">Sĕgestria</text:span>, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Omslag, täcke, hölje, duk,</text:span></text:span><text:span text:style-name="Fraktur"> som man kastar öfwer ngt l. höljer ngt i:</text:span> qui lecticas involvebant - s-as appellabant, Varr.; mercium s. <text:span text:style-name="Fraktur">(waxduk, pressenning),</text:span> Pn.; s-i involutus, Su.</text:p>
   <text:p text:style-name="P1">Segetia <text:span text:style-name="Fraktur">se</text:span> Seges.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egimundus, i, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">germaniskt personnamn (Segestis son).</text:span></text:p>
   <text:p text:style-name="P1">Segmen, Segment . . . <text:span text:style-name="Fraktur">se</text:span> Seco.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Segnis,</text:span> <text:span text:style-name="T5">A., Comp.</text:span> -ior (<text:span text:style-name="T5">Sup.</text:span> Ap.): <text:line-break/>1. <text:span text:style-name="Fraktur">om personer och deras rörelser, lynne, handlingar m. m.: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Loj, slapp, långsam, sen</text:span></text:span><text:span text:style-name="Fraktur"> i, till ngt; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">trög, sömnig, säflig, liknöjd</text:span></text:span> [<text:span text:style-name="Fraktur">mots.</text:span> vegetus, vigens, promptus <text:span text:style-name="Fraktur">(kry, pigg, rask),</text:span> navus, industrius; <text:span text:style-name="T5">syn.</text:span> ignavus, tardus]: ad imperandum; in labore s.; ad respondendum s-ior <text:span text:style-name="Fraktur">(mera sen, mindre rask),</text:span> C.; bonus tantummodo s-ior fit, ubi negligas, at malus improbior, Sa.; s-ores [<text:span text:style-name="Fraktur">mindre beslutsamme (partimän</text:span>)] castigat atque incitat, Cs.; ad persequendum, N.; s-es ac timidi; bellum haud s-ius erat; oppugnatio <text:span text:style-name="Fraktur">(lam);</text:span> audendo agendoque res Romana crevit, non his s-bus consiliis <text:span text:style-name="Fraktur">(slappa åtgerder),</text:span> quæ timidi cauta vocant; s. mora, mors; ad credendum s., L.; morbo; annis, Vg.; pes; Gratiæ s-es solvere nodum <text:span text:style-name="Fraktur">(sena att lösa),</text:span> Hor.; dextra, acta non s., Ov.; s. memoria, Sen.; animus, Pn.; indoles; inquies animo et occasionum haud s. <text:span text:style-name="Fraktur">(ej sen att begagna sig af -),</text:span> T. <text:line-break/>2. <text:span text:style-name="Fraktur">oeg., om saker:</text:span> campus <text:span text:style-name="Fraktur">(ofruktbart),</text:span> Vg.; tempus, L.; annus <text:span text:style-name="Fraktur">(i owerksamhet tillbragt),</text:span> Ov.; aqua <text:span text:style-name="Fraktur">(stillastående),</text:span> Ct.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Segnesco</text:span>, ĕre: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Slappas; taga af:</text:span></text:span> Cael.</text:p>
   <text:p text:style-name="P1"><text:soft-page-break/><text:span text:style-name="T2">Segnĭpes</text:span>, pĕdis, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">trögfotad häst:</text:span> Juv.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Segnĭter</text:span>, -ius, <text:span text:style-name="T5">Adv.</text:span> <text:line-break/>(segne, Amm.): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lojt, långsamt, trögt, slappt:</text:span></text:span> nihilo s-ius (ɔ: <text:span text:style-name="Fraktur">med oförminskad raskhet, energi)</text:span> perseveravit, N.; haud s. fortunā uti; s-ius agere, oppugnare, L.; s-ius <text:span text:style-name="Fraktur">(mindre lifligt)</text:span> irritant animos demissa per aures, quam quæ sunt oculis commissa fidelibus, Hor.; ire obviam - marito - haud s. <text:span text:style-name="Fraktur">(utan twekan l. dröjsmål),</text:span> T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Segnĭtia</text:span>, ae <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T2">Segnĭties</text:span>, ēi, <text:span text:style-name="T5">f.</text:span> <text:line-break/>(Segnĭtas, ātis, <text:span text:style-name="T5">f.</text:span>: C. <text:span text:style-name="Fraktur">enl.</text:span> Non.): <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Lojhet, slapphet, lätja, owerksamhet, liknöjdhet:</text:span></text:span> <text:line-break/>a. <text:span text:style-name="Fraktur">eg.:</text:span> s-es et socordia, Pt.; rudem esse in nostris poētis aut inertissimæ s-æ est aut fastidii delicatissimi; sine arrogantia gravis, sine s-a <text:span text:style-name="Fraktur">(slapphet)</text:span> verecundus <text:span text:style-name="Fraktur">(undsenlig),</text:span> C.; in s-e perstare, L.; quæ vos tam sera moratur s-es?, Vg.; quod erat s., vocabatur sapientia, T. - agri <text:span text:style-name="Fraktur">(ofruktbarhet),</text:span> Pn.; maris s. <text:span text:style-name="Fraktur">(windstilla),</text:span> T.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Persegnis</text:span>, <text:span text:style-name="T5">A.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Mycket långsam, slapp, matt:</text:span></text:span> proelium, L.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egobrīga <text:line-break/>(Segobria), ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">stad i Spanien.</text:span> <text:line-break/>Segobriensis, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egontiăci, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">folk i Britannien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egŏvax (vactis), <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">britanniskt namn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egovia, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">hispaniskt stadsnamn.</text:span></text:p>
   <text:p text:style-name="P1">Segrego, -gregus, Segrex <text:span text:style-name="Fraktur">se</text:span> Grex.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Segullum,</text:span> i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">tecken till tillwaro af guldstreck:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕgūsiāni <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/>Sĕgūsiāvi, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">folkslag i westra Gallien.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>egusio, ōnis, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">stad i norra Italien (Susa).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>eja, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">såddens gudinna (af</text:span> I. Sero): Mcb.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ejānus, i, <text:span text:style-name="T5">m.:</text:span> <text:span text:style-name="Fraktur">rom. cognomen i</text:span> gens Aelia. <text:line-break/>Sejāniānus, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1">Sejug . . ., Sejunct . . . <text:span text:style-name="Fraktur">se</text:span> Jugum.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ejus, i, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">rom. personnamn.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕlas,</text:span> <text:span text:style-name="T5">pl.</text:span> sela, <text:span text:style-name="T5">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur">ett slags luftsken:</text:span> Sen.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕlēnē, es, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn (såsom appell. = måne).</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T2">Sĕlēnītes</text:span>, ae, <text:span text:style-name="T5">m.</text:span> <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T2">Sĕlēnītis</text:span>, ĭdis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Marienglas</text:span></text:span><text:span text:style-name="Fraktur"> (ett slags sten, så kallad - månskenssten - af sin färg):</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕleucus, i, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">gr. personnamn, berömdt såsom namn för syriske konungar.</text:span> <text:line-break/>Sĕleucīa <text:span text:style-name="Fraktur">l.</text:span> <text:line-break/><text:soft-page-break/>Sĕleucēa, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">af Seleucus I. grundlagd stad wid Tigris.</text:span> <text:line-break/>Sĕleuciānus, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>elga, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">stad i Pisidien.</text:span> <text:line-break/>Selgĭcus, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1">Selibra <text:span text:style-name="Fraktur">se</text:span> Semi.<text:line-break/>Selĭgo <text:span text:style-name="Fraktur">se</text:span> Lĕgo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕlīnon,</text:span> i, <text:span text:style-name="T5">n.</text:span>: v. gr.: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Selleri</text:span></text:span><text:span text:style-name="Fraktur"> (lat.</text:span> apium): Ap.<text:line-break/><text:span text:style-name="T2">Sĕlīnŏīdĕs</text:span>, is, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">selleri-lik wäxt:</text:span> Pn.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕlīnus, untis, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">gr. stadsnamn (på Sicilien och i Cilicien).</text:span> <text:line-break/>Sĕlīnuntii, ōrum, <text:span text:style-name="T5">m.</text:span>: <text:span text:style-name="Fraktur">inwånare i S.</text:span> <text:line-break/>Sĕlīnūsius, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Seliquastrum,</text:span> i, <text:span text:style-name="T5">n.</text:span>: <text:span text:style-name="Fraktur">ett slags stol l. dyl.:</text:span> Varr. (l. l. V. 128).</text:p>
   <text:p text:style-name="P1">Sella <text:span text:style-name="Fraktur">med härledningar se</text:span> Sedeo.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ēlymbria, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">stad i Thracien.</text:span></text:p>
   <text:p text:style-name="P1">Sembella <text:span text:style-name="Fraktur">se</text:span> Semi.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sĕmel,</text:span> <text:span text:style-name="T5">Adv.</text:span>: <text:span text:style-name="Fraktur"><text:span text:style-name="T1">En gång</text:span></text:span><text:span text:style-name="Fraktur"> (med tonwigt på </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">en):</text:span></text:span><text:line-break/>1. <text:span text:style-name="Fraktur">= </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">En enda gång, blott en gång,</text:span></text:span><text:span text:style-name="Fraktur"> i mots. till flere gånger:</text:span> non plus quam s.; s. faciendum est aut certe non sæpe, C.; non s. hoc fecit, sed sæpius, N.; omnibus est calcanda s. via leti, Hor.<text:line-break/>2. = <text:span text:style-name="Fraktur"><text:span text:style-name="T1">Med en gång, med ett, en gång för alla:</text:span></text:span> iis s. a te ignotum esse oportet, C.; deperit pudicitia s., Ov.; ut s. complectar -, Qu.; (apud quasdam gentes) cum spe ac voto uxoris s. transigitur, T.<text:line-break/>3. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">En gång,</text:span></text:span><text:span text:style-name="Fraktur"> i uttryck (i synnerhet temporala, inledda med</text:span> quum, ut <text:span text:style-name="Fraktur">m. fl., l. causala, inledda med</text:span> quoniam <text:span text:style-name="Fraktur">o. d., hypothetiska, relativa), der det skedda, som ej kan ändras, sättes i förhållande till sina lika outeblifliga följder:</text:span> si s. amiseris libertatem, non restitues, Pt.; s. admissum reprimi ac coërceri non potest; quoniam s. induxit in animum, licere sibi, quod vellet, fecisset nihilo minus me invito, C.; in nitendo, quod s. annuisset, tantā erat curā, ut -, N.; s. admissum volat irrevocabile telum; quo s. est imbuta recens, servabit odorem testa diu, Hor.; quum s. emissi tenuerunt æquora venti, nil illis vetitum est; si s. <text:span text:style-name="Fraktur">(om I nödwändigt)</text:span> ista datis meritis tam vilibus arma, dividite -, Ov.<text:line-break/>4. <text:span text:style-name="Fraktur"><text:span text:style-name="T1">En gång</text:span></text:span><text:span text:style-name="Fraktur"> jemte flere andre; </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">förste gången:</text:span></text:span> s. atque iterum, s. ac sæpius <text:span text:style-name="Fraktur">(= flere. gånger),</text:span> C., Cs.; s. ad Corfinium, iterum in Hispania, Cs.; s. atque iterum <text:span text:style-name="Fraktur">(ett par gånger),</text:span> Juv.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">S</text:span>ĕmĕlē, es <text:span text:style-name="Fraktur">och</text:span> <text:line-break/>Sĕmĕla, ae, <text:span text:style-name="T5">f.</text:span>: <text:span text:style-name="Fraktur">myth. person, Bacchi moder.</text:span> <text:line-break/>Sĕmĕlēĭus <text:span text:style-name="Fraktur">och</text:span> <text:line-break/>Sĕmĕlēus, <text:span text:style-name="T5">A.</text:span></text:p>
   <text:p text:style-name="P1">Semen, Sement . . . <text:span text:style-name="Fraktur">se</text:span> I. Sero. <text:line-break/>Semermis, -mus <text:span text:style-name="Fraktur">se</text:span> Semi.<text:line-break/>Semestris, -strium <text:span text:style-name="Fraktur">se</text:span> Mensis.<text:line-break/>Semesus <text:span text:style-name="Fraktur">se</text:span> Semi.</text:p>
   <text:p text:style-name="P1"><text:span text:style-name="T1">Sēmi</text:span> <text:span text:style-name="Fraktur">och</text:span><text:line-break/><text:span text:style-name="T2">Sēmis</text:span>, <text:span text:style-name="Fraktur">indecl. räkneord, det förra blott brukligt i sammansättning, </text:span><text:soft-page-break/><text:span text:style-name="Fraktur">det sednare någon gång, hos efterklassiske författare, ensamt: </text:span><text:span text:style-name="Fraktur"><text:span text:style-name="T1">Half-, half:</text:span></text:span> Vitr., Col.</text:p>
